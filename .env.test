# Test environment configuration
# Uses a separate test database for functional tests.
#
# The dbname here is the base; doctrine.yaml's `when@test` block appends
# `_test%env(default::TEST_TOKEN)%` so the effective database is:
#   - meetAgain_test           (no TEST_TOKEN -> single-process phpunit)
#   - meetAgain_test1, _test2, ... (paratest sets TEST_TOKEN per worker)

DATABASE_URL="mysql://meetAgain:UserPassW0rd@ma-db:3306/meetAgain?charset=utf8mb4"

# Use null transport for tests (accepts but doesn't send emails)
MAILER_DSN=null://null

