#!/bin/sh
#
# pre-commit dispatcher -- delegates to bin/commit-hooks.sh which iterates the
# executable scripts in bin/commit-hooks/.
#
# Activate locally with:
#   git config core.hooksPath .githooks
#
# Public/open-source contributors typically have an empty bin/commit-hooks/ and
# the hook becomes a no-op. Private tooling (e.g. .claude/) can drop scripts
# there without the core repo needing to know about them.
#
# Bypass once with: git commit --no-verify

exec bin/commit-hooks.sh
