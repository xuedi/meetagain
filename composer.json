{
  "type": "project",
  "name": "xuedi/meetagain",
  "description": "Simple PHP app to organize a group and schedule recurring events ",
  "license": "EUPL-1.2",
  "authors": [
    {
      "name": "Daniel Koch",
      "email": "xuedi@beijingcode.org",
      "role": "lead"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "ext-intl": "*",
    "ext-imagick": "*",
    "ext-redis": "*",
    "ext-zip": "*",
    "beberlei/doctrineextensions": "^1.5",
    "doctrine/data-fixtures": "^2",
    "doctrine/dbal": "^4",
    "doctrine/doctrine-bundle": "^3.0",
    "doctrine/doctrine-fixtures-bundle": "^4",
    "doctrine/doctrine-migrations-bundle": "^4",
    "doctrine/orm": "^3.3",
    "knplabs/knp-time-bundle": "^2.4",
    "matthiasmullie/minify": "^1.3",
    "nikic/php-parser": "^5",
    "phpdocumentor/reflection-docblock": "^6.0",
    "phpstan/phpdoc-parser": "^2.0",
    "presta/sitemap-bundle": "^4.3",
    "rlanvin/php-rrule": "^2.6",
    "sensiolabs/ansi-to-html": "^2.0",
    "sentry/sentry-symfony": "^5.8",
    "symfony/asset": "8.0.*",
    "symfony/asset-mapper": "8.0.*",
    "symfony/cache": "8.0.*",
    "symfony/console": "8.0.*",
    "symfony/css-selector": "8.0.*",
    "symfony/dotenv": "8.0.*",
    "symfony/expression-language": "8.0.*",
    "symfony/filesystem": "8.0.*",
    "symfony/flex": "^2",
    "symfony/form": "8.0.*",
    "symfony/framework-bundle": "8.0.*",
    "symfony/html-sanitizer": "8.0.*",
    "symfony/http-client": "8.0.*",
    "symfony/intl": "8.0.*",
    "symfony/lock": "8.0.*",
    "symfony/mailer": "8.0.*",
    "symfony/mime": "8.0.*",
    "symfony/monolog-bundle": "^4",
    "symfony/process": "8.0.*",
    "symfony/property-access": "8.0.*",
    "symfony/property-info": "8.0.*",
    "symfony/rate-limiter": "8.0.*",
    "symfony/runtime": "8.0.*",
    "symfony/security-bundle": "8.0.*",
    "symfony/serializer": "8.0.*",
    "symfony/stopwatch": "8.0.*",
    "symfony/string": "8.0.*",
    "symfony/sweego-mailer": "8.0.*",
    "symfony/translation": "8.0.*",
    "symfony/twig-bundle": "8.0.*",
    "symfony/validator": "8.0.*",
    "symfony/web-link": "8.0.*",
    "symfony/yaml": "8.0.*",
    "symfonycasts/sass-bundle": "^0.9.0",
    "symfonycasts/verify-email-bundle": "^1.17",
    "twig/extra-bundle": "^3",
    "twig/string-extra": "^3.22",
    "twig/twig": "^3",
    "wikimedia/composer-merge-plugin": "^2.1"
  },
  "config": {
    "allow-plugins": {
      "carthage-software/mago": true,
      "php-http/discovery": true,
      "symfony/flex": true,
      "symfony/runtime": true,
      "wikimedia/composer-merge-plugin": true
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "plugins/autoload.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "replace": {
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "importmap:install": "symfony-cmd",
      "sass:build": "symfony-cmd",
      "asset-map:compile": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ],
    "phpunit": "vendor/bin/phpunit -c tests/config/phpunit.xml"
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "merge-plugin": {
      "include": [
        "plugins/*/composer.json"
      ],
      "recurse": false,
      "replace": false,
      "ignore-duplicates": false,
      "merge-dev": false,
      "merge-extra": false,
      "merge-scripts": false
    },
    "symfony": {
      "allow-contrib": false,
      "require": "8.0.*"
    }
  },
  "require-dev": {
    "carthage-software/mago": "^1.0.0",
    "dama/doctrine-test-bundle": "^8.4",
    "phpunit/phpunit": "^13",
    "symfony/browser-kit": "8.0.*",
    "symfony/debug-bundle": "8.0.*",
    "symfony/maker-bundle": "^1",
    "symfony/phpunit-bridge": "8.0.*",
    "symfony/web-profiler-bundle": "8.0.*"
  }
}
