{% extends 'base.html.twig' %}

{% block title %}{{ 'filmclub_vote.page_title_create'|trans }}{% endblock %}

{% block body %}
<section class="section">
    <div class="container">
        <h1 class="title">{{ 'filmclub_vote.heading_create_for_event'|trans }}</h1>

        <div class="box">
            <p class="subtitle">{{ event.title(app.request.locale) }}</p>
            <p>{{ event.start|date('d.m.Y H:i') }}</p>
        </div>

        <form method="post">
            <div class="field">
                <label class="label" for="closes_at">{{ 'filmclub_vote.label_closes_at'|trans }}</label>
                <div class="field has-addons flatpickr-field">
                    <div class="control is-expanded">
                        <input class="input" type="text" name="closes_at" id="closes_at" required data-input
                               value="{{ event.start|date_modify('-1 day')|date(get_date_format()) }}">
                    </div>
                    <div class="control">
                        <a class="button" data-toggle><span class="icon"><i class="fa fa-calendar"></i></span></a>
                    </div>
                </div>
                <p class="help">{{ 'filmclub_vote.help_closes_at'|trans }}</p>
            </div>

            <div class="field is-grouped mt-5">
                <div class="control">
                    <button type="submit" class="button is-primary">{{ 'filmclub_vote.button_create'|trans }}</button>
                </div>
                <div class="control">
                    <a href="{{ path('app_filmclub_vote') }}" class="button is-light">{{ 'global.button_cancel'|trans }}</a>
                </div>
            </div>
        </form>
    </div>
</section>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/vendor/flatpickr.min.js') }}"></script>
    {% if app.request.locale != 'en' %}
    <script src="{{ asset('js/vendor/flatpickr-l10n/' ~ app.request.locale ~ '.js') }}"></script>
    {% endif %}
    <script>
        document.querySelectorAll('.flatpickr-field').forEach((el) => {
            flatpickr(el, {
                wrap: true,
                enableTime: true,
                dateFormat: "{{ get_date_format_flatpickr() }}",
                time_24hr: {{ 'A' in get_date_format() ? 'false' : 'true' }},
                locale: "{{ app.request.locale }}"
            });
        });
    </script>
{% endblock %}
