{% extends 'base.html.twig' %}

{% block title %}{{ 'filmclub_vote.page_title'|trans }}{% endblock %}

{% block body %}
<section class="section">
    <div class="container">
        <h1 class="title">{{ 'filmclub_vote.heading_vote_for_next'|trans }}</h1>

        {% if nextEvent %}
            <div class="box">
                <h2 class="subtitle">{{ 'filmclub_vote.label_next_film_night'|trans }}: {{ nextEvent.title(app.request.locale) }}</h2>
                <p>{{ nextEvent.start|date('d.m.Y H:i') }}</p>

                {% set existingVote = null %}
                {% for vote in openVotes %}
                    {% if vote.eventId == nextEvent.id %}
                        {% set existingVote = vote %}
                    {% endif %}
                {% endfor %}

                {% if existingVote %}
                    <a href="{{ path('app_filmclub_vote_show', {id: existingVote.id}) }}" class="button is-primary mt-3">
                        {{ 'filmclub_vote.button_view_vote'|trans }}
                    </a>
                {% elseif is_granted('ROLE_ORGANIZER') %}
                    <a href="{{ path('app_filmclub_vote_create', {eventId: nextEvent.id}) }}" class="button is-success mt-3">
                        <span class="icon"><i class="fa fa-plus"></i></span>
                        <span>{{ 'filmclub_vote.button_create_vote'|trans }}</span>
                    </a>
                {% else %}
                    <p class="has-text-grey mt-3">{{ 'filmclub_vote.no_vote_yet'|trans }}</p>
                {% endif %}
            </div>
        {% else %}
            <div class="notification is-info">
                {{ 'filmclub_vote.no_upcoming_nights'|trans }}
            </div>
        {% endif %}

        {% if openVotes|length > 0 %}
            <h2 class="title is-4 mt-5">{{ 'filmclub_vote.heading_open_votes'|trans }}</h2>
            <div class="columns is-multiline">
                {% for vote in openVotes %}
                    <div class="column is-one-third">
                        <div class="card">
                            <div class="card-content">
                                {% if events[vote.eventId] is defined and events[vote.eventId] %}
                                    <p class="title is-5">{{ events[vote.eventId].title(app.request.locale) }}</p>
                                    <p class="subtitle is-6">{{ events[vote.eventId].start|date('d.m.Y H:i') }}</p>
                                {% else %}
                                    <p class="title is-5">{{ 'filmclub_vote.label_vote_number'|trans }}{{ vote.id }}</p>
                                {% endif %}
                                <p class="is-size-7">{{ 'filmclub_vote.label_closes'|trans }}: {{ vote.closesAt|date('d.m.Y H:i') }}</p>
                                <p>{{ vote.ballots|length }} {{ 'filmclub_vote.label_votes_cast'|trans }}</p>
                            </div>
                            <footer class="card-footer">
                                <a href="{{ path('app_filmclub_vote_show', {id: vote.id}) }}" class="card-footer-item">{{ 'filmclub_vote.button_vote'|trans }}</a>
                                {% if events[vote.eventId] is defined and events[vote.eventId] %}
                                    <a href="{{ path('app_event_details', {id: vote.eventId}) }}" class="card-footer-item">{{ 'filmclub_vote.link_event'|trans }}</a>
                                {% endif %}
                            </footer>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        {% if closedVotes|length > 0 %}
            <h2 class="title is-4 mt-5">{{ 'filmclub_vote.heading_past_votes'|trans }}</h2>
            <table class="table is-fullwidth">
                <thead>
                    <tr>
                        <th>{{ 'filmclub_vote.col_event'|trans }}</th>
                        <th>{{ 'filmclub_vote.col_winner'|trans }}</th>
                        <th>{{ 'filmclub_vote.col_votes'|trans }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for vote in closedVotes %}
                        <tr>
                            <td>
                                {% if events[vote.eventId] is defined and events[vote.eventId] %}
                                    <a href="{{ path('app_event_details', {id: vote.eventId}) }}">
                                        {{ events[vote.eventId].title(app.request.locale) }}
                                    </a>
                                    <br><span class="is-size-7 has-text-grey">{{ events[vote.eventId].start|date('d.m.Y') }}</span>
                                {% else %}
                                    {{ 'filmclub_vote.label_vote_number'|trans }}{{ vote.id }}
                                {% endif %}
                            </td>
                            <td>
                                {% if vote.winningFilm %}
                                    {{ vote.winningFilm.title }}
                                {% else %}
                                    <span class="has-text-grey">{{ 'filmclub_vote.no_votes'|trans }}</span>
                                {% endif %}
                            </td>
                            <td>{{ vote.ballots|length }}</td>
                            <td>
                                <a href="{{ path('app_filmclub_vote_show', {id: vote.id}) }}" class="button is-small">{{ 'filmclub_vote.button_view'|trans }}</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</section>
{% endblock %}
