<h3 class="title is-5">
    <span class="icon"><i class="fa fa-film"></i></span>
    {{ 'filmclub_tile.heading'|trans }}
</h3>

{% if vote %}
    {% if vote.votingOpen %}
        <p>{{ 'filmclub_tile.voting_open'|trans }}</p>
        <p class="has-text-grey is-size-7">{{ 'filmclub_tile.label_closes'|trans }}: {{ vote.closesAt|date('d.m.Y H:i') }}</p>
        <p class="is-size-7">{{ vote.ballots|length }} {{ 'filmclub_tile.label_votes_cast'|trans }}</p>
        <a href="{{ path('app_filmclub_vote_show', {id: vote.id}) }}" class="button is-small is-primary mt-2">
            {{ 'filmclub_tile.button_vote_now'|trans }}
        </a>
    {% else %}
        {% if vote.winningFilm %}
            <p class="has-text-weight-bold">{{ vote.winningFilm.title }}</p>
            <p class="has-text-grey is-size-7">{{ vote.winningFilm.year }} - {{ vote.winningFilm.runtime }} min</p>
        {% else %}
            <p class="has-text-grey">{{ 'filmclub_tile.no_film_selected'|trans }}</p>
        {% endif %}
        <a href="{{ path('app_filmclub_vote_show', {id: vote.id}) }}" class="button is-small is-light mt-2">
            {{ 'filmclub_tile.button_view_results'|trans }}
        </a>
    {% endif %}
{% else %}
    <p class="has-text-grey">{{ 'filmclub_tile.no_vote_yet'|trans }}</p>
    {% if is_granted('ROLE_ORGANIZER') %}
        <a href="{{ path('app_filmclub_vote_create', {eventId: eventId}) }}" class="button is-small is-success mt-2">
            <span class="icon"><i class="fa fa-plus"></i></span>
            <span>{{ 'filmclub_tile.button_create_vote'|trans }}</span>
        </a>
    {% endif %}
{% endif %}
