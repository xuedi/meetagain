{% if selection %}
<div class="mt-2">
    <p class="is-size-7 has-text-weight-semibold">{{ 'filmclub_tile.heading'|trans }}</p>
    {% if selection.film.posterImage %}
    <figure class="image mb-1">
        {% include '_components/image.html.twig' with {'image': selection.film.posterImage, 'size': '100x150', 'alt': selection.film.title} %}
    </figure>
    {% endif %}
    <p class="is-size-7">
        <a href="{{ path('app_plugin_filmclub_film_show', {id: selection.film.id}) }}">{{ selection.film.title }}</a>
    </p>
    {% if is_granted('ROLE_USER') and not isWishlisted %}
    <form method="POST" action="{{ path('app_plugin_filmclub_wishlist_add', {filmId: selection.film.id}) }}" style="display: inline">
        <button type="submit" class="button is-small is-text is-size-7">{{ 'filmclub_tile.button_add_wishlist'|trans }}</button>
    </form>
    {% endif %}
</div>
{% elseif activePoll %}
<div class="mt-2">
    <p class="is-size-7 has-text-weight-semibold">{{ 'filmclub_tile.heading'|trans }}</p>
    <p class="is-size-7 has-text-grey">{{ 'filmclub_tile.poll_closes_in'|trans({'%date%': activePoll.endDate|date('Y-m-d')}) }}</p>
    {% set candidates = activePoll.films|slice(0, 4) %}
    {% if candidates|length > 0 %}
    <div style="display: flex; gap: 0.35rem; flex-wrap: wrap; margin-top: 0.5rem">
        {% for film in candidates %}
            {% if film.posterImage %}
            <figure class="image" style="width: 40px; margin: 0">
                {% include '_components/image.html.twig' with {'image': film.posterImage, 'size': '100x150', 'alt': film.title} %}
            </figure>
            {% endif %}
        {% endfor %}
        {% if activePoll.films|length > candidates|length %}
        <span class="is-size-7 has-text-grey" style="align-self: center">+{{ activePoll.films|length - candidates|length }}</span>
        {% endif %}
    </div>
    {% endif %}
    {% if is_granted('ROLE_USER') %}
    <p class="is-size-7 has-text-grey mt-2">
        {{ (hasUserVoted ? 'filmclub_tile.status_voted' : 'filmclub_tile.status_not_voted')|trans }}
    </p>
    {% endif %}
    <a href="{{ path('app_plugin_filmclub_poll_vote', {id: activePoll.id}) }}" class="button is-small is-link mt-2">
        {{ 'filmclub_tile.button_vote_now'|trans }}
    </a>
</div>
{% else %}
<div class="mt-2">
    <p class="is-size-7 has-text-weight-semibold">{{ 'filmclub_tile.heading'|trans }}</p>
    <p class="is-size-7 has-text-grey mb-2">{{ 'filmclub_tile.no_film_selected_yet'|trans }}</p>
    {% if canCreatePoll %}
        <div class="buttons are-small mb-0">
            {% if wishlistPoolCount > 0 %}
            <a href="{{ path('app_plugin_filmclub_wishlist_group') }}?event_id={{ eventId }}" class="button is-link is-small">{{ 'filmclub_tile.button_create_poll'|trans }}</a>
            {% endif %}
            <a href="{{ path('app_plugin_filmclub_choose_directly', {eventId: eventId}) }}" class="button is-small">{{ 'filmclub_tile.button_choose_directly'|trans }}</a>
        </div>
    {% else %}
        <div class="buttons are-small mb-0">
            <a href="{{ path('app_plugin_filmclub_poll_create', {eventId: eventId}) }}" class="button is-link is-small">{{ 'filmclub_tile.link_create_poll'|trans }}</a>
            <a href="{{ path('app_plugin_filmclub_manage_select', {eventId: eventId}) }}" class="button is-small">{{ 'filmclub_tile.link_pick_film'|trans }}</a>
        </div>
    {% endif %}
</div>
{% endif %}
