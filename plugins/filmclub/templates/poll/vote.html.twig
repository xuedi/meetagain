{% extends '@Filmclub/base_filmclub.html.twig' %}

{% block title %}{{ 'filmclub_poll.page_title_vote'|trans }}{% endblock %}

{% block filmclub_body %}
<h1 class="title">{{ 'filmclub_poll.page_title_vote'|trans }}</h1>

<p class="has-text-grey mb-4">
    {{ 'filmclub_poll.poll_closes_on'|trans({'%date%': poll.endDate|date('Y-m-d')}) }}
</p>

<form method="POST" action="{{ path('app_plugin_filmclub_poll_vote', {id: poll.id}) }}" id="vote-form">
    {% for film in poll.films %}
    <div class="box mb-3">
        <label class="checkbox" style="display: flex; align-items: center; gap: 1rem; cursor: pointer">
            <input type="checkbox" name="films[]" value="{{ film.id }}"
                {{ film.id in userVotedFilmIds ? 'checked' : '' }}
                onchange="updateCounter()">
            {% if film.posterImage %}
            <figure class="image" style="width: 40px; margin: 0; flex-shrink: 0">
                {% include '_components/image.html.twig' with {'image': film.posterImage, 'size': '100x150', 'alt': film.title} %}
            </figure>
            {% endif %}
            <div>
                <p class="has-text-weight-semibold">{{ film.title }}</p>
                {% if film.year %}
                <p class="is-size-7 has-text-grey">{{ film.year }}</p>
                {% endif %}
            </div>
        </label>
    </div>
    {% endfor %}

    <p class="mb-3">
        <span id="selection-counter">{{ 'filmclub_poll.selected_count'|trans({'%selected%': userVotedFilmIds|length, '%total%': poll.films|length}) }}</span>
    </p>

    <button type="submit" class="button is-primary">{{ 'filmclub_poll.button_cast_votes'|trans }}</button>
    <a href="{{ path('app_plugin_filmclub_poll_show', {id: poll.id}) }}" class="button ml-2">{{ 'filmclub_poll.button_view_results'|trans }}</a>
</form>

<script>
function updateCounter() {
    const total = document.querySelectorAll('[name="films[]"]').length;
    const selected = document.querySelectorAll('[name="films[]"]:checked').length;
    const tpl = {{ ('filmclub_poll.selected_count'|trans({'%selected%': '__SEL__', '%total%': '__TOT__'}))|json_encode|raw }};
    document.getElementById('selection-counter').textContent = tpl.replace('__SEL__', selected).replace('__TOT__', total);
}
</script>
{% endblock %}
