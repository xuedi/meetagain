<div class="columns is-multiline">
    {% for film in films %}
        <div class="column is-narrow" style="width: 200px;">
            <a href="{{ path('app_plugin_filmclub_film_show', {id: film.id}) }}">
                <div class="card">
                    <div class="card-image">
                        <figure class="image is-2by3">
                            {% include '_components/image.html.twig' with {'image': film.posterImage, 'size': '400x600', 'alt': film.title} %}
                        </figure>
                    </div>
                    <div class="card-content p-2">
                        <p class="has-text-centered is-size-7 has-text-dark" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            {{ film.title }}
                        </p>
                        {% if film.year %}
                            <p class="has-text-centered is-size-7 has-text-grey">{{ film.year }}</p>
                        {% endif %}
                    </div>
                </div>
            </a>
        </div>
    {% else %}
        <div class="column">
            <p class="has-text-grey">{{ 'filmclub_film.empty_state'|trans }}</p>
        </div>
    {% endfor %}
</div>
