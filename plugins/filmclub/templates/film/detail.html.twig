{% extends '@Filmclub/base_filmclub.html.twig' %}

{% block title %}{{ film.title }}{% endblock %}

{% block filmclub_body %}
<div class="columns">
    <div class="column is-4-tablet is-12-mobile">
        {% if film.posterImage %}
        <figure class="image" style="border: 1px solid #e0e0e0">
            <img src="{{ film.posterImage.publicPath ?? '' }}" alt="{{ film.title }}">
        </figure>
        {% else %}
        <div class="box has-text-centered has-text-grey" style="min-height: 240px; display:flex; align-items:center; justify-content:center">
            <span>{{ 'filmclub_film.no_poster'|trans }}</span>
        </div>
        {% endif %}
    </div>
    <div class="column">
        <h1 class="title">{{ film.title }}</h1>
        {% if film.originalTitle and film.originalTitle != film.title %}
        <p class="subtitle has-text-grey">{{ film.originalTitle }}</p>
        {% endif %}

        <table class="table is-narrow">
            {% if film.year %}
            <tr>
                <th>{{ 'filmclub_film.col_year'|trans }}</th>
                <td>{{ film.year }}</td>
            </tr>
            {% endif %}
            {% if film.runtime %}
            <tr>
                <th>{{ 'filmclub_film.col_runtime'|trans }}</th>
                <td>{{ film.runtime }} min</td>
            </tr>
            {% endif %}
            {% if film.genres is not empty %}
            <tr>
                <th>{{ 'filmclub_film.col_genres'|trans }}</th>
                <td>
                    {% for genre in film.genres %}
                    <span class="tag">{{ genre }}</span>
                    {% endfor %}
                </td>
            </tr>
            {% endif %}
        </table>

        {% if film.description %}
        <p class="mt-3">{{ film.description }}</p>
        {% endif %}

        {% if wanterCount > 0 %}
        <p class="mt-3">
            {{ include('@Filmclub/_components/wishlist_counter.html.twig', {count: wanterCount}) }}
        </p>
        {% endif %}

        {% if is_granted('ROLE_USER') %}
        <div class="mt-4">
            {% if isWishlisted %}
            <form method="POST" action="{{ path('app_plugin_filmclub_wishlist_remove', {filmId: film.id}) }}" style="display: inline">
                <button type="submit" class="button is-small">
                    {{ 'filmclub_wishlist.button_remove'|trans }}
                </button>
            </form>
            {% else %}
            <form method="POST" action="{{ path('app_plugin_filmclub_wishlist_add', {filmId: film.id}) }}" style="display: inline">
                <button type="submit" class="button is-small">
                    {{ 'filmclub_wishlist.button_add'|trans }}
                </button>
            </form>
            {% endif %}

            <form method="POST" action="{{ path('app_plugin_filmclub_suggest', {filmId: film.id}) }}" style="display: inline">
                <button type="submit" class="button is-small">
                    {{ 'filmclub_suggestion.button_suggest'|trans }}
                </button>
            </form>

            <a href="{{ path('app_plugin_filmclub_note_edit', {filmId: film.id}) }}" class="ml-2">
                {{ userNote ? 'filmclub_note.link_edit_note'|trans : 'filmclub_note.link_add_note'|trans }}
            </a>
        </div>
        {% endif %}
    </div>
</div>

{% if selections is not empty %}
<hr>
<h2 class="subtitle">{{ 'filmclub_film.heading_watched_history'|trans }}</h2>
<ul>
    {% for selection in selections %}
    <li>{{ selection.selectedAt|date('Y-m-d') }}</li>
    {% endfor %}
</ul>
{% endif %}

{% if revealedNotes is not empty %}
<hr>
<h2 class="subtitle">{{ 'filmclub_note.heading_revealed'|trans }}</h2>
{% for note in revealedNotes %}
<blockquote class="mb-3" style="border-left: 3px solid #dbdbdb; padding-left: 1rem">
    <p>{{ note.body }}</p>
    <footer class="has-text-grey is-size-7">
        {{ get_user_name(note.userId) }} &middot; {{ note.createdAt|date('Y-m-d') }}
    </footer>
</blockquote>
{% endfor %}
{% endif %}
{% endblock %}
