{% extends '@Filmclub/base_filmclub.html.twig' %}

{% block title %}{{ 'filmclub_tile.heading_choose_film'|trans }}{% endblock %}

{% block filmclub_body %}
<h1 class="title">{{ 'filmclub_tile.heading_choose_film'|trans }}</h1>

<div class="box mb-4">
    <p class="subtitle">{{ event.title(app.request.locale) }}</p>
    <p class="has-text-grey is-size-7">{{ event.start|date('d.m.Y') }}</p>
</div>

{% if films is empty %}
<p class="has-text-grey">{{ 'filmclub_wishlist.empty'|trans }}</p>
{% else %}
<div class="columns is-multiline">
    {% for film in films %}
    <div class="column is-12-mobile is-6-tablet is-4-desktop">
        <div class="box">
            <div class="media">
                {% if film.posterImage %}
                <div class="media-left">
                    <figure class="image is-48x48">
                        <img src="{{ film.posterImage.publicPath ?? '' }}" alt="{{ film.title }}" style="object-fit: cover">
                    </figure>
                </div>
                {% endif %}
                <div class="media-content">
                    <p class="has-text-weight-semibold">{{ film.title }}</p>
                    {% if film.year %}<p class="is-size-7 has-text-grey">{{ film.year }}</p>{% endif %}
                </div>
            </div>
            <form method="POST" action="{{ path('app_plugin_filmclub_choose_directly_submit', {eventId: event.id, filmId: film.id}) }}" class="mt-2">
                <button type="submit" class="button is-primary is-small is-fullwidth">
                    {{ 'filmclub_tile.button_choose_directly'|trans }}
                </button>
            </form>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

<a href="{{ path('app_plugin_filmclub_views_list') }}" class="button mt-4">{{ 'global.button_cancel'|trans }}</a>
{% endblock %}
