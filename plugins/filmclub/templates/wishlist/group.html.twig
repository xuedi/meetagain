{% extends '@Filmclub/base_filmclub.html.twig' %}

{% block title %}{{ 'filmclub_wishlist.page_title_group'|trans }}{% endblock %}

{% block filmclub_body %}
<h1 class="title">{{ 'filmclub_wishlist.page_title_group'|trans }}</h1>

<div class="tabs">
    <ul>
        <li class="{{ activeTab is not defined or activeTab != 'member' ? 'is-active' : '' }}" id="tab-by-film">
            <a href="#by-film" onclick="switchTab('by-film')">{{ 'filmclub_wishlist.tab_by_film'|trans }}</a>
        </li>
        <li class="{{ activeTab is defined and activeTab == 'member' ? 'is-active' : '' }}" id="tab-by-member">
            <a href="#by-member" onclick="switchTab('by-member')">{{ 'filmclub_wishlist.tab_by_member'|trans }}</a>
        </li>
    </ul>
</div>

<div id="by-film">
{% if byFilm is empty %}
<p class="has-text-grey">{{ 'filmclub_wishlist.empty'|trans }}</p>
{% else %}

{% if is_granted('ROLE_ORGANIZER') %}
<form method="POST" action="{{ path('app_plugin_filmclub_poll_create_from_pool') }}" id="pool-form">
    <div class="field is-grouped mb-4">
        <div class="control">
            <div class="select">
                <select name="event_id" required>
                    <option value="">{{ 'filmclub_pool.flash_no_event'|trans }}</option>
                    {% for event in upcomingEvents %}
                    <option value="{{ event.id }}">{{ event.title(app.request.locale) }} - {{ event.start|date('Y-m-d') }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="control">
            <button type="submit" class="button is-primary">{{ 'filmclub_pool.button_create_poll'|trans }}</button>
        </div>
    </div>
{% endif %}

<table class="table is-fullwidth is-striped">
    <thead>
        <tr>
            {% if is_granted('ROLE_ORGANIZER') %}
            <th>{{ 'filmclub_pool.col_select'|trans }}</th>
            {% endif %}
            <th>{{ 'filmclub_wishlist.col_film'|trans }}</th>
            <th>{{ 'filmclub_wishlist.col_wanter_count'|trans }}</th>
            <th>{{ 'filmclub_wishlist.col_priority'|trans }}</th>
        </tr>
    </thead>
    <tbody>
        {% for row in byFilm %}
        <tr>
            {% if is_granted('ROLE_ORGANIZER') %}
            <td><input type="checkbox" name="films[]" value="{{ row.film.id }}"></td>
            {% endif %}
            <td>
                <a href="{{ path('app_plugin_filmclub_film_show', {id: row.film.id}) }}">
                    {% if row.film.posterImage %}
                    <img src="{{ row.film.posterImage.publicPath ?? '' }}" alt="{{ row.film.title }}" style="height: 40px; vertical-align: middle; margin-right: 0.5rem">
                    {% endif %}
                    {{ row.film.title }}
                    {% if row.film.year %}<span class="has-text-grey is-size-7">({{ row.film.year }})</span>{% endif %}
                </a>
            </td>
            <td>{{ 'filmclub_wishlist.wanted_by_members'|trans({'%count%': row.wanterCount}) }}</td>
            <td>
                {% if row.totalPriority > 0 %}
                {{ 'filmclub_wishlist.priority_label'|trans({'%count%': row.totalPriority}) }}
                {% else %}
                <span class="has-text-grey">-</span>
                {% endif %}
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>

{% if is_granted('ROLE_ORGANIZER') %}
</form>
{% endif %}

{% endif %}
</div>

<div id="by-member" style="display: none">
{% if byMember is empty %}
<p class="has-text-grey">{{ 'filmclub_wishlist.empty'|trans }}</p>
{% else %}
{% for userId, entries in byMember %}
<div class="mb-4">
    <p class="is-size-6 has-text-weight-semibold">
        <a href="{{ path('app_member_view', {id: userId}) }}">{{ get_user_name(userId) }}</a>
    </p>
    <ul class="ml-4">
        {% for entry in entries %}
        <li>
            <a href="{{ path('app_plugin_filmclub_film_show', {id: entry.film.id}) }}">{{ entry.film.title }}{% if entry.film.year %} <span class="has-text-grey is-size-7">({{ entry.film.year }})</span>{% endif %}</a>
            {% if entry.priorityCounter > 0 %}
            <span class="is-size-7 has-text-grey-dark">({{ 'filmclub_wishlist.priority_label'|trans({'%count%': entry.priorityCounter}) }})</span>
            {% endif %}
        </li>
        {% endfor %}
    </ul>
</div>
{% endfor %}
{% endif %}
</div>

<script>
function switchTab(tab) {
    document.getElementById('by-film').style.display = tab === 'by-film' ? '' : 'none';
    document.getElementById('by-member').style.display = tab === 'by-member' ? '' : 'none';
    document.getElementById('tab-by-film').classList.toggle('is-active', tab === 'by-film');
    document.getElementById('tab-by-member').classList.toggle('is-active', tab === 'by-member');
}
document.querySelectorAll('.tabs a').forEach(function(a) { a.addEventListener('click', function(e) { e.preventDefault(); }); });
</script>
{% endblock %}
