{% extends 'base.html.twig' %}

{% block title %}Pending Approval - Book Club{% endblock %}

{% block body %}
<section class="section">
    <div class="container">
        <nav class="breadcrumb">
            <ul>
                <li><a href="{{ path('app_plugin_bookclub') }}">Book Club</a></li>
                <li class="is-active"><a>Pending Approval</a></li>
            </ul>
        </nav>

        <h1 class="title">Books Pending Approval</h1>

        {% if books|length > 0 %}
            <table class="table is-fullwidth is-striped">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Author</th>
                        <th>ISBN</th>
                        <th>Added By</th>
                        <th>Added At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for book in books %}
                        <tr>
                            <td>
                                <a href="{{ path('app_plugin_bookclub_book_show', {id: book.id}) }}">
                                    {{ book.title }}
                                </a>
                            </td>
                            <td>{{ book.author ?? 'Unknown' }}</td>
                            <td>{{ book.isbn }}</td>
                            <td>{{ get_user_name(book.createdBy) }}</td>
                            <td>{{ book.createdAt|date('Y-m-d H:i') }}</td>
                            <td>
                                <a href="{{ path('app_profile_review') }}" class="button is-small is-info is-outlined">
                                    <span class="icon"><i class="fas fa-check-double"></i></span>
                                    <span>Review</span>
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="notification is-light">
                <p>No books pending approval!</p>
            </div>
        {% endif %}

    </div>
</section>
{% endblock %}
