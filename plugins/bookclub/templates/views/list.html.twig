<table class="table is-fullwidth is-striped is-hoverable">
    <thead>
        <tr>
            <th></th>
            <th>{{ 'bookclub_views.col_title'|trans }}</th>
            <th>{{ 'bookclub_views.col_author'|trans }}</th>
            <th>{{ 'bookclub_views.col_year'|trans }}</th>
            <th>{{ 'bookclub_views.col_pages'|trans }}</th>
            <th>{{ 'bookclub_views.col_discussed_at'|trans }}</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        {% for book in books %}
            <tr>
                <td style="width: 50px;">
                    {% if book.coverImage %}
                        {% include '_components/image.html.twig' with {'image': book.coverImage, 'size': '200x250'} %}
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_plugin_bookclub_book_show', {id: book.id}) }}">{{ book.title }}</a>
                </td>
                <td>{{ book.author ?? 'bookclub_views.label_unknown'|trans }}</td>
                <td>{{ book.publishedYear ?? '-' }}</td>
                <td>{{ book.pageCount ?? '-' }}</td>
                <td>
                    {% for selection in book.selections %}
                        <a href="{{ path('app_event_details', {id: selection.event.id}) }}" class="is-size-7">
                            {{ selection.event.getTitle(app.locale) }}
                        </a>
                    {% else %}
                        <span class="has-text-grey">-</span>
                    {% endfor %}
                </td>
                <td>
                    {% if is_granted('ROLE_USER') %}
                        <a href="{{ path('app_plugin_bookclub_note_edit', {bookId: book.id}) }}" class="button is-small is-light">{{ 'bookclub_views.button_notes'|trans }}</a>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
