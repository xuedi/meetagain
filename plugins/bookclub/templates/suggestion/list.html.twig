{% extends 'base.html.twig' %}

{% block title %}Suggestions - Book Club{% endblock %}

{% block body %}
<section class="section">
    <div class="container">
        <nav class="breadcrumb">
            <ul>
                <li><a href="{{ path('app_plugin_bookclub') }}">Book Club</a></li>
                <li class="is-active"><a>Suggestions</a></li>
            </ul>
        </nav>

        <h1 class="title">Book Suggestions</h1>

        {% if userSuggestions|length == 0 %}
            <div class="notification is-light">
                You haven't suggested a book yet. Choose one below or from the <a href="{{ path('app_plugin_bookclub') }}">book catalog</a>.
            </div>
        {% endif %}

        {% set userSuggestionIds = userSuggestions|map(s => s.id) %}

        <div class="columns">
            <div class="column is-8">
                <h2 class="subtitle">Pending Suggestions (by priority)</h2>

                {% if suggestions|length > 0 %}
                    <table class="table is-fullwidth is-striped">
                        <thead>
                            <tr>
                                <th>Book</th>
                                <th>Author</th>
                                <th>Suggested By</th>
                                <th>Priority</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for suggestion in suggestions %}
                                <tr>
                                    <td>
                                        <a href="{{ path('app_plugin_bookclub_book_show', {id: suggestion.book.id}) }}">
                                            {{ suggestion.book.title }}
                                        </a>
                                    </td>
                                    <td>{{ suggestion.book.author ?? 'Unknown' }}</td>
                                    <td>{{ get_user_name(suggestion.suggestedBy) }}</td>
                                    <td>
                                        {% set r = suggestion.resubmitCount %}
                                        {% if r == 0 %}
                                            <span class="icon" title="New"><i class="fa fa-thermometer-empty"></i></span>
                                        {% elseif r == 1 %}
                                            <span class="icon" title="Skipped once"><i class="fa fa-thermometer-quarter"></i></span>
                                        {% elseif r == 2 %}
                                            <span class="icon" title="Skipped {{ r }} times"><i class="fa fa-thermometer-half"></i></span>
                                        {% elseif r == 3 %}
                                            <span class="icon" title="Skipped {{ r }} times"><i class="fa fa-thermometer-three-quarters"></i></span>
                                        {% else %}
                                            <span class="icon" title="Skipped {{ r }} times"><i class="fa fa-thermometer-full"></i></span>
                                        {% endif %}
                                    </td>
                                    <td class="has-text-right">
                                        {% if suggestion.id in userSuggestionIds %}
                                            <a href="{{ path('app_plugin_bookclub_withdraw', {suggestionId: suggestion.id}) }}">
                                                <span class="icon"><i class="fa fa-trash"></i></span>
                                            </a>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="has-text-grey">No pending suggestions.</p>
                {% endif %}

                <p class="help has-text-grey mt-2">
                    Priority is based on how often a book has been skipped in previous polls and how long it has been waiting. Books that were not elected in a poll automatically move up in priority for the next one.
                </p>

                {% if is_granted('ROLE_ORGANIZER') %}
                    <div class="box mt-4">
                        <h3 class="title is-5">Manager Actions</h3>
                        <a href="{{ path('app_plugin_bookclub_poll_create') }}" class="button is-primary is-fullwidth">
                            Create Poll from Suggestions
                        </a>
                    </div>
                {% endif %}

            </div>

            <div class="column is-4">
                {% if books|length > 0 %}
                    <div class="box">
                        <h3 class="title is-5">Suggest a Book</h3>
                        <p class="mb-3">Select a book to suggest for the next poll:</p>
                        {% for book in books %}
                            <form action="{{ path('app_plugin_bookclub_suggest', {bookId: book.id}) }}" method="post" class="mb-2">
                                <button type="submit" class="button is-small is-fullwidth is-outlined">
                                    {{ book.title }}
                                </button>
                            </form>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
{% endblock %}
