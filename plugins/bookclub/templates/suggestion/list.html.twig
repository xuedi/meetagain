{% extends 'base.html.twig' %}

{% block title %}{{ 'bookclub_suggestion.page_title'|trans }} - {{ 'bookclub.page_title'|trans }}{% endblock %}

{% block body %}
<section class="section">
    <div class="container">
        <nav class="breadcrumb">
            <ul>
                <li><a href="{{ path('app_plugin_bookclub') }}">{{ 'bookclub.page_title'|trans }}</a></li>
                <li class="is-active"><a>{{ 'bookclub_suggestion.breadcrumb'|trans }}</a></li>
            </ul>
        </nav>

        <h1 class="title">{{ 'bookclub_suggestion.heading'|trans }}</h1>

        {% if userSuggestions|length == 0 %}
            <div class="notification is-light">
                {{ 'bookclub_suggestion.empty_hint'|trans({'%url%': path('app_plugin_bookclub')})|raw }}
            </div>
        {% endif %}

        {% set userSuggestionIds = userSuggestions|map(s => s.id) %}

        <div class="columns">
            <div class="column is-8">
                <h2 class="subtitle">{{ 'bookclub_suggestion.heading_pending'|trans }}</h2>

                {% if suggestions|length > 0 %}
                    <table class="table is-fullwidth is-striped">
                        <thead>
                            <tr>
                                <th>{{ 'bookclub_suggestion.col_book'|trans }}</th>
                                <th>{{ 'bookclub_suggestion.col_author'|trans }}</th>
                                <th>{{ 'bookclub_suggestion.col_suggested_by'|trans }}</th>
                                <th>{{ 'bookclub_suggestion.col_priority'|trans }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for suggestion in suggestions %}
                                <tr>
                                    <td>
                                        <a href="{{ path('app_plugin_bookclub_book_show', {id: suggestion.book.id}) }}">
                                            {{ suggestion.book.title }}
                                        </a>
                                    </td>
                                    <td>{{ suggestion.book.author ?? 'bookclub_suggestion.label_unknown'|trans }}</td>
                                    <td>{{ get_user_name(suggestion.suggestedBy) }}</td>
                                    <td>
                                        {% set r = suggestion.resubmitCount %}
                                        {% if r == 0 %}
                                            <span class="icon" title="{{ 'bookclub_suggestion.priority_new'|trans }}"><i class="fa fa-thermometer-empty"></i></span>
                                        {% elseif r == 1 %}
                                            <span class="icon" title="{{ 'bookclub_suggestion.priority_skipped_once'|trans }}"><i class="fa fa-thermometer-quarter"></i></span>
                                        {% elseif r == 2 %}
                                            <span class="icon" title="{{ 'bookclub_suggestion.priority_skipped_times'|trans({'%count%': r}) }}"><i class="fa fa-thermometer-half"></i></span>
                                        {% elseif r == 3 %}
                                            <span class="icon" title="{{ 'bookclub_suggestion.priority_skipped_times'|trans({'%count%': r}) }}"><i class="fa fa-thermometer-three-quarters"></i></span>
                                        {% else %}
                                            <span class="icon" title="{{ 'bookclub_suggestion.priority_skipped_times'|trans({'%count%': r}) }}"><i class="fa fa-thermometer-full"></i></span>
                                        {% endif %}
                                    </td>
                                    <td class="has-text-right">
                                        {% if suggestion.id in userSuggestionIds %}
                                            <a href="{{ path('app_plugin_bookclub_withdraw', {suggestionId: suggestion.id}) }}">
                                                <span class="icon"><i class="fa fa-trash"></i></span>
                                            </a>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="has-text-grey">{{ 'bookclub_suggestion.empty_no_suggestions'|trans }}</p>
                {% endif %}

                <p class="help has-text-grey mt-2">{{ 'bookclub_suggestion.priority_help'|trans }}</p>

                {% if is_granted('ROLE_ORGANIZER') %}
                    <div class="box mt-4">
                        <h3 class="title is-5">{{ 'bookclub_suggestion.heading_manager_actions'|trans }}</h3>
                        <a href="{{ path('app_plugin_bookclub_poll_create') }}" class="button is-primary is-fullwidth">
                            {{ 'bookclub_suggestion.button_create_poll'|trans }}
                        </a>
                    </div>
                {% endif %}

            </div>

            <div class="column is-4">
                {% if books|length > 0 %}
                    <div class="box">
                        <h3 class="title is-5">{{ 'bookclub_suggestion.heading_suggest_box'|trans }}</h3>
                        <p class="mb-3">{{ 'bookclub_suggestion.suggest_intro'|trans }}</p>
                        {% for book in books %}
                            <form action="{{ path('app_plugin_bookclub_suggest', {bookId: book.id}) }}" method="post" class="mb-2">
                                <button type="submit" class="button is-small is-fullwidth is-outlined">
                                    {{ book.title }}
                                </button>
                            </form>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
{% endblock %}
