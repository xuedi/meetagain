{% extends 'admin/base.html.twig' %}

{% block content %}
    <div class="container">
        <h1 class="title">{{ 'ranking_admin_member_rank.page_title'|trans }}: {{ targetUser.name }}</h1>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="notification is-{{ type }}">{{ message|trans }}</div>
            {% endfor %}
        {% endfor %}

        {{ form_start(form) }}
        {{ form_widget(form) }}
        <div class="field">
            <button type="submit" class="button is-primary">{{ 'ranking_admin_member_rank.button_save'|trans }}</button>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
