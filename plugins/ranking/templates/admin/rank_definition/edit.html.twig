{% extends 'admin/base.html.twig' %}

{% block content %}
    <div class="container">

        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="notification is-{{ type }}">{{ message|trans }}</div>
            {% endfor %}
        {% endfor %}

        {{ form_start(form) }}
        {{ form_widget(form) }}
        <div class="field">
            <button type="submit" class="button is-primary">{{ 'global.button_save'|trans }}</button>
        </div>
        {{ form_end(form) }}

    </div>
{% endblock %}
