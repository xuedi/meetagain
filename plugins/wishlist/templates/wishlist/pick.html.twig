{% extends '@Wishlist/base_wishlist.html.twig' %}

{% block title %}{{ 'wishlist_pick.page_title'|trans }}{% endblock %}

{% block wishlist_body %}
<h1 class="title">{{ 'wishlist_pick.page_title'|trans }}</h1>

<div class="box mb-4">
    <p class="subtitle mb-1">{{ event.title(app.request.locale) }}</p>
    <p class="has-text-grey is-size-7">{{ event.start|date('d.m.Y') }}</p>
</div>

{% if candidates is empty %}
<div class="notification is-warning">{{ 'wishlist_pick.empty'|trans }}</div>
<a href="{{ path('app_wishlist_group') }}" class="button">{{ 'global.button_cancel'|trans }}</a>
{% else %}
<p class="mb-3 has-text-grey">{{ 'wishlist_pick.intro'|trans }}</p>
<table class="table is-fullwidth is-striped">
    <thead>
        <tr>
            <th>{{ 'wishlist_pick.col_item'|trans }}</th>
            <th>{{ 'wishlist_pick.col_wanters'|trans }}</th>
            <th>{{ 'wishlist_pick.col_priority'|trans }}</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        {% for candidate in candidates %}
        <tr>
            <td>{{ item_list_cell(itemType, candidate.itemId) }}</td>
            <td>{{ 'wishlist_pick.wanted_by_members'|trans({'%count%': candidate.wanterCount}) }}</td>
            <td>
                {% if candidate.totalPriority > 0 %}
                {{ 'wishlist_entry.priority_label'|trans({'%count%': candidate.totalPriority}) }}
                {% else %}
                <span class="has-text-grey">-</span>
                {% endif %}
            </td>
            <td>
                <form method="POST" action="{{ path('app_item_attach', {id: event.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('app_item_attach' ~ event.id) }}">
                    <input type="hidden" name="item_type" value="{{ itemType }}">
                    <input type="hidden" name="item_id" value="{{ candidate.itemId }}">
                    <button type="submit" class="button is-small is-link">{{ 'wishlist_pick.button_attach'|trans }}</button>
                </form>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endif %}
{% endblock %}
