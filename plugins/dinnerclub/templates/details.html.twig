{% extends 'base.html.twig' %}

{% block title %}{{ "page_plugin_dinnerclub_title_details"|trans }} - {{ dish.getTranslatedName(app.locale) ?: dish.getAnyTranslatedName() }}{% endblock %}

{% block stylesheets %}
    {% if dish.previewImage or galleryImages|length > 0 %}
        <link rel="stylesheet" href="{{ '/stylesheet/fancybox.css' }}"/>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {% if dish.previewImage or galleryImages|length > 0 %}
        <script src="{{ '/javascript/fancybox.umd.js' }}"></script>
    {% endif %}
{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <nav class="breadcrumb" aria-label="breadcrumbs">
                <ul>
                    <li><a href="{{ path('app_plugin_dinnerclub') }}">Dishes</a></li>
                    <li class="is-active"><a href="#" aria-current="page">{{ dish.getTranslatedName(app.locale) ?: dish.getAnyTranslatedName() }}</a></li>
                </ul>
            </nav>

            <div class="columns">
                <div class="column is-8">
                    <div class="box">
                        <div class="level">
                            <div class="level-left">
                                <div class="level-item">
                                    <h1 class="title is-3">{{ dish.getTranslatedName(app.locale) ?: dish.getAnyTranslatedName() }}</h1>
                                </div>
                                {% if not dish.approved %}
                                    <div class="level-item">
                                        <span class="tag is-warning">Pending Approval</span>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="level-right">
                                <div class="level-item">
                                    {% if is_granted('ROLE_USER') %}
                                        <button class="button is-white like-button"
                                                data-url="{{ path('plugin_dinnerclub_like', {id: dish.id}) }}"
                                                data-liked="{{ userLiked ? 'true' : 'false' }}">
                                            <span class="icon {% if userLiked %}has-text-danger{% else %}has-text-grey-light{% endif %}">
                                                <i class="fa-solid fa-heart"></i>
                                            </span>
                                        </button>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        {% if dish.getPhonetic() %}
                            <p class="subtitle is-5 has-text-grey">
                                <span class="icon"><i class="fa-solid fa-volume-high"></i></span>
                                {{ dish.getPhonetic() }}
                            </p>
                        {% endif %}

                        {% if dish.previewImage %}
                            {% set reportCaption = 'You can <a href=' ~ path('app_report_image', {'id': dish.previewImage.id}) ~ '>report</a> an image if there is something wrong.' %}
                            <figure class="image mb-2">
                                <a data-fancybox="dish-gallery" data-caption="{{ reportCaption }}" href="/images/thumbnails/{{ dish.previewImage.hash }}_1024x768.webp">
                                    {% include '_components/image.html.twig' with {'image': dish.previewImage, 'size': '600x400'} %}
                                </a>
                            </figure>
                        {% endif %}

                        {% if galleryImages|length > 0 %}
                            <div class="columns is-multiline is-mobile mt-1">
                                {% for dishImage in galleryImages %}
                                    {% set img = dishImage.image %}
                                    {% if not dish.previewImage or img.id != dish.previewImage.id %}
                                    {% set thumbCaption = 'You can <a href=' ~ path('app_report_image', {'id': img.id}) ~ '>report</a> an image if there is something wrong.' %}
                                    <div class="column is-2">
                                        <a data-fancybox="dish-gallery" data-caption="{{ thumbCaption }}" href="/images/thumbnails/{{ img.hash }}_1024x768.webp">
                                            {% include '_components/image.html.twig' with {'image': img, 'size': '400x400'} %}
                                        </a>
                                    </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}

                        {% if dish.getTranslatedDescription(app.locale) or dish.getAnyTranslatedDescription() %}
                            <div class="content">
                                <h4>Description</h4>
                                <p>{{ (dish.getTranslatedDescription(app.locale) ?: dish.getAnyTranslatedDescription())|nl2br }}</p>
                            </div>
                        {% endif %}

                        {% if dish.getTranslatedRecipe(app.locale) or dish.getAnyTranslatedRecipe() %}
                            <div class="content">
                                <h4>Recipe</h4>
                                <p>{{ (dish.getTranslatedRecipe(app.locale) ?: dish.getAnyTranslatedRecipe())|nl2br }}</p>
                            </div>
                        {% endif %}

                        {% if dish.origin %}
                            <p>
                                <span class="icon"><i class="fa-solid fa-location-dot"></i></span>
                                <strong>Origin:</strong> {{ dish.origin }}
                            </p>
                        {% endif %}

                        {% if dish.hasSuggestions and is_granted('ROLE_ORGANIZER') %}
                            <div class="notification is-light mt-4">
                                <span class="icon"><i class="fa-solid fa-lightbulb"></i></span>
                                This dish has {{ dish.suggestionObjects|length }} pending suggestion(s).
                                <a href="{{ path('plugin_dinnerclub_suggestion_view', {'id': dish.id}) }}">Review now</a>
                            </div>
                        {% endif %}

                        {% if imageSuggestionCount > 0 and is_granted('ROLE_ORGANIZER') %}
                            <div class="notification is-light mt-2">
                                <span class="icon"><i class="fa-solid fa-image"></i></span>
                                This dish has {{ imageSuggestionCount }} pending image suggestion(s).
                                <a href="{{ path('plugin_dinnerclub_image_suggestion_view', {'id': dish.id}) }}">Review now</a>
                            </div>
                        {% endif %}
                    </div>

                </div>

                <div class="column is-4">

                    <div class="box">
                        <div class="level">
                            <div class="level-left">
                                <h3 class="title is-5 mb-0">Info</h3>
                            </div>
                            {% if is_granted('ROLE_ORGANIZER') %}
                            <div class="level-right">
                                <a href="{{ path('plugin_dinnerclub_translate', {'id': dish.id, 'lang': app.locale}) }}" class="button is-link">
                                    <span class="icon"><i class="fa-solid fa-pen-to-square"></i></span>
                                    <span>Edit</span>
                                </a>
                            </div>
                            {% endif %}
                        </div>
                        <p><strong>Added by:</strong> {{ get_user_name(dish.createdBy) }}</p>
                        <p><strong>Added:</strong> {{ dish.createdAt|time_diff }}</p>
                        {% if dish.pronunciationSystem %}
                        <p><strong>Pronunciation:</strong> {{ dish.pronunciationSystem.language }} ({{ dish.pronunciationSystem.name }})</p>
                        {% endif %}
                        <p><strong>Likes:</strong> <span class="like-count-display">{{ dish.likes }}</span></p>
                    </div>

                    {% if is_granted('ROLE_USER') %}

                    {% if userLists is not empty %}
                    <div class="box">
                        <h3 class="title is-5">
                            <span class="icon"><i class="fa-solid fa-list"></i></span>
                            <span>Add to List</span>
                        </h3>
                        <div class="field has-addons">
                            <div class="control is-expanded">
                                <div class="select is-fullwidth">
                                    <select id="add-to-list-select">
                                        <option value="">Select a list...</option>
                                        {% for list in userLists %}
                                            <option value="{{ list.id }}" {% if list.hasDish(dish.id) %}disabled{% endif %}>
                                                {{ list.name }}{% if list.hasDish(dish.id) %} (already added){% endif %}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                            <div class="control">
                                <button class="button is-link add-to-list-btn"
                                        data-url-template="{{ path('plugin_dinnerclub_lists_add_dish', {'listId': '__LIST__', 'dishId': dish.id}) }}">
                                    <span>Add</span>
                                </button>
                            </div>
                        </div>
                        <p class="is-size-7 has-text-centered">
                            <a href="{{ path('plugin_dinnerclub_lists_create') }}">Create new list</a>
                        </p>
                    </div>
                    {% else %}
                    <div class="box">
                        <h3 class="title is-5">
                            <span class="icon"><i class="fa-solid fa-list"></i></span>
                            <span>Add to List</span>
                        </h3>
                        <p class="has-text-grey is-size-7 mb-3">You don't have any lists yet. Add a new one like: favorites, plan to cook, want to try, best hungover food</p>
                        <a href="{{ path('plugin_dinnerclub_lists_create') }}" class="button is-link is-fullwidth">
                            <span class="icon"><i class="fa-solid fa-plus"></i></span>
                            <span>Create a List</span>
                        </a>
                    </div>
                    {% endif %}

                    {% endif %}

                </div>
            </div>

        </div>
    </section>

    {% if dish.previewImage or galleryImages|length > 0 %}
    <script>
        Fancybox.bind("[data-fancybox='dish-gallery']", {compact: true});
    </script>
    {% endif %}

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Like toggle button
        document.querySelectorAll('.like-button').forEach(function(button) {
            button.addEventListener('click', function() {
                fetch(button.dataset.url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(response => response.json())
                .then(data => {
                    const icon = button.querySelector('.icon');
                    if (data.liked) {
                        icon.classList.remove('has-text-grey-light');
                        icon.classList.add('has-text-danger');
                    } else {
                        icon.classList.remove('has-text-danger');
                        icon.classList.add('has-text-grey-light');
                    }
                    button.dataset.liked = data.liked ? 'true' : 'false';
                });
            });
        });

        // Add to list button
        const addToListBtn = document.querySelector('.add-to-list-btn');
        if (addToListBtn) {
            addToListBtn.addEventListener('click', function() {
                const select = document.getElementById('add-to-list-select');
                const listId = select.value;

                if (!listId) {
                    alert('Please select a list');
                    return;
                }

                const url = this.dataset.urlTemplate.replace('__LIST__', listId);
                fetch(url, {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'}
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const option = select.querySelector('option[value="' + listId + '"]');
                        option.disabled = true;
                        option.textContent += ' (already added)';
                        select.value = '';
                    } else {
                        alert(data.message);
                    }
                });
            });
        }
    });
    </script>

{% endblock %}
