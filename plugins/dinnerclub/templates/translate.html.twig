{% extends 'base.html.twig' %}

{% block title %}{{ "Translate Dish"|trans }} - {{ dish.getTranslatedName(app.locale) ?: dish.getAnyTranslatedName() }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <nav class="breadcrumb" aria-label="breadcrumbs">
                <ul>
                    <li><a href="{{ path('app_plugin_dinnerclub') }}">Dishes</a></li>
                    <li><a href="{{ path('plugin_dinnerclub_item_show', {'id': dish.id}) }}">{{ dish.getTranslatedName(app.locale) ?: dish.getAnyTranslatedName() }}</a></li>
                    <li class="is-active"><a href="#" aria-current="page">Translate ({{ targetLanguage|upper }})</a></li>
                </ul>
            </nav>

            <div class="columns">
                <div class="column is-8">
                    <div class="box">
                        <div class="columns mb-0">
                            <div class="column is-6">
                                <p class="has-text-grey">Select a language to translate</p>
                            </div>
                            <div class="column is-6">
                                <div class="buttons has-addons is-pulled-right" id="lang-switcher">
                                    {% for lang in availableLanguages %}
                                        <a href="{{ path('plugin_dinnerclub_translate', {'id': dish.id, 'lang': lang}) }}"
                                           class="button {% if lang == targetLanguage %}is-active{% endif %}">
                                            {{ lang|upper }}
                                        </a>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>

                        <h2 class="title is-4">
                            <span class="icon"><i class="fa-solid fa-language"></i></span>
                            <span>{% if existingTranslation %}Edit{% else %}Add{% endif %} Translation</span>
                            <span class="tag is-info is-medium ml-2">{{ targetLanguage|upper }}</span>
                        </h2>

                        {% if existingTranslation %}
                            <p class="mb-4 has-text-grey">
                                {% if is_granted('ROLE_ORGANIZER') %}
                                    Update the {{ targetLanguage|upper }} translation for this dish.
                                {% else %}
                                    Suggest changes to the {{ targetLanguage|upper }} translation. A manager will review your suggestions.
                                {% endif %}
                            </p>
                        {% else %}
                            <p class="mb-4 has-text-grey">
                                {% if is_granted('ROLE_ORGANIZER') %}
                                    Add a new {{ targetLanguage|upper }} translation for this dish.
                                {% else %}
                                    Suggest a {{ targetLanguage|upper }} translation for this dish. A manager will review your suggestion.
                                {% endif %}
                            </p>
                        {% endif %}

                        {{ form_start(form, {'attr': {'id': 'translate-form'}}) }}

                        <div class="field">
                            <label class="label">{{ form.name.vars.label }}</label>
                            <div class="control">
                                {{ form_widget(form.name, {'attr': {'class': 'input'}}) }}
                            </div>
                            {{ form_errors(form.name) }}
                        </div>

                        <div class="field">
                            <label class="label">{{ form.description.vars.label }}</label>
                            <div class="control">
                                {{ form_widget(form.description, {'attr': {'class': 'textarea'}}) }}
                            </div>
                            {{ form_errors(form.description) }}
                        </div>

                        <div class="field">
                            <label class="label">{{ form.recipe.vars.label }}</label>
                            <div class="control">
                                {{ form_widget(form.recipe, {'attr': {'class': 'textarea'}}) }}
                            </div>
                            {{ form_errors(form.recipe) }}
                        </div>

                        <div class="field is-grouped mt-5">
                            <div class="control">
                                <button type="submit" id="save-btn" class="button is-link" disabled>
                                    <span class="icon"><i class="fa-solid fa-check"></i></span>
                                    <span>{% if is_granted('ROLE_ORGANIZER') %}Save{% else %}Submit Suggestion{% endif %}</span>
                                </button>
                            </div>
                            <div class="control">
                                <a id="reset-btn" href="{{ path('plugin_dinnerclub_translate', {'id': dish.id, 'lang': targetLanguage}) }}" class="button" style="pointer-events: none; opacity: 0.5;">Reset</a>
                            </div>
                        </div>

                        {{ form_end(form) }}
                    </div>

                    {% if is_granted('ROLE_ORGANIZER') %}
                    <div class="box">
                        <h2 class="title is-4">
                            <span class="icon"><i class="fa-solid fa-location-dot"></i></span>
                            <span>Origin</span>
                        </h2>

                        {{ form_start(originForm) }}

                        <div class="columns">
                            <div class="column is-6">
                                <div class="field">
                                    <label class="label">{{ originForm.pronunciationSystem.vars.label }}</label>
                                    <div class="control">
                                        <div class="select is-fullwidth">
                                            {{ form_widget(originForm.pronunciationSystem, {'attr': {'id': 'pronunciation-system-select'}}) }}
                                        </div>
                                    </div>
                                    {{ form_errors(originForm.pronunciationSystem) }}
                                </div>
                            </div>
                            <div class="column is-6">
                                <div class="field">
                                    <label class="label" id="phonetic-label">Transcription</label>
                                    <div class="control">
                                        {{ form_widget(originForm.phonetic, {'attr': {'class': 'input', 'id': 'phonetic-input'}}) }}
                                    </div>
                                    {{ form_errors(originForm.phonetic) }}
                                </div>
                            </div>
                        </div>

                        <div class="field">
                            <label class="label">
                                <span class="icon-text">
                                    <span class="icon"><i class="fa-solid fa-location-dot"></i></span>
                                    <span>{{ originForm.origin.vars.label }}</span>
                                </span>
                            </label>
                            <div class="control">
                                {{ form_widget(originForm.origin, {'attr': {'class': 'input'}}) }}
                            </div>
                            {{ form_errors(originForm.origin) }}
                        </div>

                        <div class="field mt-4">
                            <div class="control">
                                <button type="submit" class="button is-link">
                                    <span class="icon"><i class="fa-solid fa-check"></i></span>
                                    <span>Save Origin</span>
                                </button>
                            </div>
                        </div>

                        {{ form_end(originForm) }}
                    </div>
                    {% endif %}
                </div>

                <div class="column is-4">
            </div>

        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var saveBtn  = document.getElementById('save-btn');
            var resetBtn = document.getElementById('reset-btn');
            var switcher = document.getElementById('lang-switcher');
            var form     = document.getElementById('translate-form');
            if (!form) return;

            function onDirty() {
                saveBtn.disabled       = false;
                resetBtn.style.pointerEvents = '';
                resetBtn.style.opacity = '';
                switcher.querySelectorAll('.button').forEach(function (btn) {
                    btn.classList.add('is-static');
                    btn.style.pointerEvents = 'none';
                });
                form.removeEventListener('input', onDirty);
                form.removeEventListener('change', onDirty);
            }

            form.addEventListener('input', onDirty);
            form.addEventListener('change', onDirty);
        });
    </script>

    {% if is_granted('ROLE_ORGANIZER') %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var select = document.getElementById('pronunciation-system-select');
            var phonetic = document.getElementById('phonetic-input');
            if (!select || !phonetic) return;

            var label = document.getElementById('phonetic-label');

            function updatePhonetic() {
                var hasSystem = select.value !== '';
                phonetic.disabled = !hasSystem;
                if (!hasSystem) {
                    phonetic.value = '';
                    label.textContent = 'Transcription';
                } else {
                    var systemName = select.options[select.selectedIndex].text.split(' (')[0] || 'Transcription';
                    label.textContent = systemName;
                }
            }

            select.addEventListener('change', updatePhonetic);
            updatePhonetic();
        });
    </script>
    {% endif %}

{% endblock %}
