{% extends 'base.html.twig' %}

{% block title %}{{ "Translate Dish"|trans }} - {{ dish.getTranslatedName(dish.originLang ?? app.locale) }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <nav class="breadcrumb" aria-label="breadcrumbs">
                <ul>
                    <li><a href="{{ path('app_plugin_dinnerclub') }}">Dishes</a></li>
                    <li><a href="{{ path('plugin_dinnerclub_item_show', {'id': dish.id}) }}">{{ dish.getTranslatedName(dish.originLang ?? app.locale) }}</a></li>
                    <li class="is-active"><a href="#" aria-current="page">Translate ({{ targetLanguage|upper }})</a></li>
                </ul>
            </nav>

            <div class="columns">
                <div class="column is-8">
                    <div class="box">
                        <div class="columns mb-0">
                            <div class="column is-6">
                                <p class="has-text-grey">Select a language to translate</p>
                            </div>
                            <div class="column is-6">
                                <div class="buttons has-addons is-pulled-right">
                                    {% for lang in availableLanguages %}
                                        <a href="{{ path('plugin_dinnerclub_translate', {'id': dish.id, 'lang': lang}) }}"
                                           class="button {% if lang == targetLanguage %}is-active{% endif %}">
                                            {{ lang|upper }}
                                        </a>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>

                        <h2 class="title is-4">
                            <span class="icon"><i class="fa-solid fa-language"></i></span>
                            <span>{% if existingTranslation %}Edit{% else %}Add{% endif %} Translation</span>
                            <span class="tag is-info is-medium ml-2">{{ targetLanguage|upper }}</span>
                        </h2>

                        {% if existingTranslation %}
                            <p class="mb-4 has-text-grey">
                                {% if is_granted('ROLE_ORGANIZER') %}
                                    Update the {{ targetLanguage|upper }} translation for this dish.
                                {% else %}
                                    Suggest changes to the {{ targetLanguage|upper }} translation. A manager will review your suggestions.
                                {% endif %}
                            </p>
                        {% else %}
                            <p class="mb-4 has-text-grey">
                                {% if is_granted('ROLE_ORGANIZER') %}
                                    Add a new {{ targetLanguage|upper }} translation for this dish.
                                {% else %}
                                    Suggest a {{ targetLanguage|upper }} translation for this dish. A manager will review your suggestion.
                                {% endif %}
                            </p>
                        {% endif %}

                        {{ form_start(form) }}

                        <div class="field">
                            <label class="label">{{ form.name.vars.label }}</label>
                            <div class="control">
                                {{ form_widget(form.name, {'attr': {'class': 'input'}}) }}
                            </div>
                            {{ form_errors(form.name) }}
                        </div>

                        <div class="field">
                            <label class="label">{{ form.phonetic.vars.label }}</label>
                            <div class="control">
                                {{ form_widget(form.phonetic, {'attr': {'class': 'input'}}) }}
                            </div>
                            {{ form_errors(form.phonetic) }}
                        </div>

                        <div class="field">
                            <label class="label">{{ form.description.vars.label }}</label>
                            <div class="control">
                                {{ form_widget(form.description, {'attr': {'class': 'textarea'}}) }}
                            </div>
                            {{ form_errors(form.description) }}
                        </div>

                        <div class="field">
                            <label class="label">{{ form.recipe.vars.label }}</label>
                            <div class="control">
                                {{ form_widget(form.recipe, {'attr': {'class': 'textarea'}}) }}
                            </div>
                            {{ form_errors(form.recipe) }}
                        </div>

                        <div class="field is-grouped mt-5">
                            <div class="control">
                                <button type="submit" class="button is-link">
                                    <span class="icon"><i class="fa-solid fa-check"></i></span>
                                    <span>{% if is_granted('ROLE_ORGANIZER') %}Save{% else %}Submit Suggestion{% endif %}</span>
                                </button>
                            </div>
                            <div class="control">
                                <a href="{{ path('plugin_dinnerclub_item_show', {'id': dish.id}) }}" class="button">Cancel</a>
                            </div>
                        </div>

                        {{ form_end(form) }}
                    </div>

                    {% if is_granted('ROLE_ORGANIZER') %}
                    <div class="box">
                        <h2 class="title is-4">
                            <span class="icon"><i class="fa-solid fa-location-dot"></i></span>
                            <span>Origin</span>
                        </h2>

                        {{ form_start(originForm) }}

                        <div class="field">
                            <label class="label">
                                <span class="icon-text">
                                    <span class="icon"><i class="fa-solid fa-language"></i></span>
                                    <span>{{ originForm.originLang.vars.label }}</span>
                                </span>
                            </label>
                            <div class="control">
                                <div class="select">
                                    {{ form_widget(originForm.originLang) }}
                                </div>
                            </div>
                            {{ form_errors(originForm.originLang) }}
                        </div>

                        <div class="field">
                            <label class="label">
                                <span class="icon-text">
                                    <span class="icon"><i class="fa-solid fa-location-dot"></i></span>
                                    <span>{{ originForm.origin.vars.label }}</span>
                                </span>
                            </label>
                            <div class="control">
                                {{ form_widget(originForm.origin, {'attr': {'class': 'input'}}) }}
                            </div>
                            {{ form_errors(originForm.origin) }}
                        </div>

                        <div class="field mt-4">
                            <div class="control">
                                <button type="submit" class="button is-link">
                                    <span class="icon"><i class="fa-solid fa-check"></i></span>
                                    <span>Save Origin</span>
                                </button>
                            </div>
                        </div>

                        {{ form_end(originForm) }}
                    </div>
                    {% endif %}
                </div>

                <div class="column is-4">
                    <div class="box">
                        <h3 class="title is-5">
                            <span class="icon"><i class="fa-solid fa-info-circle"></i></span>
                            <span>Original ({{ dish.originLang|upper }})</span>
                        </h3>
                        <div class="content">
                            <p><strong>Name:</strong> {{ dish.getTranslatedName(dish.originLang ?? 'en') }}</p>
                            {% if dish.getPhonetic(dish.originLang ?? 'en') %}
                                <p><strong>Phonetic:</strong> {{ dish.getPhonetic(dish.originLang ?? 'en') }}</p>
                            {% endif %}
                            {% if dish.getTranslatedDescription(dish.originLang ?? 'en') %}
                                <p><strong>Description:</strong> {{ dish.getTranslatedDescription(dish.originLang ?? 'en') }}</p>
                            {% endif %}
                            {% if dish.getTranslatedRecipe(dish.originLang ?? 'en') %}
                                <p><strong>Recipe:</strong> {{ dish.getTranslatedRecipe(dish.originLang ?? 'en')|nl2br }}</p>
                            {% endif %}
                        </div>
                    </div>

                    <div class="box">
                        <h3 class="title is-5">
                            <span class="icon"><i class="fa-solid fa-volume-high"></i></span>
                            <span>Phonetic systems</span>
                        </h3>
                        <div class="content is-small">
                            <table class="table is-narrow is-fullwidth">
                                <thead>
                                    <tr><th>Language</th><th>System</th><th>Example</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>Chinese</td><td>Pinyin</td><td>má po dòu fu</td></tr>
                                    <tr><td>Japanese</td><td>Rōmaji</td><td>ra-men</td></tr>
                                    <tr><td>Arabic</td><td>Romanisation</td><td>kus-kus</td></tr>
                                    <tr><td>Korean</td><td>Revised Romanisation</td><td>bi-bim-bap</td></tr>
                                    <tr><td>Thai</td><td>RTGS</td><td>phàt thai</td></tr>
                                    <tr><td>Hindi</td><td>IAST</td><td>bi-ryā-nī</td></tr>
                                    <tr><td>Greek</td><td>Greeklish</td><td>mu-sa-kás</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>

{% endblock %}
