{% extends 'base.html.twig' %}

{% block title %}{{ 'dinnerclub_suggestion.page_title_images'|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <nav class="breadcrumb" aria-label="breadcrumbs">
                <ul>
                    <li><a href="{{ path('app_plugin_dinnerclub') }}">{{ 'dinnerclub.breadcrumb_dishes'|trans }}</a></li>
                    <li><a href="{{ path('plugin_dinnerclub_suggestions_list') }}">{{ 'dinnerclub_suggestion.breadcrumb_suggestions'|trans }}</a></li>
                    <li class="is-active"><a href="#" aria-current="page">{{ 'dinnerclub_suggestion.breadcrumb_images'|trans }}</a></li>
                </ul>
            </nav>

            <h1 class="title">
                <span class="icon"><i class="fa-solid fa-image"></i></span>
                <span>{{ 'dinnerclub_suggestion.heading_images'|trans }}</span>
            </h1>

            {% if dishes is empty %}
                <div class="notification is-info is-light">
                    <span class="icon"><i class="fa-solid fa-check-circle"></i></span>
                    <span>{{ 'dinnerclub_suggestion.empty_images'|trans }}</span>
                </div>
            {% else %}
                <div class="columns is-multiline">
                    {% for dish in dishes %}
                        <div class="column is-4">
                            <div class="card">
                                {% if dish.previewImage %}
                                    <div class="card-image">
                                        <figure class="image is-4by3">
                                            {% include '_components/image.html.twig' with {'image': dish.previewImage, 'size': '600x400'} %}
                                        </figure>
                                    </div>
                                {% endif %}
                                <div class="card-content">
                                    <p class="title is-5">{{ dish.getTranslatedName(app.locale) ?: dish.getAnyTranslatedName() }}</p>
                                    <p class="subtitle is-6 has-text-grey">
                                        <span class="icon"><i class="fa-solid fa-image"></i></span>
                                        {{ 'dinnerclub_suggestion.card_pending_images'|trans }}
                                    </p>
                                </div>
                                <footer class="card-footer">
                                    <a href="{{ path('plugin_dinnerclub_image_suggestion_view', {'id': dish.id}) }}" class="card-footer-item">
                                        <span class="icon"><i class="fa-solid fa-eye"></i></span>
                                        <span>{{ 'dinnerclub_suggestion.button_review'|trans }}</span>
                                    </a>
                                    <a href="{{ path('plugin_dinnerclub_item_show', {'id': dish.id}) }}" class="card-footer-item">
                                        <span class="icon"><i class="fa-solid fa-external-link"></i></span>
                                        <span>{{ 'dinnerclub_suggestion.button_view_dish'|trans }}</span>
                                    </a>
                                </footer>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            <div class="mt-5">
                <a href="{{ path('plugin_dinnerclub_suggestions_list') }}" class="button">
                    <span class="icon"><i class="fa-solid fa-arrow-left"></i></span>
                    <span>{{ 'dinnerclub_suggestion.button_back_suggestions'|trans }}</span>
                </a>
            </div>

        </div>
    </section>

{% endblock %}
