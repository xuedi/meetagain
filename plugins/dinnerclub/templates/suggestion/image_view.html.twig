{% extends 'base.html.twig' %}

{% block title %}{{ 'dinnerclub_suggestion.page_title_image_view'|trans }} - {{ dish.getTranslatedName(app.locale) ?: dish.getAnyTranslatedName() }}{% endblock %}

{% block javascripts %}
    {% if dish.previewImage %}
        <script src="{{ asset('js/vendor/fancybox.umd.js') }}"></script>
    {% endif %}
{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <nav class="breadcrumb" aria-label="breadcrumbs">
                <ul>
                    <li><a href="{{ path('app_plugin_dinnerclub') }}">{{ 'dinnerclub.breadcrumb_dishes'|trans }}</a></li>
                    <li><a href="{{ path('plugin_dinnerclub_suggestions_list') }}">{{ 'dinnerclub_suggestion.breadcrumb_suggestions'|trans }}</a></li>
                    <li><a href="{{ path('plugin_dinnerclub_image_suggestions_list') }}">{{ 'dinnerclub_suggestion.breadcrumb_images'|trans }}</a></li>
                    <li class="is-active"><a href="#" aria-current="page">{{ dish.getTranslatedName(app.locale) ?: dish.getAnyTranslatedName() }}</a></li>
                </ul>
            </nav>

            <div class="columns">
                <div class="column is-8">
                    <h1 class="title">
                        <span class="icon"><i class="fa-solid fa-image"></i></span>
                        <span>{{ 'dinnerclub_suggestion.heading_image_view'|trans }}</span>
                    </h1>
                    <p class="subtitle">{{ dish.getTranslatedName(app.locale) ?: dish.getAnyTranslatedName() }}</p>

                    {% if suggestions is empty %}
                        <div class="notification is-info is-light">
                            {{ 'dinnerclub_suggestion.empty_dish_images'|trans }}
                        </div>
                    {% else %}
                        {% for suggestion in suggestions %}
                            <div class="box">
                                <div class="level">
                                    <div class="level-left">
                                        <div class="level-item">
                                            {% if suggestion.type.value == 'add_image' %}
                                                <span class="tag is-info is-medium">{{ 'dinnerclub_suggestion.tag_add_image'|trans }}</span>
                                            {% else %}
                                                <span class="tag is-warning is-medium">{{ 'dinnerclub_suggestion.tag_set_preview'|trans }}</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <div class="level-right">
                                        <div class="level-item">
                                            <span class="has-text-grey is-size-7">
                                                by {{ get_user_name(suggestion.suggestedBy) }}
                                                {{ suggestion.createdAt|time_diff }}
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="columns">
                                    <div class="column is-6">
                                        <p class="mb-2"><strong>{{ 'dinnerclub_suggestion.label_suggested_image'|trans }}</strong></p>
                                        {% include '_components/image.html.twig' with {'image': suggestion.image, 'size': '400x400'} %}
                                    </div>
                                    {% if suggestion.type.value == 'set_preview' and dish.previewImage %}
                                        <div class="column is-6">
                                            <p class="mb-2"><strong>{{ 'dinnerclub_suggestion.label_current_preview'|trans }}</strong></p>
                                            {% include '_components/image.html.twig' with {'image': dish.previewImage, 'size': '400x400'} %}
                                        </div>
                                    {% endif %}
                                </div>

                                <div class="buttons mt-3">
                                    <a href="{{ path('app_profile_review') }}"
                                       class="button is-info is-outlined is-small">
                                        <span class="icon"><i class="fa-solid fa-check-double"></i></span>
                                        <span>{{ 'dinnerclub_suggestion.button_review_page'|trans }}</span>
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>

                <div class="column is-4">
                    <div class="box">
                        <h3 class="title is-5">{{ 'dinnerclub_suggestion.heading_dish_info'|trans }}</h3>
                        {% if dish.previewImage %}
                            {% include '_components/image.html.twig' with {'image': dish.previewImage, 'size': '400x400'} %}
                        {% endif %}
                        {% if dish.pronunciationSystem %}
                        <p class="mt-3"><strong>{{ 'dinnerclub.label_pronunciation'|trans }}</strong> {{ dish.pronunciationSystem.language }} ({{ dish.pronunciationSystem.name }})</p>
                        {% endif %}
                        {% if dish.origin %}
                            <p><strong>{{ 'dinnerclub.label_origin'|trans }}</strong> {{ dish.origin }}</p>
                        {% endif %}
                        <p><strong>{{ 'dinnerclub.label_likes'|trans }}</strong> {{ dish.likes }}</p>
                    </div>

                    <div class="box">
                        <h3 class="title is-5">{{ 'dinnerclub_suggestion.heading_translations'|trans }}</h3>
                        {% for translation in dish.translation %}
                            <div class="mb-3">
                                <span class="tag is-info">{{ translation.language|upper }}</span>
                                <span>{{ translation.name }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="mt-5">
                <a href="{{ path('plugin_dinnerclub_image_suggestions_list') }}" class="button">
                    <span class="icon"><i class="fa-solid fa-arrow-left"></i></span>
                    <span>{{ 'dinnerclub_suggestion.button_back_images'|trans }}</span>
                </a>
            </div>

        </div>
    </section>

{% endblock %}
