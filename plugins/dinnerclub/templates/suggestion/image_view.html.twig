{% extends 'base.html.twig' %}

{% block title %}Review Image Suggestions - {{ dish.getTranslatedName(app.locale) ?: dish.getAnyTranslatedName() }}{% endblock %}

{% block stylesheets %}
    {% if dish.previewImage %}
        <link rel="stylesheet" href="{{ asset('styles/vendor/fancybox.css') }}"/>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {% if dish.previewImage %}
        <script src="{{ asset('js/vendor/fancybox.umd.js') }}"></script>
    {% endif %}
{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <nav class="breadcrumb" aria-label="breadcrumbs">
                <ul>
                    <li><a href="{{ path('app_plugin_dinnerclub') }}">Dishes</a></li>
                    <li><a href="{{ path('plugin_dinnerclub_suggestions_list') }}">Suggestions</a></li>
                    <li><a href="{{ path('plugin_dinnerclub_image_suggestions_list') }}">Image Suggestions</a></li>
                    <li class="is-active"><a href="#" aria-current="page">{{ dish.getTranslatedName(app.locale) ?: dish.getAnyTranslatedName() }}</a></li>
                </ul>
            </nav>

            <div class="columns">
                <div class="column is-8">
                    <h1 class="title">
                        <span class="icon"><i class="fa-solid fa-image"></i></span>
                        <span>Review Image Suggestions</span>
                    </h1>
                    <p class="subtitle">{{ dish.getTranslatedName(app.locale) ?: dish.getAnyTranslatedName() }}</p>

                    {% if suggestions is empty %}
                        <div class="notification is-info is-light">
                            No pending image suggestions for this dish.
                        </div>
                    {% else %}
                        {% for suggestion in suggestions %}
                            <div class="box">
                                <div class="level">
                                    <div class="level-left">
                                        <div class="level-item">
                                            {% if suggestion.type.value == 'add_image' %}
                                                <span class="tag is-info is-medium">Add Image</span>
                                            {% else %}
                                                <span class="tag is-warning is-medium">Set as Preview</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <div class="level-right">
                                        <div class="level-item">
                                            <span class="has-text-grey is-size-7">
                                                by {{ get_user_name(suggestion.suggestedBy) }}
                                                {{ suggestion.createdAt|time_diff }}
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="columns">
                                    <div class="column is-6">
                                        <p class="mb-2"><strong>Suggested image:</strong></p>
                                        {% include '_components/image.html.twig' with {'image': suggestion.image, 'size': '400x400'} %}
                                    </div>
                                    {% if suggestion.type.value == 'set_preview' and dish.previewImage %}
                                        <div class="column is-6">
                                            <p class="mb-2"><strong>Current preview:</strong></p>
                                            {% include '_components/image.html.twig' with {'image': dish.previewImage, 'size': '400x400'} %}
                                        </div>
                                    {% endif %}
                                </div>

                                <div class="buttons mt-3">
                                    <a href="{{ path('plugin_dinnerclub_image_suggestion_apply', {'suggestionId': suggestion.id}) }}"
                                       class="button is-success">
                                        <span class="icon"><i class="fa-solid fa-check"></i></span>
                                        <span>Apply</span>
                                    </a>
                                    <a href="{{ path('plugin_dinnerclub_image_suggestion_deny', {'suggestionId': suggestion.id}) }}"
                                       class="button is-danger is-light">
                                        <span class="icon"><i class="fa-solid fa-times"></i></span>
                                        <span>Reject</span>
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>

                <div class="column is-4">
                    <div class="box">
                        <h3 class="title is-5">Dish Info</h3>
                        {% if dish.previewImage %}
                            {% include '_components/image.html.twig' with {'image': dish.previewImage, 'size': '400x400'} %}
                        {% endif %}
                        {% if dish.pronunciationSystem %}
                        <p class="mt-3"><strong>Pronunciation:</strong> {{ dish.pronunciationSystem.language }} ({{ dish.pronunciationSystem.name }})</p>
                        {% endif %}
                        {% if dish.origin %}
                            <p><strong>Origin:</strong> {{ dish.origin }}</p>
                        {% endif %}
                        <p><strong>Likes:</strong> {{ dish.likes }}</p>
                    </div>

                    <div class="box">
                        <h3 class="title is-5">Existing Translations</h3>
                        {% for translation in dish.translation %}
                            <div class="mb-3">
                                <span class="tag is-info">{{ translation.language|upper }}</span>
                                <span>{{ translation.name }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="mt-5">
                <a href="{{ path('plugin_dinnerclub_image_suggestions_list') }}" class="button">
                    <span class="icon"><i class="fa-solid fa-arrow-left"></i></span>
                    <span>Back to Image Suggestions</span>
                </a>
            </div>

        </div>
    </section>

{% endblock %}
