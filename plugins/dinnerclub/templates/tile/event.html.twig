<div class="is-flex is-justify-content-space-between is-align-items-center mb-2">
    <h3 class="title is-5 mb-0">Dinner Menu</h3>
    {% if dinner and is_granted('ROLE_ORGANIZER') %}
        <a href="{{ path('app_plugin_dinnerclub_dinner_manage', {eventId: eventId}) }}" class="has-text-grey" title="Edit menu">
            <span class="icon"><i class="fa fa-edit"></i></span>
        </a>
    {% endif %}
</div>

{% if dinner %}
    {% for course in dinner.courses %}
        {% if course.items|length > 0 %}
            <p class="has-text-weight-semibold is-size-7 mt-3 mb-1">{{ course.name }}</p>
            {% for item in course.items %}
                <p class="is-size-7">{{ item.dish.getTranslatedName(app.locale) ?: item.dish.getTranslatedName('en') }}</p>
            {% endfor %}
        {% endif %}
    {% endfor %}

    {% if dinner.reservationName or dinner.pricePerPerson is not null %}
        <hr style="margin: 0.75rem 0;">
        <div class="is-size-7">
            {% if dinner.reservationName %}
                <p><span class="has-text-grey">Reservation:</span> {{ dinner.reservationName }}</p>
            {% endif %}
            {% if dinner.pricePerPerson is not null %}
                <p><span class="has-text-grey">Price per person:</span> {{ dinner.pricePerPerson|number_format(2) }}</p>
            {% endif %}
        </div>
    {% endif %}
{% else %}
    {% if is_granted('ROLE_ORGANIZER') %}
        <p class="has-text-grey is-size-7">Add a planned dinner to this, with proper menu options.</p>
        <form method="post" action="{{ path('app_plugin_dinnerclub_dinner_create', {eventId: eventId}) }}" class="mt-2">
            <button type="submit" class="button is-small">Create dinner</button>
        </form>
    {% endif %}
{% endif %}
