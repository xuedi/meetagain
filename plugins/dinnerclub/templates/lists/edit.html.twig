{% extends 'base.html.twig' %}

{% block title %}{{ 'dinnerclub_lists.page_title_edit'|trans }} - {{ list.name }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <nav class="breadcrumb" aria-label="breadcrumbs">
                <ul>
                    <li><a href="{{ path('app_plugin_dinnerclub') }}">{{ 'dinnerclub.breadcrumb_dishes'|trans }}</a></li>
                    <li><a href="{{ path('plugin_dinnerclub_lists') }}">{{ 'dinnerclub_lists.breadcrumb'|trans }}</a></li>
                    <li><a href="{{ path('plugin_dinnerclub_lists_view', {'id': list.id}) }}">{{ list.name }}</a></li>
                    <li class="is-active"><a href="#" aria-current="page">{{ 'dinnerclub_lists.breadcrumb_edit'|trans }}</a></li>
                </ul>
            </nav>

            <div class="columns">
                <div class="column is-6">
                    <div class="box">
                        <h1 class="title is-4">
                            <span class="icon"><i class="fa-solid fa-pen"></i></span>
                            <span>{{ 'dinnerclub_lists.heading_edit'|trans }}</span>
                        </h1>

                        {{ form_start(form) }}

                        <div class="field">
                            <label class="label">{{ form.name.vars.label|trans }}</label>
                            <div class="control">
                                {{ form_widget(form.name, {'attr': {'class': 'input'}}) }}
                            </div>
                            {{ form_errors(form.name) }}
                        </div>

                        <div class="field">
                            <label class="label">{{ form.description.vars.label|trans }}</label>
                            <div class="control">
                                {{ form_widget(form.description, {'attr': {'class': 'textarea'}}) }}
                            </div>
                            {{ form_errors(form.description) }}
                        </div>

                        <div class="field">
                            <div class="control">
                                <label class="checkbox">
                                    {{ form_widget(form.isPublic) }}
                                    {{ form.isPublic.vars.label|trans }}
                                </label>
                            </div>
                            <p class="help">{{ form.isPublic.vars.help|trans }}</p>
                        </div>

                        <div class="field is-grouped mt-5">
                            <div class="control">
                                <button type="submit" class="button is-link">
                                    <span class="icon"><i class="fa-solid fa-check"></i></span>
                                    <span>{{ 'dinnerclub_lists.button_save'|trans }}</span>
                                </button>
                            </div>
                            <div class="control">
                                <a href="{{ path('plugin_dinnerclub_lists_view', {'id': list.id}) }}" class="button">{{ 'global.button_cancel'|trans }}</a>
                            </div>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>

                <div class="column is-6">
                    <div class="box">
                        <h3 class="title is-5">{{ 'dinnerclub_lists.heading_list_info'|trans }}</h3>
                        <p><strong>{{ 'dinnerclub_lists.label_created'|trans }}</strong> {{ list.createdAt|time_diff }}</p>
                        <p><strong>{{ 'dinnerclub_lists.label_dishes'|trans }}</strong> {{ list.dishCount }}</p>
                    </div>
                </div>
            </div>

        </div>
    </section>

{% endblock %}
