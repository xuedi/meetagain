{% extends 'base.html.twig' %}

{% block title %}{{ "Edit Dish"|trans }} - {{ dish.getTranslatedName(dish.originLang ?? app.locale) }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <nav class="breadcrumb" aria-label="breadcrumbs">
                <ul>
                    <li><a href="{{ path('app_plugin_dinnerclub') }}">Dishes</a></li>
                    <li><a href="{{ path('plugin_dinnerclub_item_show', {'id': dish.id}) }}">{{ dish.getTranslatedName(app.locale) ?: dish.getTranslatedName(dish.originLang) }}</a></li>
                    <li class="is-active"><a href="#" aria-current="page">Edit Dish</a></li>
                </ul>
            </nav>

            <div class="columns">
                <div class="column is-8">
                    <div class="box">
                        <h2 class="title is-4">
                            <span class="icon"><i class="fa-solid fa-pen-to-square"></i></span>
                            <span>Edit Dish</span>
                        </h2>

                        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

                        <div class="field">
                            <label class="label">
                                <span class="icon-text">
                                    <span class="icon"><i class="fa-solid fa-image"></i></span>
                                    <span>{{ form.previewImage.vars.label }}</span>
                                </span>
                            </label>
                            {% if dish.previewImage %}
                                <figure class="image mb-2" style="max-width: 200px;">
                                    {% include '_components/image.html.twig' with {'image': dish.previewImage, 'size': '200x150'} %}
                                </figure>
                            {% endif %}
                            <div class="control">
                                {{ form_widget(form.previewImage) }}
                            </div>
                            {{ form_errors(form.previewImage) }}
                        </div>

                        <div class="field">
                            <label class="label">
                                <span class="icon-text">
                                    <span class="icon"><i class="fa-solid fa-language"></i></span>
                                    <span>{{ form.originLang.vars.label }}</span>
                                </span>
                            </label>
                            <div class="control">
                                <div class="select">
                                    {{ form_widget(form.originLang) }}
                                </div>
                            </div>
                            {{ form_errors(form.originLang) }}
                        </div>

                        <div class="field">
                            <label class="label">
                                <span class="icon-text">
                                    <span class="icon"><i class="fa-solid fa-location-dot"></i></span>
                                    <span>{{ form.origin.vars.label }}</span>
                                </span>
                            </label>
                            <div class="control">
                                {{ form_widget(form.origin, {'attr': {'class': 'input'}}) }}
                            </div>
                            {{ form_errors(form.origin) }}
                        </div>

                        <div class="field is-grouped mt-5">
                            <div class="control">
                                <button type="submit" class="button is-link">
                                    <span class="icon"><i class="fa-solid fa-check"></i></span>
                                    <span>Save Changes</span>
                                </button>
                            </div>
                            <div class="control">
                                <a href="{{ path('plugin_dinnerclub_item_show', {'id': dish.id}) }}" class="button">Cancel</a>
                            </div>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>

                <div class="column is-4">
                    <div class="box">
                        <h3 class="title is-5">
                            <span class="icon"><i class="fa-solid fa-circle-info"></i></span>
                            <span>Note</span>
                        </h3>
                        <div class="content is-small has-text-grey">
                            <p>This form edits the dish's base data. Translation fields (name, phonetic, description, recipe) are edited per-language via the <strong>Translate</strong> page on the dish detail view.</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>

{% endblock %}
