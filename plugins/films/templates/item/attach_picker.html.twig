{# Steward picker to attach an existing film to the event. Posts to the core attach route. #}
{% if films is empty %}
    <p class="has-text-grey is-size-7">{{ 'films.attach_empty'|trans }}</p>
{% else %}
    <form method="post" action="{{ path('app_item_attach', {id: eventId}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('app_item_attach' ~ eventId) }}">
        <input type="hidden" name="item_type" value="film">
        <div class="field has-addons">
            <div class="control is-expanded">
                <div class="select is-small is-fullwidth">
                    <select name="item_id">
                        {% for film in films %}
                            <option value="{{ film.id }}">{{ film.title }}{% if film.year %} ({{ film.year }}){% endif %}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="control">
                <button type="submit" class="button is-small is-link">{{ 'films.attach_button'|trans }}</button>
            </div>
        </div>
    </form>
{% endif %}
