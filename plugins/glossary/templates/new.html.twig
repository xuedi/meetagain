{% extends 'base.html.twig' %}

{% block title %}{{ 'glossary.page_title_new'|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">
            <div class="columns is-centered">
                <div class="column is-half">

                    <h1 class="title is-4">{{ 'glossary.heading_suggest_new'|trans }}</h1>
                    <div class="box">

                        {{ form_start(form) }}
                        {{ form_row(form.phrase) }}
                        {% if form.pinyin is defined %}{{ form_row(form.pinyin) }}{% endif %}
                        {{ form_row(form.explanation) }}
                        {% if form.category is defined %}{{ form_row(form.category) }}{% endif %}
                        <div class="has-text-right mt-6">
                            <a href="{{ path('app_plugin_glossary') }}" class="button">{{ 'global.button_cancel'|trans }}</a>
                            <button type="submit" class="button is-link">{{ 'glossary.button_suggest_new'|trans }}</button>
                        </div>
                        {{ form_end(form) }}

                    </div>

                    <a href="{{ path('app_plugin_glossary') }}" class="is-size-7">{{ 'glossary.link_back_to_list'|trans }}</a>

                </div>
            </div>
        </div>
    </section>

{% endblock %}
