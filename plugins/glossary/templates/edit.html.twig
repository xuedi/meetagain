{% extends 'base.html.twig' %}

{% block title %}{{ 'glossary.page_title_new'|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <div class="columns">
                <div class="column is-9">
                    {% include '@Glossary/blocks/list.html.twig' %}
                </div>
                <div class="column is-3">
                    {% if is_granted('ROLE_USER') %}
                        <h2 class="title is-5">{{ 'glossary.heading_suggest_change'|trans }}</h2>
                        <div class="box">

                            {{ form_start(form) }}
                            {{ form_row(form.phrase) }}
                            {{ form_row(form.pinyin) }}
                            {{ form_row(form.explanation) }}
                            {{ form_row(form.category) }}
                            <div class="has-text-right mt-6">
                                <a href="{{ path('app_plugin_glossary') }}" class="button">{{ 'global.cancel'|trans }}</a>
                                {% if is_granted('ROLE_ORGANIZER') %}
                                    <button type="submit" class="button is-link">{{ 'global.save'|trans }}</button>
                                {% else %}
                                    <button type="submit" class="button is-link">{{ 'glossary.button_suggest_change'|trans }}</button>
                                {% endif %}
                            </div>
                            {{ form_end(form) }}

                        </div>
                    {% endif %}

                    {% if editItem.suggestions is not empty %}
                        <h2 class="title is-5">{{ 'glossary.heading_waiting_approval'|trans }}</h2>
                        {% for suggestion in editItem.suggestions %}
                            {% set value = suggestion.value %}
                            {% if suggestion.field.value == categoryFieldValue %}
                                {% set value = categoryNames[suggestion.value]|trans %}
                            {% endif %}
                            <div class="box has-background-info-light">
                                <p>
                                    <b>{{ get_user_name(suggestion.createdBy) }}</b> suggested {{ suggestion.createdAt | time_diff }} to change the
                                    <b>{{ suggestion.field.value }}</b> to '<b>{{ value }}</b>'
                                </p>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>

        </div>
    </section>

{% endblock %}
