{% set maxLength = 110 %}
{% if editItem is defined or shortList is defined %}
    {% set maxLength = 60 %}
{% endif %}

{% set primaryLabel = config.primaryLabel ?? ('glossary_blocks.col_phrase'|trans) %}
{% set secondaryLabel = config.secondaryLabel ?? ('glossary.label_pinyin'|trans) %}
{% set definitionLabel = config.definitionLabel ?? ('glossary_blocks.col_explanation'|trans) %}

<table id="filteredTable" class="table is-fullwidth">
    <thead>
    <tr>
        <th>{{ primaryLabel }}</th>
        {% if config.secondaryEnabled %}<th>{{ secondaryLabel }}</th>{% endif %}
        <th>{{ definitionLabel }}</th>
        {% if config.hasCategories %}<th>{{ 'glossary_blocks.col_category'|trans }}</th>{% endif %}
        {% if is_granted('ROLE_USER') %}
            <th>
                <a href="{{ path('app_plugin_glossary_new') }}">
                    <i class="fas fa-plus"></i>
                </a>
            </th>
        {% endif %}
    </tr>
    </thead>
    <tbody>

    {% if is_granted('ROLE_ORGANIZER') %}

        {% for item in list %}{# action items for managers #}
            {% if item.approved == false or item.suggestions is not empty %}
            <tr class="{% if editItem is defined and editItem.id == item.id %}has-background-light{% endif %}">
                <td>{{ item.phrase }}</td>
                {% if config.secondaryEnabled %}<td>{{ item.pinyin }}</td>{% endif %}
                <td>{{ item.getExplanationShortened(maxLength)|nl2br }}</td>
                {% if config.hasCategories %}<td>{{ config.getCategoryLabel(item.category)|default('') }}</td>{% endif %}
                <td>
                    {% if item.approved == false %}
                    <a class="has-text-success" href="{{ path('app_plugin_glossary_approval_list', {id: item.id}) }}">
                        <i class="fas fa-edit"></i>
                    </a>
                    {% endif %}
                    {% if item.suggestions is not empty %}
                        <a class="has-text-warning" href="{{ path('app_plugin_glossary_suggestion_list', {id: item.id}) }}">
                            <i class="fa fa-edit"></i>
                        </a>
                    {% endif %}
                    <a class="has-text-danger" href="{{ path('app_plugin_glossary_delete_view', {id: item.id}) }}">
                        <i class="fa fa-trash"></i>
                    </a>
                </td>
            </tr>
            {% endif %}
        {% endfor %}

        {% for item in list %} {# rest of list #}
            {% if item.approved == true and item.suggestions is empty %}
                <tr class="{% if editItem is defined and editItem.id == item.id %}has-background-light{% endif %}">
                    <td>{{ item.phrase }}</td>
                    {% if config.secondaryEnabled %}<td>{{ item.pinyin }}</td>{% endif %}
                    <td>{{ item.getExplanationShortened(maxLength)|nl2br }}</td>
                    {% if config.hasCategories %}<td>{{ config.getCategoryLabel(item.category)|default('') }}</td>{% endif %}
                    <td>
                        <a href="{{ path('app_plugin_glossary_edit', {id: item.id}) }}">
                            <i class="fas fa-edit"></i>
                        </a>
                        <a class="has-text-danger" href="{{ path('app_plugin_glossary_delete_view', {id: item.id}) }}">
                            <i class="fa fa-trash"></i>
                        </a>
                    </td>
                </tr>
            {% endif %}
        {% endfor %}

    {% else %}{# normal user #}

        {% for item in list %}
            {% if item.approved == true %}
            <tr class="{% if editItem is defined and editItem.id == item.id %}has-background-light{% endif %}">
                <td>{{ item.phrase }}</td>
                {% if config.secondaryEnabled %}<td>{{ item.pinyin }}</td>{% endif %}
                <td>{{ item.getExplanationShortened(maxLength)|nl2br }}</td>
                {% if config.hasCategories %}<td>{{ config.getCategoryLabel(item.category)|default('') }}</td>{% endif %}
                {% if is_granted('ROLE_USER') %}
                    <td>
                        <a href="{{ path('app_plugin_glossary_edit', {id: item.id}) }}">
                            <i class="fas fa-edit"></i>
                        </a>
                        {% if is_granted('ROLE_ORGANIZER') %}
                            <a class="has-text-danger" href="{{ path('app_plugin_glossary_delete_view', {id: item.id}) }}">
                                <i class="fa fa-trash"></i>
                            </a>
                        {% endif %}
                    </td>
                {% endif %}
            </tr>
            {% endif %}
        {% endfor %}
    {% endif %}
    </tbody>
</table>
