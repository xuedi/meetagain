{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Local dependency update checker - creates commits for available updates",
  "extends": [
    "config:recommended"
  ],
  "dryRun": false,
  "platform": "local",
  "requireConfig": "optional",
  "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
  "onboarding": false,
  "ignoreDeps": [],
  "packageRules": [
    {
      "description": "Group all Symfony packages together",
      "matchPackagePrefixes": ["symfony/"],
      "groupName": "Symfony packages"
    },
    {
      "description": "Group all Doctrine packages together",
      "matchPackagePrefixes": ["doctrine/"],
      "groupName": "Doctrine packages"
    },
    {
      "description": "Group all Twig packages together",
      "matchPackagePrefixes": ["twig/"],
      "groupName": "Twig packages"
    }
  ],
  "composer": {
    "enabled": true
  },
  "labels": [],
  "assignees": [],
  "reviewers": [],
  "prConcurrentLimit": 0,
  "prCreation": "immediate",
  "automerge": false,
  "platformAutomerge": false
}
