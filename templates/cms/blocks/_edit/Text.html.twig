<div class="field">
    <label class="label">Content</label>
    <div class="control">
        <textarea class="textarea" name="content" rows="12" placeholder="Textarea">{{ block is defined ? block.content : '' }}</textarea>
    </div>
</div>

<input type="hidden" name="imageRight" value="{{ block is defined and block.imageRight ? '1' : '0' }}">
