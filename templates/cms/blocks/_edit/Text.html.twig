<div class="field">
    <label class="label">Title <span class="has-text-grey is-size-7">(optional)</span></label>
    <div class="control">
        <input class="input" name="title" type="text" value="{{ block is defined ? block.title : '' }}">
    </div>
</div>

<div class="field">
    <label class="label">Content</label>
    <div class="control">
        <textarea class="textarea" name="content" rows="12" placeholder="Textarea">{{ block is defined ? block.content : '' }}</textarea>
    </div>
</div>

<input type="hidden" name="imageRight" value="{{ block is defined and block.imageRight ? '1' : '0' }}">
