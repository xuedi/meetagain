{# not defined: new block  #}
{% if block is not defined or editBlock == blockId %}

    <div class="field">
        <label class="label">Headline</label>
        <div class="control">
            <input class="input" name="headline" type="text" value="{% if block is defined %}{{ block.headline }}{% endif %}">
        </div>
    </div>

    <div class="field">
        <label class="label">SubHeadline</label>
        <div class="control">
            <input class="input" name="subHeadline" type="text" value="{% if block is defined %}{{ block.subHeadline }}{% endif %}">
        </div>
    </div>

    <div class="field">
        <label class="label">Text</label>
        <div class="control">
            <textarea class="textarea" name="text" rows="5" placeholder="Textarea">{% if block is defined %}{{ block.text }}{% endif %}</textarea>
        </div>
    </div>

    <div class="field">
        <label class="label">Button Link</label>
        <div class="control">
            <input class="input" name="buttonLink" type="text" value="{% if block is defined %}{{ block.buttonLink }}{% endif %}">
        </div>
    </div>

    <div class="field">
        <label class="label">Button Text</label>
        <div class="control">
            <input class="input" name="buttonText" type="text" value="{% if block is defined %}{{ block.buttonText }}{% endif %}">
        </div>
    </div>

    <div class="field">
        <label class="label">Background Color</label>
        <div class="control">
            <input class="input" name="color" type="text" value="{% if block is defined %}{{ block.color }}{% endif %}">
        </div>
    </div>

    <input type="hidden" name="imageRight" value="{{ block is defined and block.imageRight ? '1' : '0' }}">

{% else %}

    <div class="has-text-centered"><span class="has-text-grey-light">Hero banner always shown on top</span></div>
    {% if blockImage %}
        <div class="columns is-vcentered">
            {% if not block.imageRight %}
                <div class="column is-4">
                    {% include '_components/image.html.twig' with {'image': blockImage} %}
                </div>
                <div class="column is-1"></div>
            {% endif %}
            <div class="column is-7">
                <h1 class="title is-4">{{ block.headline }}</h1>
                <h2 class="title is-6">{{ block.subHeadline }}</h2>
                <p>{{ block.text|nl2br }}</p>
                <span class="button">{{ block.buttonText }}</span>
                <p class="mt-3">
                    Color: <span class="tag" style="background-color: {{ block.color }}">{{ block.color }}</span>
                </p>
            </div>
            {% if block.imageRight %}
                <div class="column is-1"></div>
                <div class="column is-4">
                    {% include '_components/image.html.twig' with {'image': blockImage} %}
                </div>
            {% endif %}
        </div>
    {% else %}
        <h1 class="title is-4">{{ block.headline }}</h1>
        <h2 class="title is-6">{{ block.subHeadline }}</h2>
        <p>{{ block.text|nl2br }}</p>
        <span class="button">{{ block.buttonText }}</span>
        <p class="mt-3">
            Color: <span class="tag" style="background-color: {{ block.color }}">{{ block.color }}</span>
        </p>
    {% endif %}

{% endif %}
