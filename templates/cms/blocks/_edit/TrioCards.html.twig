<div class="field">
    <label class="label">{{ "trio_cards_headline"|trans }}</label>
    <div class="control">
        <input class="input" name="headline" type="text"
               value="{{ block is defined ? block.headline : '' }}">
    </div>
</div>

{% for i in 0..2 %}
    {% set card = block is defined ? block.cards[i] : null %}
    <div class="box mt-4">
        <p class="has-text-weight-bold mb-3">{{ "trio_cards_card"|trans }} {{ i + 1 }}</p>

        {% if blockId is defined %}
            {# Card image management — only available when editing existing block #}
            <div class="columns is-vcentered mb-3">
                <div class="column is-narrow">
                    {% if card and card.image %}
                        <div class="is-relative" style="width: 105px;">
                            <img src="/images/thumbnails/{{ card.image.hash }}_210x140.webp"
                                 alt="" width="105" height="70"
                                 style="object-fit: cover; display: block;">
                            <a href="{{ path('app_admin_cms_card_image_remove', {'blockId': blockId, 'slot': i}) }}"
                               class="delete is-small has-background-danger"
                               style="position: absolute; top: 2px; right: 2px;"
                               title="Remove"></a>
                        </div>
                    {% else %}
                        <a href="#"
                           class="button is-small is-success modalTrigger"
                           data-modal-url="{{ path('app_admin_cms_card_image_modal', {'blockId': blockId, 'slot': i}) }}">
                            <span class="icon"><i class="fa fa-image"></i></span>
                            <span>{{ "trio_cards_add_image"|trans }}</span>
                        </a>
                    {% endif %}
                </div>
                {% if card and card.image %}
                    <div class="column is-narrow">
                        <a href="#"
                           class="button is-small modalTrigger"
                           data-modal-url="{{ path('app_admin_cms_card_image_modal', {'blockId': blockId, 'slot': i}) }}">
                            <span class="icon"><i class="fa fa-exchange"></i></span>
                            <span>{{ "trio_cards_replace_image"|trans }}</span>
                        </a>
                    </div>
                {% endif %}
            </div>
        {% endif %}

        <div class="field">
            <label class="label">{{ "trio_cards_sub_headline"|trans }}</label>
            <div class="control">
                <input class="input" name="cards[{{ i }}][subHeadline]" type="text"
                       value="{{ card ? card.subHeadline : '' }}">
            </div>
        </div>

        <div class="field">
            <label class="label">{{ "trio_cards_text"|trans }}</label>
            <div class="control">
                <textarea class="textarea" name="cards[{{ i }}][text]" rows="3">{{ card ? card.text : '' }}</textarea>
            </div>
        </div>

        <div class="columns">
            <div class="column">
                <div class="field">
                    <label class="label">{{ "trio_cards_button_text"|trans }}</label>
                    <div class="control">
                        <input class="input" name="cards[{{ i }}][buttonText]" type="text"
                               value="{{ card ? card.buttonText : '' }}">
                    </div>
                </div>
            </div>
            <div class="column">
                <div class="field">
                    <label class="label">{{ "trio_cards_button_link"|trans }}</label>
                    <div class="control">
                        <input class="input" name="cards[{{ i }}][buttonLink]" type="text"
                               value="{{ card ? card.buttonLink : '' }}">
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endfor %}
