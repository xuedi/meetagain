{# not defined: new block  #}
{% if block is not defined or editBlock == blockId %}

    <div class="field">
        <label class="label">Titel</label>
        <div class="control">
            <input class="input" name="title" type="text" value="{% if block is defined %}{{ block.title }}{% endif %}">
        </div>
    </div>

    <div class="field">
        <label class="label">Content</label>
        <div class="control">
            <textarea class="textarea" name="content" placeholder="Textarea">{% if block is defined %}{{ block.content }}{% endif %}</textarea>
        </div>
    </div>

    <div class="field">
        <div class="control">
            <label class="checkbox">
                <input type="hidden" name="imageRight" value="0">
                <input type="checkbox" name="imageRight" value="1" {% if block is defined and block.imageRight %}checked{% endif %}>
                Image Right
            </label>
        </div>
    </div>

{% else %}

    <div class="columns is-vcentered">
        {% if not block.imageRight %}
            <div class="column is-4">
                {% include '_components/image_upload.html.twig' with {
                    'entity': 'cmsBlock',
                    'id': blockId,
                    'image': blockImage
                } %}
            </div>
            <div class="column is-1"></div>
        {% endif %}
        <div class="column">
            <h2 class="title is-5">{{ block.title }}</h2>
            <p>{{ block.content|nl2br }}</p>
        </div>
        {% if block.imageRight %}
            <div class="column is-1"></div>
            <div class="column is-4">
                {% include '_components/image_upload.html.twig' with {
                    'entity': 'cmsBlock',
                    'id': blockId,
                    'image': blockImage
                } %}
            </div>
        {% endif %}
    </div>

{% endif %}
