{#
    Warning Box — Collapsible confirmation panel for destructive admin actions

    Renders a hidden Bulma message element that can be revealed by a toggleTrigger elsewhere
    on the page. Supports danger (red) and warning (orange) variants. An optional confirmation
    button with a trash icon links to the action URL. Used in admin edit pages for delete/reset
    "Danger Zone" sections.

    Used in:    templates/admin/event/edit.html.twig
                templates/admin/cms/cms_edit.html.twig
                templates/admin/host/edit.html.twig
                templates/admin/location/edit.html.twig
    Parameters:
        - id          (string, required)        — unique element ID used by toggleTrigger
        - title       (string, required)        — header text of the message box
        - content     (string, required)        — body HTML; rendered raw
        - type        (string, optional)        — 'danger' (default) or 'warning'
        - buttonUrl   (string, optional)        — action URL; shows button when set
        - buttonLabel (string, optional)        — label for the confirmation button
        - showButton  (bool, optional)          — override button visibility; default true when buttonUrl set
    Depends on: assets/js/toggles.js (.toggleTrigger)
#}
<article class="message is-{{ type|default('danger') }} is-hidden" id="{{ id }}">
    <div class="message-header">
        <p>{{ title }}</p>
        <button class="delete toggleTrigger" data-id="{{ id }}" aria-label="delete"></button>
    </div>
    <div class="message-body has-text-black has-background-white">
        {{ content|raw }}
        {% if (showButton is not defined and buttonUrl is defined) or showButton %}
            <div class="has-text-right mt-3">
                <a class="button" href="{{ buttonUrl }}">
                    <span class="icon"><i class="fa fa-trash"></i></span>
                    <span>{{ buttonLabel }}</span>
                </a>
            </div>
        {% endif %}
    </div>
</article>
