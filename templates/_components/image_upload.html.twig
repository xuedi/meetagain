{#
    Image Upload — Image preview card with modal upload, rotate, and remove actions

    Renders a Bulma card overlay with the current image and action buttons. The upload button
    opens the image modal via AJAX; an optional rotate button posts a rotation request. Hidden
    entirely when no image is set and showWhenEmpty is false.

    Used in:    templates/admin/cms/cms_block_edit.html.twig
                templates/profile/index.html.twig
    Parameters:
        - entity         (string, required)       — entity type key: 'user', 'cmsBlock', 'event'
        - id             (int, required)           — entity ID passed to image modal and rotate routes
        - image          (Image|null, required)    — current image entity; null hides the component unless showWhenEmpty
        - showWhenEmpty  (bool, optional)          — show upload button even when no image; default: false
        - rotate         (bool, optional)          — show rotate button; default: false
        - label          (string, optional)        — upload button label; default: 'Change Image'
        - removeImageUrl (string|null, optional)   — URL for the remove-image action; shows × button when set
    Depends on: _components/image.html.twig, assets/js/modal.js (.modalTrigger, .fileRotateTrigger)
#}
{% if image is not null or (showWhenEmpty is defined and showWhenEmpty) %}
    {% set modalUrl = path('app_image_modal', {'entity': entity, 'id': id}) %}
    {% set label = label is defined ? label : ('shared.image_upload_default_label'|trans) %}
    {% set rotate = rotate is defined ? rotate : false %}

    <div class="card">
        <div class="card-image">
            <figure class="image">
                {% include '_components/image.html.twig' with {'image': image} %}
            </figure>
        </div>
        <div class="card-content is-overlay">
            <a href="#" class="button is-link modalTrigger" data-modal-url="{{ modalUrl }}">
                <span class="icon">
                    <i class="fa fa-images"></i>
                </span>
                <span>{{ label }}</span>
            </a>
            {% if rotate %}
                <a class="button is-link fileRotateTrigger"
                   href="{{ path('app_image_rotate', {'entity': entity, 'id': id}) }}">
                    <span class="icon">
                        <i class="fa fa-rotate-right"></i>
                    </span>
                </a>
            {% endif %}
            {% if removeImageUrl is defined and removeImageUrl is not null %}
                <a class="button is-danger"
                   href="{{ removeImageUrl }}"
                   title="{{ 'shared.image_upload_remove_title'|trans }}">
                    <span class="icon">
                        <i class="fa fa-times"></i>
                    </span>
                </a>
            {% endif %}
        </div>
    </div>
{% endif %}
