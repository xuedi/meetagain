{#
    Toggle — Yes/No button pair for boolean settings

    Renders two small Bulma buttons as an addons group. The active state is colour-coded:
    yes is highlighted green when true, no is highlighted red when false. By default both
    buttons submit a POST with CSRF token via the AJAX toggle handler; passing noAjax
    renders data-post anchors that do a full-page POST instead.

    Used in:    templates/admin/system/config/index.html.twig
                templates/profile/_partials/rsvp_list.html.twig
                templates/profile/config.html.twig
    Parameters:
        - link        (string, required) — URL for both the yes and no actions
        - status      (bool, required)   — current value; drives active button highlight
        - csrfTokenId (string, required) — CSRF token intention string
        - noAjax      (any, optional)    — when defined, renders a plain POST form instead of AJAX
    Depends on: assets/js/block-user.js (.triggerToggleBlock)
#}
{% if noAjax is defined %}
    <div class="buttons has-addons is-right">
        <a href="{{ link }}"
           class="button is-small {% if status %}is-success{% endif %}"
           data-post
           data-csrf-token="{{ csrf_token(csrfTokenId) }}">{{ "shared.toggle_yes"|trans }}</a>
        <a href="{{ link }}"
           class="button is-small {% if not status %}is-danger{% endif %}"
           data-post
           data-csrf-token="{{ csrf_token(csrfTokenId) }}">{{ "shared.toggle_no"|trans }}</a>
    </div>
{% else %}
    <div class="buttons has-addons is-right triggerToggleBlock">
        <button type="button" class="button is-small {% if status %}is-success{% endif %}" data-type="yes" data-url="{{ link }}" data-csrf-token="{{ csrf_token(csrfTokenId) }}">{{ "shared.toggle_yes"|trans }}</button>
        <button type="button" class="button is-small {% if not status %}is-danger{% endif %}" data-type="no" data-url="{{ link }}" data-csrf-token="{{ csrf_token(csrfTokenId) }}">{{ "shared.toggle_no"|trans }}</button>
    </div>
{% endif %}
