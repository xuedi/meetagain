{#
    Toggle yes/no button pair for boolean settings

    Parameters:
    - link: URL for the toggle action (required)
    - status: boolean — true highlights "yes" in green, false highlights "no" in red (required)
    - noAjax: if defined, disables AJAX toggling (optional)
#}
<div class="buttons has-addons is-right {% if noAjax is not defined %}triggerToggleBlock{% endif %}">
    <a href="{{ link }}" class="button is-small {% if status %}is-success{% endif %}" data-type="yes">{{ "toggle_yes"|trans }}</a>
    <a href="{{ link }}" class="button is-small {% if not status %}is-danger{% endif %}" data-type="no">{{ "toggle_no"|trans }}</a>
</div>
