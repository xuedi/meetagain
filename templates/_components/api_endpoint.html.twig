{#
    API Endpoint — Collapsible HTTP method + path row with example payload

    Renders one API endpoint as a colour-coded method badge, a path button, and a chevron
    toggle that reveals a description and curl/JSON example. Colour is driven by the HTTP
    method; the path optionally links to a Symfony route. Expand/collapse is handled by
    the admin debug JS.

    Used in:    templates/_non_locale/api.html.twig
    Parameters:
        - method      (string, required)       — HTTP verb: GET, POST, PUT, or DELETE
        - apiPath     (string, required)       — display path e.g. '/api/v1/events'
        - description (string, required)       — short description shown in the expanded panel
        - example     (string, required)       — example request body; HOST is replaced at render time
        - route       (string|null, optional)  — Symfony route name; makes the path a clickable link
    Depends on: assets/js/admin/debug.js (.api-toggle, .api-example)
#}
{% set methodColors = {'GET': 'is-info', 'POST': 'is-success', 'PUT': 'is-warning', 'PATCH': 'is-link', 'DELETE': 'is-danger'} %}

<div class="api-endpoint api-endpoint--{{ method|lower }}">
    <div class="buttons has-addons mb-1">
        <span class="button {{ methodColors[method] }} is-static api-method">{{ method }}</span>
        {% if route %}
            <a class="button is-light api-path" href="{{ path(route) }}" rel="nofollow">{{ apiPath }}</a>
        {% else %}
            <span class="button is-light is-static api-path">{{ apiPath }}</span>
        {% endif %}
        <button class="button api-toggle" aria-expanded="false" aria-label="{{ 'shared.image_upload_aria_toggle_example'|trans }}">
            <span class="icon"><i class="fas fa-chevron-down"></i></span>
        </button>
    </div>
    <div class="api-example box is-hidden mb-3">
        <p class="has-text-weight-semibold mb-2">{{ description }}</p>
        <pre>{{ example|replace({'HOST': app.request.schemeAndHttpHost}) }}</pre>
    </div>
</div>
