{#
    Username — User display name with optional role/status badges

    Renders the user's name as a profile link followed by zero or more icon badges.
    Badges are coloured Font Awesome icons with a tooltip title, sourced from the
    user_badges() Twig function.

    Used in:    templates/_components/usercard.html.twig
    Parameters:
        - link   (string, required)        — URL to the user's profile page
        - name   (string, required)        — display name shown as the link text
        - badges (UserBadge[], required)   — list of UserBadge DTOs with color, icon, title
#}
<a href="{{ link }}">{{ name }}</a>
{% for badge in badges %}
    <span class="icon {{ badge.color }}" title="{{ badge.title }}">
        <i class="{{ badge.icon }}"></i>
    </span>
{% endfor %}
