{#
    API Toolbox Sidebar — Promotes the meetagain-toolbox repo on the API docs page

    Renders a sticky info box on /api/ that surfaces the out-of-tree toolbox (MCP server +
    SKILL.md). This is the project's discovery surface for AI tooling - we deliberately do
    not advertise via Link: headers or /.well-known/* (see architecture/rest-api.md).
    The npx install line is monospace so users can copy it.

    Used in:    templates/_non_locale/api.html.twig
    Parameters: none
    Depends on: Font Awesome (globally loaded)
#}
<aside class="api-toolbox-sidebar box">
    <h3 class="title is-5">
        <span class="icon-text">
            <span class="icon has-text-link"><i class="fas fa-robot"></i></span>
            <span>{{ 'api.toolbox.title'|trans }}</span>
        </span>
    </h3>

    <p class="mb-4">{{ 'api.toolbox.intro'|trans }}</p>

    <ul>
        <li class="mb-2">{{ 'api.toolbox.bullet_mcp'|trans }}</li>
        <li class="mb-2">{{ 'api.toolbox.bullet_skill'|trans }}</li>
        <li class="mb-2">{{ 'api.toolbox.bullet_rest'|trans }}</li>
    </ul>

    <p class="label is-small has-text-grey mt-4 mb-2">{{ 'api.toolbox.install_label'|trans }}</p>
    <pre class="mb-4">npx -y @meetagain/mcp-server</pre>

    <p class="label is-small has-text-grey mt-4 mb-2">{{ 'api.toolbox.spec_label'|trans }}</p>
    <p class="mb-4">
        <a href="{{ path('app_api_openapi') }}" class="is-family-monospace is-size-7">
            <span class="icon"><i class="fas fa-code"></i></span>
            <span>/api/openapi.json</span>
        </a>
        <span class="is-size-7 has-text-grey ml-1">{{ 'api.toolbox.spec_help'|trans }}</span>
    </p>

    <div class="buttons">
        <a class="button is-link is-light is-fullwidth"
           href="https://github.com/xuedi/meetagain-toolbox"
           target="_blank" rel="noopener">
            <span class="icon"><i class="fab fa-github"></i></span>
            <span>{{ 'api.toolbox.button_github'|trans }}</span>
        </a>
        <a class="button is-light is-fullwidth"
           href="https://github.com/xuedi/meetagain-toolbox/blob/main/mcp-server/README.md"
           target="_blank" rel="noopener">
            <span class="icon"><i class="fas fa-rocket"></i></span>
            <span>{{ 'api.toolbox.button_install'|trans }}</span>
        </a>
    </div>
</aside>
