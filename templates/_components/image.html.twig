{#
    Image — Thumbnail image tag with automatic size selection and cache-busting

    Renders a WebP thumbnail from /images/thumbnails/ or a default PNG placeholder when
    no image is provided. The size can be passed explicitly; when omitted it is derived
    from the image type enum value. A cache-busting query string is appended via updatedAt.

    Used in:    widely used — _components/comment, usercard, image_upload and many page templates
    Parameters:
        - image (Image|null, optional) — entity with hash, alt, updatedAt, type; null shows placeholder
        - size  (string, optional)     — explicit thumbnail dimensions as 'WxH' e.g. '400x400';
                                         auto-selected from image.type when omitted:
                                         type 1 → 400x400, type 2 → 600x400, type 3 → 210x140,
                                         type 4 → 432x432, default → 50x50
#}
{% if size is not defined  %}
    {% set size = '50x50' %}
    {% if image is defined and image.type is defined %}
        {% if image.type.value == 1 %}
            {% set size = '400x400' %}
        {% endif %}
        {% if image.type.value == 2 %}
            {% set size = '600x400' %}
        {% endif %}
        {% if image.type.value == 3 %}
            {% set size = '210x140' %}
        {% endif %}
        {% if image.type.value == 4 %}
            {% set size = '432x432' %}
        {% endif %}
    {% endif %}
{% endif %}

{% if image is defined and image %}
    {% set file = image.hash ~ '_' ~ size ~ '.webp' %}{# ~ image.extension #}
    {% if image.updatedAt is not null %}{# to invalidate browser cache #}
        {% set file = file ~ '?v' ~ image.updatedAt|date("YmdHis") %}
    {% endif %}
    <img src="/images/thumbnails/{{ file }}" alt="{{ image.alt|default('') }}" width="{{ size|split('x')[0] }}" height="{{ size|split('x')[1] }}" />
{% else %}
    <img src="{{ asset('images/default_' ~ size ~ '.png') }}" alt="Placeholder IMAGE"/>
{% endif %}
