{% include 'base_navbar_notifications.html.twig' %}
{% if is_granted('developer_app.review') %}
    {% set pendingDeveloperApps = pending_developer_app_count() %}
    {% if pendingDeveloperApps > 0 %}
        <a href="{{ path('app_admin_security_developer_apps', {'status': 'pending'}) }}"
           class="navbar-item" title="{{ 'developer_apps.pill_admin_title'|trans }}">
            <span class="icon"><i class="fa fa-inbox"></i></span>
            <span class="tag is-warning ml-2">{{ pendingDeveloperApps }}</span>
        </a>
    {% endif %}
{% endif %}
{% if app.user %}
    {% set unreadDeveloperAppOutcomes = unread_developer_app_outcome_count() %}
    {% if unreadDeveloperAppOutcomes > 0 %}
        <a href="{{ path('app_profile_developer_apps', {'filter': 'unread-outcome'}) }}"
           class="navbar-item" title="{{ 'developer_apps.pill_user_title'|trans }}">
            <span class="icon"><i class="fa fa-bell"></i></span>
            <span class="tag is-info ml-2">{{ unreadDeveloperAppOutcomes }}</span>
        </a>
    {% endif %}
{% endif %}
<div class="navbar-item dropdown is-hoverable">
    <div class="dropdown-trigger">
        <button class="button" aria-haspopup="true" aria-controls="dropdown-menu">
            <span>{{ app.user.name }}</span>
            <span class="icon is-small">
                <i class="fas fa-angle-down" aria-hidden="true"></i>
            </span>
        </button>
    </div>
    <div class="dropdown-menu" id="dropdown-menu" role="menu">
        <div class="dropdown-content">
            <a class="navbar-item" href="{{ path('app_profile') }}">{{ "chrome.menu_profile_view_profile" | trans }}</a>
            <a class="navbar-item" href="{{ path('app_profile_social') }}">{{ "chrome.menu_profile_social" | trans }}</a>
            <a class="navbar-item" href="{{ path('app_profile_messages') }}">{{ "chrome.menu_profile_messages" | trans }}</a>
            <a class="navbar-item" href="{{ path('app_profile_images') }}">{{ "chrome.menu_profile_images" | trans }}</a>
            {% for link in get_plugin_profile_dropdown_links() %}
                <a class="navbar-item" href="{{ link.slug }}">{{ link.name | trans }}</a>
            {% endfor %}
            <hr class="dropdown-divider"/>
            <a class="navbar-item" href="{{ path('app_profile_config') }}">{{ "chrome.menu_profile_config" | trans }}</a>
            <hr class="dropdown-divider"/>
            <form action="{{ path('app_security_logout') }}" method="post" class="is-contents">
                <input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
                <button type="submit" class="navbar-item LinkLikeButton">{{ "chrome.menu_profile_logout" | trans }}</button>
            </form>
        </div>
    </div>
</div>
