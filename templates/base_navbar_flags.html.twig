{% if app.request.attributes.get('_route_params') is not null and get_alternative_languages()  is not empty %}
    <div class="navbar-item dropdown is-hoverable pl-0">
        <div class="dropdown-trigger is-hoverable">
            <button class="button" aria-haspopup="menu" aria-label="Select language">
                <span class="icon">
                    <img class="is-flag" src="{{ asset('images/flags/' ~ app.request.locale ~ '.svg') }}" width="32" height="24"
                         alt="Current locale flag: {{ app.request.locale }}"/>
                </span>
                <span class="icon is-small"><i class="fas fa-angle-down" aria-hidden="true"></i></span>
            </button>
        </div>
        <div class="dropdown-menu" id="dropdown-languages" role="menu">
            <div class="dropdown-content">
                {% for altLangCode, altLangLink in get_alternative_languages() %}
                    <link rel="alternate" hreflang="{{ altLangCode }}" href="{{ altLangLink }}"/>
                    <nobr>
                        <a class="navbar-item" href="{{ altLangLink }}" role="menuitem">
                            <figure style="width: 32px; height: 24px; flex-shrink: 0; overflow: hidden;">
                                <img class="is-flag" src="{{ asset('images/flags/' ~ altLangCode ~ '.svg') }}" width="32" height="24"
                                     alt="Locale flag: {{ altLangCode }}"/>
                            </figure>
                            <span class="ml-3">
                                {{ ('language_'~altLangCode) | trans({}, "messages", altLangCode) }}
                            </span>
                            <span class="ml-2 has-text-grey">
                                ({{ ('language_'~altLangCode) | trans }})
                            </span>
                        </a>
                    </nobr>
                {% endfor %}
            </div>
        </div>
    </div>
{% endif %}
