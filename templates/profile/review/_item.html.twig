{% set csrfToken = csrf_token('review_action') %}
<div class="box">
    <div class="columns is-vcentered">
        <div class="column">
            <div class="media">
                {% if item.icon %}
                <div class="media-left">
                    <span class="icon is-medium has-text-grey">
                        <i class="fas fa-{{ item.icon }}"></i>
                    </span>
                </div>
                {% endif %}
                <div class="media-content">
                    <p>{{ item.description }}</p>
                    {% if item.longDescription is not null %}
                        <p class="has-text-grey-dark mt-2">{{ item.longDescription|nl2br }}</p>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="column is-narrow">
            <div class="buttons are-small">
                <form method="post" action="{{ path('app_profile_review_approve', {providerIdentifier: providerIdentifier, itemId: item.id}) }}" style="display:inline">
                    <input type="hidden" name="_token" value="{{ csrfToken }}">
                    <button type="submit" class="button is-success">
                        {{ 'profile.review.approve'|trans }}
                    </button>
                </form>
                {% if item.canDeny %}
                <form method="post" action="{{ path('app_profile_review_deny', {providerIdentifier: providerIdentifier, itemId: item.id}) }}" style="display:inline">
                    <input type="hidden" name="_token" value="{{ csrfToken }}">
                    <button type="submit" class="button is-danger is-outlined">
                        {{ 'profile.review.deny'|trans }}
                    </button>
                </form>
                {% endif %}
            </div>
        </div>
    </div>
</div>
