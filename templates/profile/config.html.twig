{% extends 'base.html.twig' %}

{% block title %}{{ "profile.page_title"|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <div class="columns">
                <div class="column">

                    <div class="box">
                        <h1 class="title is-5">{{ 'profile_config.section_settings'|trans }}</h1>
                        <div class="field is-grouped">
                            <div class="control is-expanded">
                                {{ 'profile_config.toggle_email_notification'|trans }}
                            </div>
                            <div class="control">
                                {% include '_components/toggle.html.twig' with {
                                    'link': path('app_profile_config_toggle', {'type': 'notification'}),
                                    'status': user.isNotification,
                                    'noAjax': true
                                } %}
                            </div>
                        </div>
                        {% if user.isNotification %}
                            {% for notification in user.notificationSettings.list %}
                                <div class="field is-grouped">
                                    <div class="control is-expanded">{{ notification.label }}</div>
                                    <div class="control">
                                        {% include '_components/toggle.html.twig' with {
                                            'link': path('app_profile_config_toggle_notification', {'type': notification.key}),
                                            'status': notification.value,
                                        } %}
                                    </div>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>

                    <div class="box">
                        <h2 class="title is-5">{{ 'profile_config.section_privacy'|trans }}</h2>
                        <div class="field is-grouped">
                            <div class="control is-expanded">{{ 'profile_config.toggle_public_profile'|trans }}</div>
                            <div class="control">
                                {% include '_components/toggle.html.twig' with {
                                    'link': path('app_profile_config_toggle', {'type': 'public'}),
                                    'status': user.isPublic
                                } %}
                            </div>
                        </div>
                        <div class="field is-grouped">
                            <div class="control is-expanded">{{ 'profile_config.toggle_tagging'|trans }}</div>
                            <div class="control">
                                {% include '_components/toggle.html.twig' with {
                                    'link': path('app_profile_config_toggle', {'type': 'tagging'}),
                                    'status': user.isTagging
                                } %}
                            </div>
                        </div>
                        <div class="field is-grouped">
                            <div class="control is-expanded">{{ 'profile_config.toggle_osm'|trans }}</div>
                            <div class="control">
                                {% include '_components/toggle.html.twig' with {
                                    'link': path('app_profile_config_toggle', {'type': 'osm'}),
                                    'status': user.isOsmConsent
                                } %}
                            </div>
                        </div>
                    </div>

                </div>
                <div class="column">

                    <div class="box">
                        <h2 class="title is-5">{{ 'profile_config.section_change_password'|trans }}</h2>
                        {{ form_start(form) }}
                        {% for flash_error in app.flashes('error') %}
                            <div class="notification is-danger">
                                <button class="delete"></button>{{ flash_error }}</div>
                        {% endfor %}
                        {% for flash_success in app.flashes('success') %}
                            <div class="notification is-success">
                                <button class="delete"></button>{{ flash_success }}</div>
                        {% endfor %}
                        {{ form_errors(form) }}

                        {{ form_row(form.oldPassword) }}
                        {{ form_row(form.newPassword) }}

                        <button class="button is-link">{{ "button_change_password" | trans }}</button>
                        {{ form_end(form) }}

                        <p class="mt-4">
                            {{ 'profile_config.password_reset_hint'|trans({'%reset_link%': '<a href="' ~ path('app_reset') ~ '">' ~ ('profile_config.password_reset_link_label'|trans) ~ '</a>'})|raw }}
                        </p>
                    </div>

                    <div class="box">
                        <h2 class="title is-5">{{ 'profile_config.section_blocked_users'|trans }}</h2>
                        {% if blockedUsers|length == 0 %}
                            <p>{{ 'profile_config.blocked_empty'|trans }}</p>
                        {% else %}
                            <table class="table is-fullwidth">
                                <tbody>
                                {% for block in blockedUsers %}
                                    <tr id="block-{{ block.blocked.id }}">
                                        <td class="col-narrow">
                                            {% include '_components/image.html.twig' with {'image': block.blocked.image, 'size': '50x50'} %}
                                        </td>
                                        <td>
                                            {{ block.blocked.name }}
                                        </td>
                                        <td style="width: 60px; text-align: right;">
                                            <a href="{{ path('app_profile_unblock_user', {'id': block.blocked.id}) }}"
                                               class="ajax-unblock"
                                               data-user-id="{{ block.blocked.id }}"
                                               data-user-name="{{ block.blocked.name }}">
                                                <span class="icon"><i class="fa fa-unlock"></i></span>
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                            <p class="mt-2">
                                <a href="{{ path('app_profile_blocked_users') }}">{{ 'profile_config.blocked_view_all'|trans }}</a>
                            </p>
                        {% endif %}
                    </div>

                </div>
            </div>


        </div>
    </section>

{% endblock %}
