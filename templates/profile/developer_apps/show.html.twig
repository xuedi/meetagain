{% extends 'base.html.twig' %}

{% block title %}{{ app.appName }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="container">
            <nav class="breadcrumb is-small" aria-label="breadcrumbs">
                <ul>
                    <li><a href="{{ path('app_profile_developer_apps') }}">{{ 'developer_apps.heading'|trans }}</a></li>
                    <li class="is-active"><a aria-current="page">{{ app.appName }}</a></li>
                </ul>
            </nav>

            {% if app.hasUnreadOutcome %}
                {% set notifClass = 'is-info' %}
                {% set heading = '' %}
                {% if app.status.value == 'approved' %}
                    {% set notifClass = 'is-success' %}
                    {% set heading = 'developer_apps.outcome_approved_heading'|trans %}
                {% elseif app.status.value == 'denied' %}
                    {% set notifClass = 'is-warning' %}
                    {% set heading = 'developer_apps.outcome_denied_heading'|trans %}
                {% elseif app.status.value == 'revoked' %}
                    {% set notifClass = 'is-danger' %}
                    {% set heading = 'developer_apps.outcome_revoked_heading'|trans %}
                {% endif %}
                <section class="notification {{ notifClass }}">
                    <h2 class="title is-5">{{ heading }}</h2>
                    {% if app.status.value == 'approved' %}
                        <p>{{ 'developer_apps.outcome_approved_body'|trans }}</p>
                        <p class="mt-3"><strong>{{ 'developer_apps.label_client_id'|trans }}:</strong> <code>{{ app.clientIdentifier }}</code></p>
                        {% if clientSecret is not null and clientSecret != '' %}
                            <p class="mt-2"><strong>{{ 'developer_apps.label_client_secret'|trans }}:</strong> <code>{{ clientSecret }}</code></p>
                            <p class="has-text-weight-bold mt-2">{{ 'developer_apps.outcome_secret_warning'|trans }}</p>
                        {% endif %}
                    {% elseif app.status.value == 'denied' %}
                        {% if app.denyReason %}
                            <p><strong>{{ 'developer_apps.label_reason'|trans }}:</strong> {{ app.denyReason }}</p>
                        {% endif %}
                        <p class="mt-2">
                            <a class="button is-light is-small" href="{{ path('app_profile_developer_apps_submit_revision', {'id': app.id}) }}">
                                {{ 'developer_apps.button_revise_resubmit'|trans }}
                            </a>
                        </p>
                    {% elseif app.status.value == 'revoked' %}
                        {% if app.denyReason %}
                            <p><strong>{{ 'developer_apps.label_reason'|trans }}:</strong> {{ app.denyReason }}</p>
                        {% endif %}
                        <p class="mt-2">{{ 'developer_apps.outcome_revoked_body'|trans }}</p>
                    {% endif %}

                    <form method="post" action="{{ path('app_profile_developer_apps_acknowledge', {'id': app.id}) }}" class="mt-3">
                        <input type="hidden" name="_token" value="{{ csrf_token('developer_apps_acknowledge_' ~ app.id) }}">
                        <button class="button is-light" type="submit">{{ 'developer_apps.button_got_it'|trans }}</button>
                    </form>
                </section>
            {% endif %}

            <div class="box">
                <h1 class="title is-4">{{ app.appName }}</h1>
                <p>
                    <span class="tag {{ app.status.tagClass }}">{{ app.status.label|trans }}</span>
                </p>

                <table class="table is-fullwidth mt-4">
                    <tbody>
                        {% if app.description %}
                            <tr><th>{{ 'developer_apps.label_description'|trans }}</th><td>{{ app.description }}</td></tr>
                        {% endif %}
                        {% if app.homepageUrl %}
                            <tr><th>{{ 'developer_apps.label_homepage'|trans }}</th><td><a href="{{ app.homepageUrl }}" rel="noopener">{{ app.homepageUrl }}</a></td></tr>
                        {% endif %}
                        <tr>
                            <th>{{ 'developer_apps.label_redirect_uris'|trans }}</th>
                            <td>
                                <ul>
                                    {% for uri in app.redirectUris %}<li><code>{{ uri }}</code></li>{% endfor %}
                                </ul>
                            </td>
                        </tr>
                        <tr>
                            <th>{{ 'developer_apps.label_grants'|trans }}</th>
                            <td>{{ app.requestedGrants|join(', ') }}</td>
                        </tr>
                        <tr><th>{{ 'developer_apps.label_submitted'|trans }}</th><td>{{ app.submittedAt|date('Y-m-d H:i') }}</td></tr>
                        {% if app.reviewedAt %}
                            <tr><th>{{ 'developer_apps.label_reviewed'|trans }}</th><td>{{ app.reviewedAt|date('Y-m-d H:i') }}</td></tr>
                        {% endif %}

                        {% if app.status.value == 'approved' %}
                            <tr>
                                <th>{{ 'developer_apps.label_client_id'|trans }}</th>
                                <td><code>{{ app.clientIdentifier }}</code></td>
                            </tr>
                            <tr>
                                <th>{{ 'developer_apps.label_client_secret'|trans }}</th>
                                <td>
                                    {% if clientSecret is not null and clientSecret != '' and not app.hasUnreadOutcome %}
                                        <code>{{ clientSecret }}</code>
                                    {% else %}
                                        <span class="has-text-grey">{{ 'developer_apps.secret_placeholder'|trans }}</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endif %}
                    </tbody>
                </table>

                <div class="buttons mt-4">
                    <a class="button is-light" href="{{ path('app_profile_developer_apps_edit', {'id': app.id}) }}">
                        {{ 'developer_apps.button_edit'|trans }}
                    </a>
                    {% if app.status.value in ['approved', 'denied', 'revoked'] %}
                        <a class="button is-warning is-light" href="{{ path('app_profile_developer_apps_submit_revision', {'id': app.id}) }}">
                            {{ 'developer_apps.button_revise_resubmit'|trans }}
                        </a>
                    {% endif %}
                    <form method="post" action="{{ path('app_profile_developer_apps_delete', {'id': app.id}) }}" onsubmit="return confirm('{{ 'developer_apps.confirm_delete'|trans }}');">
                        <input type="hidden" name="_token" value="{{ csrf_token('developer_apps_delete_' ~ app.id) }}">
                        <button class="button is-danger is-light" type="submit">{{ 'developer_apps.button_delete'|trans }}</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
