<table class="table is-fullwidth mt-3">
    <tbody>
    <tr>
        <td class="has-text-grey has-text-centered pt-6" colspan="2">{{ title }}</td>
    </tr>
    {% for user in userlist %}
        {% if loop.index == 6 %}
            <tr>
                <td class="has-text-centered" colspan="2">
                    <a data-show-more href="#">{{ 'profile_social.list_show_more'|trans }}</a>
                </td>
            </tr>
        {% endif %}
        <tr class="{% if loop.index > 5 %}is-hidden{% endif %}">
            <td>
                <span class="icon">
                    <a href="{{ path('app_profile_messages', {'id': user.id}) }}" class="fa fa-envelope has-text-grey-light"></a>
                </span>
                <a href="{{ path('app_member_view', {'id': user.id}) }}" class="has-text-dark">{{ user.name }}</a>
            </td>
            <td class="has-text-right">
                <form method="post" action="{{ path('app_profile_social_toggle_follow', {'id': user.id}) }}" class="is-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('app_profile_social_toggle_follow' ~ user.id) }}">
                    <button type="submit" class="button is-small {{ buttonColor }}">
                        <span class="icon"><i class="fa fa-plus"></i></span><span>{{ buttonTitle }}</span>
                    </button>
                </form>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
