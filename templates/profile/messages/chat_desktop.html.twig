<div class="container">

    <div class="columns">
        <div class="column is-3">

            <div class="panel is-shadowless">

                <div class="panel-block">
                    <h1 class="title is-5">{{ 'profile_messages.section_heading'|trans }}</h1>
                </div>

                {% for conversation in conversations %}
                    <!-- TODO: is-active -->
                    <a class="panel-block is-block"
                            {% if conversationsId == conversation.user.id %} class="message-own" {% endif %}
                       href="{{ path('app_profile_messages', {'id': conversation.user.id}) }}"
                    >
                        <div class="level">
                            <div class="level-left">
                                <div class="level-item">
                                    {% include '_components/image.html.twig' with {'image': conversation.user.image, 'size': '50x50'} %}
                                </div>
                                <div class="level-item">
                                    <div class="is-block has-text-left">
                                        <strong>{{ conversation.user.name }}</strong><br/>
                                        <small class="is-small">{{ conversation.lastMessage | time_diff }}</small>
                                    </div>
                                </div>
                            </div>
                            <div class="level-right">
                                <div class="content">
                                    {% if conversation.unread > 0 %}
                                        <span class="tag has-background-danger-light">{{ conversation.unread }}</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </a>
                {% endfor %}

            </div>
        </div>

        <div class="column is-9">

            {% if messages is null %}
                <h1 class="title is-6">{{ 'profile_messages.welcome_heading'|trans }}</h1>
                <p class="mb-2">
                    {{ 'profile_messages.welcome_intro'|trans }}
                </p>
                <p class="mb-2">
                    {{ 'profile_messages.welcome_rule'|trans }}
                </p>
                <p class="mb-2">
                    {{ 'profile_messages.welcome_addressbook_hint'|trans }}
                </p>
            {% else %}
                <div class="chat-layout">
                    {# Block button in header #}
                    {% if conversationsId %}
                        <div class="level mb-2">
                            <div class="level-left"></div>
                            <div class="level-right">
                                {% if hasBlockedPartner %}
                                    <form action="{{ path('app_profile_unblock_user', {'id': conversationsId}) }}" method="post" class="is-inline ajax-block-form">
                                        <button type="submit" class="button is-warning is-small">
                                            <span class="icon"><i class="fa fa-unlock"></i></span><span>{{ 'member.button_unblock'|trans }}</span>
                                        </button>
                                    </form>
                                {% else %}
                                    <form action="{{ path('app_profile_block_user', {'id': conversationsId}) }}" method="post" class="is-inline ajax-block-form">
                                        <button type="submit" class="button is-dark is-small">
                                            <span class="icon"><i class="fa fa-ban"></i></span><span>{{ 'member.button_block'|trans }}</span>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}

                    <div class="pr-3 messages-scroll" id="desktop-message-container">
                        {% for message in messages %}
                            {% if user.id == message.sender.id %}
                                <div class="level is-block">
                                    <div class="level-right">
                                        <div class="level-item">
                                            <div class="box">
                                                <small class="is-small">{{ message.createdAt | time_diff }}</small><br>
                                                <span class="breakText">{{ message.content }}</span>
                                            </div>
                                        </div>
                                        <div class="level-item">
                                            {% include '_components/image.html.twig' with {'image': message.sender.image, 'size': '50x50'} %}
                                        </div>
                                    </div>
                                </div>
                            {% else %}
                                <div class="level">
                                    <div class="level-left">
                                        <div class="level-item">
                                            {% include '_components/image.html.twig' with {'image': message.sender.image, 'size': '50x50'} %}
                                        </div>
                                        <div class="level-item">
                                            <div class="box">
                                                <small class="is-small">{{ message.createdAt | time_diff }}</small><br>
                                                <span class="breakText">{{ message.content }}</span>
                                            </div>
                                        </div>
                                        {% if message.wasRead == false %}
                                            <div class="level-item">
                                                    <span class="panel-icon has-text-danger">
                                                        <i class="fas fa-circle" aria-hidden="true"></i>
                                                    </span>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <div>
                        <hr>
                        {% if isBlocked %}
                            <div class="notification is-warning">
                                <span class="icon"><i class="fa fa-ban"></i></span>
                                {{ 'profile_messages.cannot_message'|trans }}
                            </div>
                        {% elseif form %}
                            {{ form_start(form) }}
                            <div class="level">
                                <div class="level-item">
                                    <input class="input" type="text" name="{{ field_name(form.comment) }}"
                                           placeholder="{{ 'profile_messages.input_placeholder'|trans }}"/>
                                </div>
                                <div class="level-right">
                                    <button class="button is-link ml-2">{{ 'profile_messages.button_send'|trans }}</button>
                                </div>
                            </div>
                            {{ form_end(form) }}
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>

</div>