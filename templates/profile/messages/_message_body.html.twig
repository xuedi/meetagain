{# Renders a chat message body. A support-question marker prefix is shown as a coloured system note. #}
{% set marker = constant('App\\Entity\\Message::SUPPORT_QUESTION_MARKER') %}
{% if content starts with marker %}
    <span class="has-text-warning-dark has-text-weight-semibold">{{ 'profile_messages.system_support_question'|trans }}</span><br>
    <span class="breakText">{{ content|slice(marker|length) }}</span>
{% else %}
    <span class="breakText">{{ content }}</span>
{% endif %}
