{% set selectableGallery = (imageUploadGallery is defined ? imageUploadGallery : [])|filter(item => item.link is not null) %}
{% if selectableGallery is not empty %}
    <h1 class="title is-4">Choose from previous images</h1>
    <div class="mb-5">
        {% for galleryItem in selectableGallery %}
            <a href="{{ galleryItem.link }}" class="image-item fileSelectTrigger">
                {% include '_block/image.html.twig' with {'image': galleryItem.image, 'size': '80x80'} %}
            </a>
        {% endfor %}
    </div>
{% endif %}

<div class="title is-4">Upload new Image</div>
{% if uploadForm is defined %}
    {{ form_start(uploadForm) }}
    {{ form_row(uploadForm.files) }}
    <div class="field">
        <button type="submit" class="button is-link">Upload</button>
    </div>
    {{ form_end(uploadForm) }}
{% else %}
    <div class="file is-link">
        <label class="file-label">
            <input
                class="file-input fileUploadTrigger"
                type="file"
                name="image_upload[newImage]"
                data-url="{{ uploadUrl }}"
            />
            <span class="file-cta">
                <span class="file-icon">
                    <i class="fas fa-upload"></i>
                </span>
                <span class="file-label">Upload image</span>
            </span>
        </label>
    </div>
    <p class="mt-3">
        Selected images are uploaded and used immediately, no confirmation.
    </p>
{% endif %}
