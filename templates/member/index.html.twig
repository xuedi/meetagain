{% extends 'base.html.twig' %}

{% block title %}{% if pageCurrent > 1 %}{{ "member.page_title_paginated"|trans({'%page%': pageCurrent}) }}{% else %}{{ "member.page_title"|trans }}{% endif %}{% endblock %}
{% block meta_description %}{{ get_meta_description('members') }}{% endblock %}

{% block body %}
    <section class="section">
        <div class="container">
            <h1 class="title is-3">{{ 'member.page_title' | trans }}</h1>

            <div class="columns is-multiline">
                {% for user in users %}
                    <div class="column is-2">
                        {% include '_components/usercard.html.twig' with {'user': user} %}
                    </div>
                {% endfor %}
            </div>

            {% if pageTotal > 1 %}
                <nav class="pagination is-centered" role="navigation" aria-label="pagination">
                    {% if pageCurrent > 1 %}
                        <a href="{{ path('app_member', {'page': pageCurrent - 1}) }}"
                           class="pagination-previous">{{ 'member.pagination_previous'|trans }}</a>
                    {% endif %}

                    {% if pageCurrent < pageTotal %}
                        <a href="{{ path('app_member', {'page': pageCurrent + 1}) }}"
                           class="pagination-next">{{ 'member.pagination_next'|trans }}</a>
                    {% endif %}

                    <ul class="pagination-list">
                        {% for i in 1..pageTotal %}
                            <li>
                                <a href="{{ path('app_member', {'page': i}) }}"
                                   class="pagination-link {% if i == pageCurrent %}is-current{% endif %}"
                                   aria-label="{{ 'member.pagination_aria_label'|trans({'%page%': i}) }}"
                                   aria-current="{% if i == pageCurrent %}page{% endif %}">
                                    {{ i }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </nav>

                <div class="has-text-centered mt-4">
                    <p class="help">
                        {{ 'member.pageview_information' | trans ({
                            '%pageCurrent%': pageCurrent,
                            '%pageTotal%': pageTotal,
                            '%userTotal%': userTotal
                        }) }}
                    </p>
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}