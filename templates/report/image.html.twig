{% extends 'base.html.twig' %}

{% block title %}{{ "report.page_title_image"|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">
            <div class="columns is-centered">
                <div class="column is-6">
                    <div class="box">

                        <div class="notification is-warning">
                            <p class="has-text-weight-bold">{{ "report.warning_title"|trans }}</p>
                            <p>{{ "report.warning_body"|trans }}</p>
                        </div>

                        <div class="has-text-centered mb-5">
                            {% include '_components/image.html.twig' with {'image': image, 'size': '100x100'} %}
                        </div>

                        {{ form_start(form) }}

                        <div class="field">
                            {{ form_row(form.reported) }}
                        </div>

                        <div class="field">
                            {{ form_row(form.remarks) }}
                        </div>

                        <div class="field">
                            <button class="button is-danger is-medium is-fullwidth">
                                <span class="icon is-small">
                                    <i class="fa-solid fa-circle-exclamation"></i>
                                </span>
                                <span>{{ "report.button_submit"|trans }}</span>
                            </button>
                        </div>

                        {{ form_end(form) }}

                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
