{% extends 'base.html.twig' %}

{% block title %}{{ "registration_approved_title"|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <div class="columns is-centered">
                <div class="column is-8">

                    <div class="box">
                        <div class="has-text-centered mb-5">
                            <span class="icon is-large has-text-success">
                                <i class="fas fa-check-circle fa-3x"></i>
                            </span>
                        </div>

                        <h1 class="title has-text-centered">{{ "registration_approved_title"|trans }}</h1>
                        <p class="subtitle has-text-centered">{{ "registration_approved_subtitle"|trans }}</p>

                        <div class="content">
                            <h3>{{ "registration_next_steps"|trans }}</h3>
                            <ul>
                                <li><strong>{{ "registration_tip_profile"|trans }}</strong> - {{ "registration_tip_profile_desc"|trans }}</li>
                                <li><strong>{{ "registration_tip_events"|trans }}</strong> - {{ "registration_tip_events_desc"|trans }}</li>
                                <li><strong>{{ "registration_tip_community"|trans }}</strong> - {{ "registration_tip_community_desc"|trans }}</li>
                                <li><strong>{{ "registration_tip_settings"|trans }}</strong> - {{ "registration_tip_settings_desc"|trans }}</li>
                            </ul>
                        </div>

                        <div class="has-text-centered mt-5">
                            <a href="{{ path('app_login') }}" class="button is-primary is-large">
                                <span class="icon">
                                    <i class="fas fa-sign-in-alt"></i>
                                </span>
                                <span>{{ "login_now"|trans }}</span>
                            </a>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </section>

{% endblock %}
