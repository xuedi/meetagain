{% extends 'base.html.twig' %}

{% block title %}{{ "security.approved_title"|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <div class="columns is-centered mt-6">
                <div class="column is-6-tablet is-5-desktop">

                    <div class="has-text-centered mb-5">
                        <span class="icon is-large has-text-success">
                            <i class="fas fa-check-circle fa-4x"></i>
                        </span>
                    </div>

                    <h1 class="title has-text-centered">{{ "security.approved_title"|trans }}</h1>
                    <p class="subtitle has-text-centered">{{ "security.approved_subtitle"|trans }}</p>

                    <div class="content mt-5">
                        <h3>{{ "security.approved_next_steps"|trans }}</h3>
                        <ul>
                            <li><strong>{{ "security.approved_tip_profile"|trans }}</strong> - {{ "security.approved_tip_profile_desc"|trans }}</li>
                            <li><strong>{{ "security.approved_tip_events"|trans }}</strong> - {{ "security.approved_tip_events_desc"|trans }}</li>
                            <li><strong>{{ "security.approved_tip_community"|trans }}</strong> - {{ "security.approved_tip_community_desc"|trans }}</li>
                            <li><strong>{{ "security.approved_tip_settings"|trans }}</strong> - {{ "security.approved_tip_settings_desc"|trans }}</li>
                        </ul>
                    </div>

                    <div class="has-text-centered mt-5">
                        <a href="{{ path('app_login') }}" class="button is-primary is-medium">
                            <span class="icon">
                                <i class="fas fa-sign-in-alt"></i>
                            </span>
                            <span>{{ "security.button_login_now"|trans }}</span>
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </section>

{% endblock %}
