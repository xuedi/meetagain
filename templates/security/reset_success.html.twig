{% extends 'base.html.twig' %}

{% block title %}{{ "page_reset_success_title"|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">
            <div class="columns is-centered mt-6">
                <div class="column is-6-tablet is-5-desktop has-text-centered">
                    <span class="icon is-large has-text-success">
                        <i class="fas fa-check-circle fa-4x"></i>
                    </span>
                    <h1 class="title is-3 mt-5">{{ 'reset_success.heading'|trans }}</h1>
                    <p class="subtitle is-5 mt-3">{{ 'reset_success.description'|trans }}</p>
                    <div class="mt-5">
                        <a href="{{ path('app_login') }}" class="button is-primary">
                            <span class="icon"><i class="fas fa-sign-in-alt"></i></span>
                            <span>{{ 'reset_success.cta'|trans }}</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
