{% extends 'base.html.twig' %}

{% block title %}{{ "page_title_register"|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <div class="columns is-centered mt-5">
                <div class="column is-6-tablet is-5-desktop">

                    <h1 class="title is-5">{{ "page_register_headline"|trans }}</h1>

                    {{ form_start(form) }}

                    {% for flash_error in app.flashes('verify_email_error') %}
                        <div class="notification is-danger is-light mb-4" role="alert">{{ flash_error }}</div>
                    {% endfor %}

                    {{ form_errors(form) }}

                    {{ form_row(form.name) }}
                    {{ form_row(form.email) }}
                    {{ form_row(form.plainPassword, {
                        label: 'Password'
                    }) }}
                    {{ form_row(form.agreeTerms) }}

                    <div class="field is-grouped mt-4">
                        <div class="control">
                            <button class="button is-primary">{{ "button_Register" | trans }}</button>
                            <a class="button is-light" href="/{{ app.request.locale }}/terms" target="_blank" rel="noopener">{{ "terms" | trans }}</a>
                        </div>
                    </div>
                    {{ form_end(form) }}

                </div>

                <div class="column is-5-tablet is-4-desktop">
                    {% include '_components/info_sidebar.html.twig' with {
                        title: 'register.sidebar.title'|trans,
                        intro: 'register.sidebar.intro'|trans,
                        bullets: [
                            'register.sidebar.bullet1'|trans,
                            'register.sidebar.bullet2'|trans,
                            'register.sidebar.bullet3'|trans,
                        ],
                        link_url: path('app_login'),
                        link_text: 'register.sidebar.link'|trans,
                        link_icon: 'sign-in-alt',
                    } only %}
                </div>
            </div>

        </div>
    </section>

{% endblock %}
