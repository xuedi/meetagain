{% extends 'base.html.twig' %}

{% block title %}{{ "security.page_title_register"|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <div class="columns is-centered mt-5">
                <div class="column is-6-tablet is-5-desktop">

                    <h1 class="title is-5">{{ "security.headline_register"|trans }}</h1>

                    {{ form_start(form) }}

                    {% for flash_error in app.flashes('verify_email_error') %}
                        <div class="notification is-danger is-light mb-4" role="alert">{{ flash_error }}</div>
                    {% endfor %}

                    {{ form_errors(form) }}

                    {{ form_row(form.name) }}
                    {{ form_row(form.email) }}
                    {{ form_row(form.plainPassword, {
                        label: 'Password'
                    }) }}
                    {{ form_row(form.agreeTerms) }}

                    <div class="field is-grouped mt-4">
                        <div class="control">
                            <button class="button is-primary">{{ "security.button_register" | trans }}</button>
                            <a class="button is-light" href="/{{ app.request.locale }}/terms" target="_blank" rel="noopener">{{ "security.button_terms" | trans }}</a>
                        </div>
                    </div>
                    {{ form_end(form) }}

                </div>

                <div class="column is-5-tablet is-4-desktop">
                    {% include '_components/info_sidebar.html.twig' with {
                        title: 'security.register_sidebar_title'|trans,
                        intro: 'security.register_sidebar_intro'|trans,
                        bullets: [
                            'security.register_sidebar_bullet1'|trans,
                            'security.register_sidebar_bullet2'|trans,
                            'security.register_sidebar_bullet3'|trans,
                        ],
                        link_url: path('app_login'),
                        link_text: 'security.register_sidebar_link'|trans,
                        link_icon: 'sign-in-alt',
                    } only %}
                </div>
            </div>

        </div>
    </section>

{% endblock %}
