{% extends 'base.html.twig' %}

{% block title %}{{ "security.headline_reset_password"|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <div class="columns is-centered mt-5">
                <div class="column is-6-tablet is-5-desktop">

                    <h1 class="title is-5">{{ "security.headline_reset_password"|trans }}</h1>

                    {{ form_start(form) }}
                    {{ form_widget(form) }}
                    <button class="button is-primary mt-4">{{ 'global.button_save'|trans }}</button>
                    {{ form_end(form) }}

                </div>

                <div class="column is-5-tablet is-4-desktop">
                    {% include '_components/info_sidebar.html.twig' with {
                        title: 'security.reset_password_sidebar_title'|trans,
                        intro: 'security.reset_password_sidebar_intro'|trans,
                        bullets: [
                            'security.reset_password_sidebar_bullet1'|trans,
                            'security.reset_password_sidebar_bullet2'|trans,
                            'security.reset_password_sidebar_bullet3'|trans,
                        ],
                        link_url: path('app_login'),
                        link_text: 'security.reset_password_sidebar_link'|trans,
                        link_icon: 'sign-in-alt',
                    } only %}
                </div>
            </div>

        </div>
    </section>

{% endblock %}
