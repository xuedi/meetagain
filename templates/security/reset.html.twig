{% extends 'base.html.twig' %}

{% block title %}{{ "security.page_title_reset"|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <div class="columns is-centered mt-5">
                <div class="column is-6-tablet is-5-desktop">

                    <h1 class="title is-5">{{ "security.page_title_reset"|trans }}</h1>

                    {{ form_start(form) }}

                    {{ form_row(form.email) }}

                    <div class="field">
                        <label class="label">{{ 'security.label_captcha'|trans }}</label>
                        <div class="is-flex is-align-items-center" style="gap: 0.75rem;">
                            <img src="data:image/png;base64, {{ captcha }}" alt="captcha">
                            <div class="control is-flex-grow-1">
                                {{ form_widget(form.captcha) }}
                            </div>
                        </div>
                    </div>

                    {{ form_widget(form) }}

                    <p class="is-size-7 has-text-grey mt-2">{{ 'security.captcha_limit_text'|trans }}</p>
                    <div data-captcha-counter data-url="{{ path('app_ajax_get_captcha_count') }}">
                        <p class="mb-4 is-size-7 has-text-grey">
                            {{ 'security.captcha_tries_pre'|trans }} <strong id="refreshCount">{{ refreshCount }}</strong> {{ 'security.captcha_tries_mid'|trans }} <strong id="refreshTime">{{ refreshTime }}</strong> {{ 'security.captcha_tries_post'|trans }}
                        </p>
                    </div>

                    <button class="button is-primary">{{ "security.button_send_reset_link" | trans }}</button>
                    {{ form_end(form) }}

                </div>

                <div class="column is-5-tablet is-4-desktop">
                    {% include '_components/info_sidebar.html.twig' with {
                        title: 'security.reset_sidebar_title'|trans,
                        intro: 'security.reset_sidebar_intro'|trans,
                        bullets: [
                            'security.reset_sidebar_bullet1'|trans,
                            'security.reset_sidebar_bullet2'|trans,
                            'security.reset_sidebar_bullet3'|trans,
                        ],
                        link_url: path('app_login'),
                        link_text: 'security.reset_sidebar_link'|trans,
                        link_icon: 'arrow-left',
                    } only %}
                </div>
            </div>

        </div>
    </section>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/captcha-counter.js') }}" defer></script>
{% endblock %}
