{% extends 'base.html.twig' %}

{% block title %}{{ "page_reset_headline"|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <div class="columns is-centered mt-5">
                <div class="column is-6-tablet is-5-desktop">

                    <h1 class="title is-5">{{ "page_reset_headline"|trans }}</h1>

                    {{ form_start(form) }}

                    {{ form_row(form.email) }}

                    <div class="field">
                        <label class="label">Captcha</label>
                        <img src="data:image/png;base64, {{ captcha }}" alt="captcha" class="mb-2">
                        <div class="control">
                            {{ form_widget(form.captcha) }}
                        </div>
                    </div>

                    {{ form_widget(form) }}

                    <p class="is-size-7 has-text-grey mt-2">{{ 'captcha.limit_text'|trans }}</p>
                    <div data-captcha-counter data-url="{{ path('app_ajax_get_captcha_count') }}">
                        <p class="mb-4 is-size-7 has-text-grey">
                            {{ 'captcha.tries_pre'|trans }} <strong id="refreshCount">{{ refreshCount }}</strong> {{ 'captcha.tries_mid'|trans }} <strong id="refreshTime">{{ refreshTime }}</strong> {{ 'captcha.tries_post'|trans }}
                        </p>
                    </div>

                    <button class="button is-primary">{{ "button_send_reset_link" | trans }}</button>
                    {{ form_end(form) }}

                </div>

                <div class="column is-5-tablet is-4-desktop">
                    {% include '_components/info_sidebar.html.twig' with {
                        title: 'reset.sidebar.title'|trans,
                        intro: 'reset.sidebar.intro'|trans,
                        bullets: [
                            'reset.sidebar.bullet1'|trans,
                            'reset.sidebar.bullet2'|trans,
                            'reset.sidebar.bullet3'|trans,
                        ],
                        link_url: path('app_login'),
                        link_text: 'reset.sidebar.link'|trans,
                        link_icon: 'arrow-left',
                    } only %}
                </div>
            </div>

        </div>
    </section>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/captcha-counter.js') }}" defer></script>
{% endblock %}
