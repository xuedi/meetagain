{% extends 'base.html.twig' %}

{% block title %}{{ "security.page_title_login"|trans }}{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">

            <div class="columns is-centered mt-5">
                <div class="column is-6-tablet is-5-desktop">

                    <h1 class="title is-5">{{ "security.headline_login"|trans }}</h1>

                    <form method="post">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                        <input type="hidden" name="_target_path" value="{{ redirectPath }}"/>
                        {% if error %}
                            <div class="notification is-danger is-light mb-4">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                        {% endif %}

                        <div class="field">
                            <label class="label">{{ 'email' | trans }}</label>
                            <p class="control has-icons-left">
                                <input type="email" name="_username" id="username" class="input" autocomplete="email" placeholder="{{ 'email' | trans }}">
                                <span class="icon is-small is-left"><i class="fas fa-envelope"></i></span>
                            </p>
                        </div>

                        <div class="field">
                            <label class="label">{{ 'password' | trans }}</label>
                            <p class="control has-icons-left">
                                <input type="password" name="_password" id="password" class="input" placeholder="{{ 'password' | trans }}">
                                <span class="icon is-small is-left"><i class="fas fa-lock"></i></span>
                            </p>
                        </div>

                        <div class="field is-grouped mt-5">
                            <div class="control">
                                <button type="submit" class="button is-primary">{{ 'chrome.menu_login'|trans }}</button>
                                <a href="{{ path('app_register') }}" class="button is-light">{{ 'security.button_register'|trans }}</a>
                            </div>
                        </div>
                    </form>

                    <p class="mt-4 is-size-7">
                        {{ "security.intro_reset_link"|trans }} <a href="{{ path('app_reset') }}">{{ 'security.link_here' | trans }}</a>
                    </p>

                </div>

                <div class="column is-5-tablet is-4-desktop">
                    {% include '_components/info_sidebar.html.twig' with {
                        title: 'security.login_sidebar_title'|trans,
                        intro: 'security.login_sidebar_intro'|trans,
                        bullets: [
                            'security.login_sidebar_bullet1'|trans,
                            'security.login_sidebar_bullet2'|trans,
                            'security.login_sidebar_bullet3'|trans,
                        ],
                        link_url: path('app_register'),
                        link_text: 'security.login_sidebar_link'|trans,
                        link_icon: 'arrow-right',
                    } only %}
                </div>
            </div>

        </div>
    </section>

{% endblock %}
