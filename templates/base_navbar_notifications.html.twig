{% set notifications = get_notifications() %}
<div class="navbar-item pr-0 dropdown is-hoverable is-right">
    <div class="dropdown-trigger">
        <a class="button {% if notifications.totalCount > 0 %}is-danger{% else %}is-light{% endif %}" href="{{ path('app_profile_notifications') }}">
            <span class="icon is-small">
                <i class="fas fa-bell" aria-hidden="true"></i>
            </span>
        </a>
    </div>
    {% if notifications.totalCount > 0 %}
    <div class="dropdown-menu notifications-dropdown" role="menu">
        <div class="dropdown-content">
            {% for item in notifications.items %}
                {% if item.route and route_exists(item.route) %}
                    <a href="{{ path(item.route, item.routeParams) }}" class="dropdown-item">
                        <span class="icon is-small"><i class="fa {{ item.icon }}"></i></span>
                        <span>{{ item.label|raw }}</span>
                    </a>
                {% else %}
                    <div class="dropdown-item">
                        <span class="icon is-small"><i class="fa {{ item.icon }}"></i></span>
                        <span>{{ item.label|raw }}</span>
                    </div>
                {% endif %}
            {% endfor %}
            <hr class="dropdown-divider">
            <a href="{{ path('app_profile_notifications') }}" class="dropdown-item has-text-centered">
                {{ 'chrome.notifications_view_all'|trans }}
            </a>
        </div>
    </div>
    {% endif %}
</div>
