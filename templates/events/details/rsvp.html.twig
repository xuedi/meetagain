<nav class="level">
    <div class="level-left">
        <div class="level-item">
            <h2 class="title is-4">RSVP</h2>
        </div>
    </div>
    <div class="level-right">
        {% if event.canceled %}
            <span class="tag is-danger is-light">{{ "events.tag_event_canceled"|trans }}</span>
        {% elseif is_granted('ROLE_USER') %}
            <form method="post" action="{{ path('app_event_toggle_rsvp', {'event': event.id}) }}" class="is-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('app_event_toggle_rsvp' ~ event.id) }}">
                {% if event.rsvp.contains(app.user) %}
                    <button type="submit" class="button is-danger is-small ml-4">
                        <span class="icon"><i class="fa fa-minus"></i></span><span>{{ 'events.button_rsvp_remove'|trans }}</span>
                    </button>
                {% else %}
                    <button type="submit" class="button is-success is-small ml-4">
                        <span class="icon"><i class="fa fa-plus"></i></span><span>{{ 'events.button_rsvp_add'|trans }}</span>
                    </button>
                {% endif %}
            </form>
        {% endif %}
    </div>
</nav>
<div class="columns is-multiline mt-2">
    {% for rsvp in event.rsvp %}
        <div class="column is-2">
            {% include '_components/usercard.html.twig' with {'user': rsvp} %}
        </div>
    {% endfor %}
</div>