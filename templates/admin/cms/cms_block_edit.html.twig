{% extends 'admin/base.html.twig' %}

{% set caps = block.type.capabilities %}
{% set supportsImage = caps.supportsImage() %}
{% set hasImageRight = caps.supportsImageRight %}
{% set imageOnRight = hasImageRight and blockObject.imageRight %}

{% block content %}

    {% set blockDeleteFormHtml %}
        <p>{{ 'admin_cms.block_delete_warning' | trans }}</p>
        <div class="has-text-right mt-3">
            <form method="post" action="{{ path('app_admin_cms_block_delete') }}" class="is-inline">
                <input type="hidden" name="blockId" value="{{ block.id }}">
                <input type="hidden" name="id" value="{{ cms.id }}">
                <input type="hidden" name="locale" value="{{ block.language }}">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_cms_block_delete' ~ block.id) }}">
                <button type="submit" class="button is-danger">
                    <span class="icon"><i class="fa fa-trash"></i></span>
                    <span>{{ 'global.button_delete' | trans }}</span>
                </button>
            </form>
        </div>
    {% endset %}
    {% include '_components/warning_box.html.twig' with {
        'id': 'cms-block-delete-warning',
        'title': 'admin_cms.block_delete_title' | trans,
        'content': blockDeleteFormHtml,
        'type': 'danger'
    } %}

    {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

    {% set removeImageUrl = blockImage is not null
        ? path('app_admin_cms_block_image_remove', {'blockId': block.id})
        : null %}
    {% set toggleSideUrl = hasImageRight
        ? path('app_admin_cms_block_image_toggle_side', {'blockId': block.id})
        : null %}

    {% set form %}
        <div class="box">
            <form id="cms-block-form" method="post" action="{{ path('app_admin_cms_edit_block_save') }}">
                <input type="hidden" name="blockId" value="{{ block.id }}"/>
                <input type="hidden" name="blockType" value="{{ block.type.value }}"/>

                {% include 'cms/blocks/_edit/' ~ block.type.name ~ '.html.twig' with {
                    'block': blockObject,
                    'blockId': block.id,
                    'blockImage': blockImage,
                    'editBlock': block.id,
                    'cmsId': cms.id,
                } only %}

                <div class="buttons mt-4">
                    <button class="button is-primary">{{ 'global.button_save'|trans }}</button>
                    <a class="button" href="{{ path('app_admin_cms_block_edit', {'blockId': block.id}) }}">
                        {{ 'global.button_discard'|trans }}
                    </a>
                    <button type="button" class="button is-danger toggleTrigger" data-id="cms-block-delete-warning">
                        <span class="icon"><i class="fa fa-trash"></i></span>
                    </button>
                </div>
            </form>
        </div>
    {% endset %}

    {% if supportsImage %}
        {% set imageColumn %}
            <div class="is-relative">
                {% include '_components/image_upload.html.twig' with {
                    'entity': 'cmsBlock',
                    'id': block.id,
                    'image': blockImage,
                    'removeImageUrl': removeImageUrl,
                    'removeImageCsrfToken': 'admin_cms_block_image_remove' ~ block.id,
                    'showWhenEmpty': true,
                } %}
                {% if toggleSideUrl %}
                    <form method="post" action="{{ toggleSideUrl }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('app_admin_cms_block_image_toggle_side' ~ block.id) }}">
                        <button type="submit" class="button is-small is-fullwidth mt-2">
                            {% if imageOnRight %}
                                <span class="icon"><i class="fa fa-arrow-left"></i></span>
                                <span>{{ 'admin_cms.button_move_left' | trans }}</span>
                            {% else %}
                                <span class="icon"><i class="fa fa-arrow-right"></i></span>
                                <span>{{ 'admin_cms.button_move_right' | trans }}</span>
                            {% endif %}
                        </button>
                    </form>
                {% endif %}
                {% if blockImage is null %}
                    <p class="help has-text-grey mt-2">{{ 'admin_cms.no_image_help' | trans }}</p>
                {% endif %}
                <div id="cms-image-overlay" style="display:none; position:absolute; inset:0;
                     background:rgba(0,0,0,0.75); z-index:10; border-radius:4px;
                     flex-direction:column; align-items:center; justify-content:center; gap:.5rem;">
                    <span class="icon has-text-warning is-large"><i class="fa fa-2x fa-save"></i></span>
                    <p class="has-text-weight-semibold has-text-centered has-text-white">{{ 'admin_cms.save_changes_first' | trans }}</p>
                </div>
            </div>
        {% endset %}

        <div class="columns">
            {% if not imageOnRight %}
                <div class="column is-one-quarter">{{ imageColumn }}</div>
            {% endif %}
            <div class="column">{{ form }}</div>
            {% if imageOnRight %}
                <div class="column is-one-quarter">{{ imageColumn }}</div>
            {% endif %}
        </div>
    {% else %}
        {{ form }}
    {% endif %}

{% endblock %}

{% block javascripts %}
    {% if supportsImage %}
    <script src="{{ asset('js/admin/cms-block-edit.js') }}" defer></script>
    {% endif %}
    {% if block.type.name == 'FactsRow' %}
    <script src="{{ asset('js/admin/cms-facts-row-editor.js') }}" defer></script>
    {% endif %}
    {% if block.type.name == 'Text' %}
    <script src="{{ asset('js/vendor/quill.min.js') }}"></script>
    <script src="{{ asset('js/admin/quill-editor.js') }}" defer></script>
    {% endif %}
{% endblock %}
