{% extends 'admin/base.html.twig' %}

{% block content %}

    {% include '_components/warning_box.html.twig' with {
        'id': 'cms-delete-warning',
        'title': 'Delete the Page',
        'content': '<p>If you delete this page, all of its connected blocks and images and so on will be also removed. Also, all language variation! Please consider to set this Page just offline.</p>',
        'buttonLabel': 'Yes, Delete',
        'buttonUrl': path('app_admin_cms_delete', {'id': cms.id}),
        'type': 'danger'
    } %}

    <div class="box">
        {{ form_start(form) }}
        <div class="columns is-vcentered">
            <div class="column is-2">
                {{ form_row(form.slug) }}
            </div>
            <div class="column is-2">
                {{ form_row(form.published) }}
            </div>
            <div class="column is-2">
                <div class="buttons has-addons">
                    {% for locale in get_admin_language_codes() %}
                        {% set link = path('app_admin_cms_edit', {'id': cms.id, 'locale': locale}) %}
                        <a class="button {% if locale == editLocale %}is-active{% endif %}" href="{{ link }}">{{ locale }}</a>
                    {% endfor %}
                </div>
            </div>
            <div class="column">
                <div class="buttons is-right">
                    <button class="button">{{ "button_save" | trans }}</button>
                    <a class="button is-danger toggleTrigger" data-id="cms-delete-warning"
                       href="{{ path('app_admin_cms_delete', {'id': cms.id}) }}">
                        <span class="icon"><i class="fa fa-trash"></i></span>
                    </a>
                    {% if linkedAnnouncement %}
                        <a class="button is-info" href="{{ path('app_admin_email_announcements_view', {'id': linkedAnnouncement.id}) }}">
                            <span class="icon"><i class="fa fa-bullhorn"></i></span>
                            <span>open</span>
                        </a>
                    {% else %}
                        <a class="button is-info" href="{{ path('app_admin_email_announcements_from_cms', {'id': cms.id}) }}">
                            <span class="icon"><i class="fa fa-bullhorn"></i></span>
                            <span>Create</span>
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="columns">
            <div class="column is-6">
                {{ form_row(form.pageTitle) }}
            </div>
            <div class="column is-6">
                {{ form_row(form.linkName) }}
            </div>
        </div>
        <div class="field">
            <div class="control">
                <div class="field is-grouped">
                    {% for choice in form.menuLocations %}
                        <div class="control">
                            <label class="checkbox">
                                {{ form_widget(choice) }}
                                {{ form_label(choice) }}
                            </label>
                        </div>
                    {% endfor %}
                </div>
            </div>
            {{ form_help(form.menuLocations) }}
            {{ form_errors(form.menuLocations) }}
        </div>
        {{ form_end(form) }}
    </div>


    <div class="container">
        {% for block in blocks %}
            {% set moveDownLink = path('app_admin_cms_edit_block_down', {'id': cms.id, 'blockId': block.id, 'locale': editLocale}) %}
            {% set moveUpLink = path('app_admin_cms_edit_block_up', {'id': cms.id, 'blockId': block.id, 'locale': editLocale}) %}
            {% set editBlockLink = path('app_admin_cms_block_edit', {'blockId': block.id}) %}
            <div class="mb-4" style="position: relative;">
                <div class="float-box-menu">
                    <a href="{{ moveDownLink }}"><span class="icon"><i class="fa fa-angle-down"></i></span></a>
                    <a href="{{ moveUpLink }}"><span class="icon"><i class="fa fa-angle-up"></i></span></a>
                    <a href="{{ editBlockLink }}"><span class="icon"><i class="fa fa-edit"></i></span></a>
                </div>
                {% include 'cms/blocks/_preview/' ~ block.type.name ~ '.html.twig' with {
                    'block': block.blockObject,
                    'blockImage': block.image,
                } %}
            </div>
        {% endfor %}
    </div>

    <div class="container mt-6">
        {% include 'admin/cms/newBlocks.html.twig' %}
    </div>

{% endblock %}
