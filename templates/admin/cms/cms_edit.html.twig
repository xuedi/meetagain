{% extends 'admin/base.html.twig' %}

{% block content %}

    {% set deleteFormHtml %}
        <p>If you delete this page, all of its connected blocks and images and so on will be also removed. Also, all language variation! Please consider to set this Page just offline.</p>
        <div class="has-text-right mt-3">
            <form method="post" action="{{ path('app_admin_cms_delete') }}" class="is-inline">
                <input type="hidden" name="id" value="{{ cms.id }}">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_cms_delete' ~ cms.id) }}">
                <button type="submit" class="button">
                    <span class="icon"><i class="fa fa-trash"></i></span>
                    <span>Yes, Delete</span>
                </button>
            </form>
        </div>
    {% endset %}
    {% include '_components/warning_box.html.twig' with {
        'id': 'cms-delete-warning',
        'title': 'Delete the Page',
        'content': deleteFormHtml,
        'type': 'danger'
    } %}

    <div class="container">
        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}
    </div>

    <div class="box">
        {{ form_start(form) }}
        <div class="columns is-vcentered">
            <div class="column is-2">
                {{ form_row(form.slug) }}
            </div>
            <div class="column is-2">
                {{ form_row(form.published) }}
            </div>
            <div class="column is-2">
                <div class="buttons has-addons">
                    {% for locale in get_admin_language_codes() %}
                        {% set link = path('app_admin_cms_edit', {'id': cms.id, 'locale': locale}) %}
                        <a class="button {% if locale == editLocale %}is-active{% endif %}" href="{{ link }}">{{ locale }}</a>
                    {% endfor %}
                </div>
            </div>
            <div class="column">
                <div class="buttons is-right">
                    <button class="button">{{ 'global.button_save'|trans }}</button>
                    <button type="button" class="button is-danger toggleTrigger" data-id="cms-delete-warning">
                        <span class="icon"><i class="fa fa-trash"></i></span>
                    </button>
                </div>
            </div>
        </div>
        <div class="columns">
            <div class="column is-6">
                {{ form_row(form.pageTitle) }}
            </div>
            <div class="column is-6">
                {{ form_row(form.linkName) }}
            </div>
        </div>
        <div class="field">
            <div class="control">
                <div class="field is-grouped">
                    {% for choice in form.menuLocations %}
                        <div class="control">
                            <label class="checkbox">
                                {{ form_widget(choice) }}
                                {{ form_label(choice) }}
                            </label>
                        </div>
                    {% endfor %}
                </div>
            </div>
            {{ form_help(form.menuLocations) }}
            {{ form_errors(form.menuLocations) }}
        </div>
        {{ form_end(form) }}
    </div>


    <div class="container">
        {% for block in blocks %}
            {% set editBlockLink = path('app_admin_cms_block_edit', {'blockId': block.id}) %}
            <div class="mb-4 is-relative cms-block-preview">
                <div class="float-box-menu">
                    <form method="post" action="{{ path('app_admin_cms_edit_block_down') }}" class="is-inline">
                        <input type="hidden" name="id" value="{{ cms.id }}">
                        <input type="hidden" name="blockId" value="{{ block.id }}">
                        <input type="hidden" name="locale" value="{{ editLocale }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('app_admin_cms_edit_block_down' ~ block.id) }}">
                        <button type="submit" class="button-as-icon"><span class="icon"><i class="fa fa-angle-down"></i></span></button>
                    </form>
                    <form method="post" action="{{ path('app_admin_cms_edit_block_up') }}" class="is-inline">
                        <input type="hidden" name="id" value="{{ cms.id }}">
                        <input type="hidden" name="blockId" value="{{ block.id }}">
                        <input type="hidden" name="locale" value="{{ editLocale }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('app_admin_cms_edit_block_up' ~ block.id) }}">
                        <button type="submit" class="button-as-icon"><span class="icon"><i class="fa fa-angle-up"></i></span></button>
                    </form>
                    <a href="{{ editBlockLink }}"><span class="icon"><i class="fa fa-edit"></i></span></a>
                </div>
                {% include 'cms/blocks/_preview/' ~ block.type.name ~ '.html.twig' with {
                    'block': block.blockObject,
                    'blockImage': block.image,
                } %}
            </div>
        {% endfor %}
    </div>

    <div class="container mt-6">
        {% include 'admin/cms/newBlocks.html.twig' %}
    </div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/admin/cms-facts-row-editor.js') }}" defer></script>
{% endblock %}
