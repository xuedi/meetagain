{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">
        <article class="message is-success is-hidden" id="cms-add">
            {{ form_start(form) }}
            <div class="message-header">
                <p>Add new cms page</p>
                <button class="delete toggleTrigger" data-id="cms-add" aria-label="delete"></button>
            </div>
            <div class="message-body">
                <p>
                    Please enter the URL slug for the new page. You can add content blocks in the next step.
                </p>
                <p>
                    {{ form_row(form.slug) }}
                </p>
                <div class="has-text-right">
                    <button class="button">{{ "button_add" | trans }}</button>
                </div>
            </div>
            {{ form_end(form, {'render_rest': false}) }}
        </article>

        {% if cms|length == 0 %}
            <p class="has-text-grey-light">No pages created yet. Click the + icon to create your first page!</p>
        {% endif %}

        <table id="filteredTable" class="table is-fullwidth">
            <thead>
            <tr>
                <th>Slug</th>
                <th>CreatedBy</th>
                <th>CreatedAt</th>
                <th>Status</th>
                <th></th>
                <th>Blocks</th>
                <th>Translations</th>
                <th><a class="toggleTrigger" data-id="cms-add" href="#"><span class="icon"><i class="fa fa-plus"></i></span></a></th>
            </tr>
            </thead>
            <tbody>
            {% for page in cms %}
                <tr>
                    <td>{{ page.slug }}</td>
                    <td>{{ page.createdBy.name }}</td>
                    <td>{{ page.createdAt|date('Y-m-d') }}</td>
                    <td>
                        {% if page.published %}
                            <span class="has-text-success">{{ 'published' | trans }}</span>
                        {% else %}
                            <span class="has-text-grey-light">{{ 'draft' | trans }}</span>
                        {% endif %}
                    </td>
                    <td>
                        <span class="icon-text">
                            {% if page.slug == 'index' %}
                                <span class="icon has-text-grey-light" title="{{ 'Home page' | trans }}">
                                    <i class="fa fa-home"></i>
                                </span>
                            {% endif %}
                            {% if page.locked %}
                                <span class="icon has-text-grey-light" title="{{ 'Locked (visible on all groups)' | trans }}">
                                    <i class="fa fa-lock"></i>
                                </span>
                            {% endif %}
                            {% if page.id in cms_with_announcements %}
                                <span class="icon has-text-grey-light" title="{{ 'Has linked announcement' | trans }}">
                                    <i class="fa fa-bullhorn"></i>
                                </span>
                            {% endif %}
                        </span>
                    </td>
                    <td>{{ page.blocks|length }}</td>
                    <td>{{ page.languages|length }}</td>
                    <td>
                        {% if not (page.locked and not is_admin) %}
                            <a href="{{ path('app_admin_cms_edit', {'id': page.id, 'locale': app.request.locale}) }}"><span class="icon"><i class="fa fa-edit"></i></span></a>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="mt-4 has-text-centered">
            <span class="icon-text">
                <span class="icon has-text-grey-light"><i class="fas fa-home"></i></span>
                <span class="has-text-grey-light">Home page</span>
            </span>
            <span class="icon-text ml-4">
                <span class="icon has-text-grey-light"><i class="fas fa-lock"></i></span>
                <span class="has-text-grey-light">Locked (visible on all groups)</span>
            </span>
            <span class="icon-text ml-4">
                <span class="icon has-text-grey-light"><i class="fas fa-bullhorn"></i></span>
                <span class="has-text-grey-light">Has linked announcement</span>
            </span>
        </div>

    </div>

{% endblock %}
