{% for newBlock in newBlocks %}
    <a class="toggleTrigger" data-id="new-block-{{ newBlock.name }}" href="#">
        <button class="button">
            <span class="icon"><i class="fa fa-plus"></i></span>
            <span>{{ ("admin_cms.block_" ~ newBlock.name) | lower | trans }}</span>
        </button>
    </a>
{% endfor %}

<br>
<br>


{% for newBlock in newBlocks %}
    <article class="message is-success is-hidden" id="new-block-{{ newBlock.name }}">
        <form method="post" action="{{ path('app_admin_cms_add_block', {'id': cms.id}) }}">
        <input type="hidden" name="editLocale" value="{{ editLocale }}"/>
        <input type="hidden" name="blockType" value="{{ newBlock.value }}"/>
        <div class="message-header">
            <p>{{ 'admin_cms.add_new_block' | trans({'%type%': ("admin_cms.block_" ~ newBlock.name) | lower | trans}) }}</p>
            <button class="delete toggleTrigger" data-id="new-block-{{ newBlock.name }}" aria-label="delete"></button>
        </div>
        <div class="message-body">
            <p>
                {% include 'cms/blocks/_edit/' ~ newBlock.name ~ '.html.twig' %}
            </p>
            <div class="has-text-right">
                <button class="button">{{ 'global.add'|trans }}</button>
            </div>
        </div>
        </form>
    </article>
{% endfor %}
