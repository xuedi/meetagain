{% extends 'admin/base.html.twig' %}

{% block content %}
<div class="container">

    <div class="level mb-4">
        <div class="level-left">
            <h1 class="title is-4">SEO — Sitemap Preview</h1>
        </div>
        <div class="level-right">
            <a class="button is-info is-light" href="https://search.google.com/search-console/sitemaps" target="_blank" rel="noopener">
                Google Search Console ↗
            </a>
        </div>
    </div>

    <div class="notification is-info is-light mb-4">
        <strong>{{ total }}</strong> URLs across 3 sections will be included in the sitemap.
        Each URL is expanded to all enabled locales in the sitemap XML.
    </div>

    {% set warnings_total = urls|filter(u => u.warnings|length > 0)|length %}
    {% if warnings_total > 0 %}
    <div class="notification is-warning is-light mb-4">
        <strong>{{ warnings_total }}</strong> URL(s) have warnings — check the table below.
    </div>
    {% endif %}

    <table id="filteredTable" class="table is-fullwidth is-striped is-hoverable">
        <thead>
            <tr>
                <th>Section</th>
                <th>Label</th>
                <th>URL</th>
                <th>Locales</th>
                <th>Last Mod</th>
                <th>Warnings</th>
            </tr>
        </thead>
        <tbody>
        {% for entry in urls %}
            <tr{% if entry.warnings|length > 0 %} class="has-background-warning-light"{% endif %}>
                <td><span class="tag is-light">{{ entry.section }}</span></td>
                <td>{{ entry.label }}</td>
                <td>
                    <a href="{{ entry.url }}" target="_blank" rel="noopener" class="is-size-7 has-text-grey">
                        {{ entry.url }}
                    </a>
                </td>
                <td>{{ entry.locales }}</td>
                <td>{{ entry.lastmod }}</td>
                <td>
                    {% for warning in entry.warnings %}
                        <span class="tag is-warning is-light">{{ warning }}</span>
                    {% endfor %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
