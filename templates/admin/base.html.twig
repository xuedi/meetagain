{% extends 'base.html.twig' %}

{% block title %}{{ 'admin_shell.page_title'|trans }}{% endblock %}


{% block body %}

    <header class="admin-shell-topbar is-hidden-tablet">
        <button id="adminBurger"
                class="admin-shell-burger"
                type="button"
                aria-label="{{ 'admin_shell.menu_toggle'|trans }}"
                aria-controls="adminDrawer"
                aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <span class="admin-shell-title">{{ 'admin_shell.page_title'|trans }}</span>
    </header>

    <div id="adminBackdrop" class="admin-shell-backdrop" aria-hidden="true"></div>

    <section class="section">
        <div class="container">
            <div class="columns">
                <div id="adminDrawer"
                     class="column is-2 admin-shell-drawer"
                     aria-hidden="true">
                    {% include 'admin/base_navbar.html.twig' %}
                </div>
                <div class="column is-10">
                    {% block content %}{% endblock %}
                </div>
            </div>
        </div>
    </section>

    <script src="{{ asset('js/vendor/jstable.min.js') }}"></script>
    <script src="{{ asset('js/vendor/flatpickr.min.js') }}"></script>
    {% if app.request.locale != 'en' %}
    <script src="{{ asset('js/vendor/flatpickr-l10n/' ~ app.request.locale ~ '.js') }}"></script>
    {% endif %}
    <script src="{{ asset('js/admin/base.js') }}"
            data-date-format="{{ get_date_format_flatpickr() }}"
            data-locale="{{ app.request.locale }}"
            defer></script>
    <script src="{{ asset('js/admin/dropdowns.js') }}" defer></script>
    <script src="{{ asset('js/admin/sections.js') }}" defer></script>
    <script src="{{ asset('js/admin/sidebar.js') }}" defer></script>

{% endblock %}
