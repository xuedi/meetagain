<aside class="menu">
    {% for section in admin_navigation.sidebarSections %}
        <p class="menu-label">{{ section.section }}</p>
        <ul class="menu-list">
            {% for link in section.links %}
                <li><a class="{% if active == link.active %}is-active{% endif %}" href="{{ path(link.route) }}">{{ link.label | trans }}</a></li>
            {% endfor %}
        </ul>
    {% endfor %}
</aside>
