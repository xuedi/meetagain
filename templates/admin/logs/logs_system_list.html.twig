{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/logs/_tabs_navigation.html.twig' with {'activeSection': 'logs'} %}

        <table id="filteredTable" class="table is-fullwidth">
            <thead>
            <tr>
                <th>{{ 'admin_logs.col_created_at'|trans }}</th>
                <th>{{ 'admin_logs.col_type'|trans }}</th>
                <th>{{ 'admin_logs.col_level'|trans }}</th>
                <th>{{ 'admin_logs.col_message'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for log in logs %}
                <tr>
                    <td>{{ log.date | date('Y-m-d  H:i') }}</td>
                    <td>{{ log.type }}</td>
                    <td>{{ log.level }}</td>
                    <td>{{ log.message }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </div>

{% endblock %}
