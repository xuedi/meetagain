{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/_components/admin_tabs.html.twig' with {'adminTabs': adminTabs} only %}
        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

        <table id="filteredTable" class="table is-fullwidth">
            <thead>
            <tr>
                <th colspan="2">{{ 'admin_logs.col_created_at'|trans }}</th>
                <th>{{ 'admin_logs.col_user'|trans }}</th>
                <th>{{ 'admin_logs.col_message'|trans }}</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            {% for activity in activities %}
                <tr>
                    <td>{{ activity.createdAt | date('Y-m-d') }}</td>
                    <td>{{ activity.createdAt | date('H:i') }}</td>
                    <td>
                        {{ activity.user.email }}
                        {% if activity.user and activity.user.id != userFilterId %}
                            {% set filterParams = currentRange != defaultRange ? {'range': currentRange, 'user': activity.user.id} : {'user': activity.user.id} %}
                            <a href="{{ path('app_admin_activity_log', filterParams) }}"
                               class="ml-1 has-text-grey"
                               title="{{ 'admin_logs.filter_by_user'|trans }}">
                                <span class="icon is-small"><i class="fa fa-filter"></i></span>
                            </a>
                        {% endif %}
                    </td>
                    <td>{{ activity.message }}</td>
                    <td>
                        <a href="{{ path('app_admin_activity_log_show', {'id': activity.id}) }}">
                            <span class="icon"><i class="fa fa-eye"></i></span>
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </div>

{% endblock %}

