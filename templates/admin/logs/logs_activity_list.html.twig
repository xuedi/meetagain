{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/logs/_tabs_navigation.html.twig' with {'activeSection': 'logs'} %}

        <table id="filteredTable" class="table is-fullwidth">
            <thead>
            <tr>
                <th colspan="2">CreatedAt</th>
                <th>User</th>
                <th>Type</th>
                <th>Message</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            {% for activity in activities %}
                <tr>
                    <td>{{ activity.createdAt | date('Y-m-d') }}</td>
                    <td>{{ activity.createdAt | date('H:i') }}</td>
                    <td>{{ activity.user.email }}</td>
                    <td>{{ activity.type.name }}</td>
                    <td>{{ activity.message }}</td>
                    <td>
                        <a href="{{ path('app_admin_activity_log_show', {'id': activity.id}) }}">
                            <span class="icon"><i class="fa fa-eye"></i></span>
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </div>

{% endblock %}

