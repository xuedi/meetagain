{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/_components/admin_tabs.html.twig' with {'adminTabs': adminTabs} only %}
        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

        <table class="table is-fullwidth">
            <thead>
            <tr>
                <th>{{ 'admin_logs.col_task'|trans }}</th>
                <th>{{ 'admin_logs.col_status'|trans }}</th>
                <th>{{ 'admin_logs.col_duration'|trans }}</th>
                <th>{{ 'admin_logs.col_message'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for task in log.tasks %}
                <tr>
                    <td><code>{{ task.identifier }}</code></td>
                    <td>
                        {% if task.status == 'ok' %}
                            <span class="tag is-success">{{ 'admin_logs.status_ok'|trans }}</span>
                        {% elseif task.status == 'warning' %}
                            <span class="tag is-warning">{{ 'admin_logs.status_warning'|trans }}</span>
                        {% elseif task.status == 'error' %}
                            <span class="tag is-danger">{{ 'admin_logs.status_error'|trans }}</span>
                        {% else %}
                            <span class="tag is-danger is-dark">{{ 'admin_logs.status_exception'|trans }}</span>
                        {% endif %}
                    </td>
                    <td class="has-text-grey">{{ task.duration_ms }} ms</td>
                    <td>{{ task.message }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </div>

{% endblock %}
