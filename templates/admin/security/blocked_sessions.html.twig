{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/_components/admin_tabs.html.twig' with {'adminTabs': adminTabs} only %}
        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

        <table class="table is-fullwidth">
            <thead>
                <tr>
                    <th>{{ 'admin_security.col_type'|trans }}</th>
                    <th>{{ 'admin_security.col_key'|trans }}</th>
                    <th>{{ 'admin_security.col_triggered_by'|trans }}</th>
                    <th>{{ 'admin_security.col_threat'|trans }}</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for entry in entries %}
                    <tr>
                        <td>
                            <span class="tag">{{ ('admin_security.type_' ~ entry.type)|trans }}</span>
                        </td>
                        <td>
                            {% if entry.type == 'session' %}
                                <code>{{ entry.key|slice(0, 16) }}{{ entry.key|length > 16 ? '...' : '' }}</code>
                            {% else %}
                                {{ entry.key }}
                            {% endif %}
                        </td>
                        <td>{{ entry.snapshot.primaryProvider ?: '-' }}</td>
                        <td>{{ entry.snapshot.maxThreatLevel ?? '-' }}</td>
                        <td class="has-text-right">
                            {% if entry.snapshot.incidentId is defined and entry.snapshot.incidentId %}
                                <a href="{{ path('app_admin_security_incidents_show', {id: entry.snapshot.incidentId}) }}">
                                    <span class="icon"><i class="fa fa-eye"></i></span>
                                </a>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="has-text-centered has-text-grey">
                            {{ 'admin_security.empty_blocked'|trans }}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

    </div>

{% endblock %}
