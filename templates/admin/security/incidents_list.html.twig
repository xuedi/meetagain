{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/_components/admin_tabs.html.twig' with {'adminTabs': adminTabs} only %}
        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

        <table id="filteredTable" class="table is-fullwidth">
            <thead>
                <tr>
                    <th>{{ 'admin_security.col_ip'|trans }}</th>
                    <th>{{ 'admin_security.col_session_id'|trans }}</th>
                    <th>{{ 'admin_security.col_ended'|trans }}</th>
                    <th>{{ 'admin_security.col_triggered_by'|trans }}</th>
                    <th>{{ 'admin_security.col_blocked'|trans }}</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for incident in incidents %}
                    <tr>
                        <td class="is-nowrap">{{ incident.ip }}</td>
                        <td class="is-nowrap">{{ incident.sessionId|slice(0, 16) }}{{ incident.sessionId|length > 16 ? '...' : '' }}</td>
                        <td class="is-nowrap">{{ incident.endedAt|date('Y-m-d H:i:s') }}</td>
                        <td>{{ ('admin_security.provider_label_' ~ incident.triggeredBy)|trans }}</td>
                        <td>{{ incident.blockedUntilDescription }}</td>
                        <td>
                            <a href="{{ path('app_admin_security_incidents_show', {'id': incident.id}) }}">
                                <span class="icon"><i class="fa fa-eye"></i></span>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="has-text-centered has-text-grey">
                            {{ 'admin_security.empty_incidents'|trans }}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

    </div>

{% endblock %}
