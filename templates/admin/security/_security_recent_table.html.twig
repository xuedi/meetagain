{# Shared recent-events table partial. Caller passes rows + typeKey ('reason' or 'limiter'). #}
<table class="table is-fullwidth">
    <thead>
        <tr>
            <th>{{ 'admin_security.col_time'|trans }}</th>
            <th>{{ 'admin_security.col_ip'|trans }}</th>
            <th>{{ 'admin_security.col_url'|trans }}</th>
            <th>{{ typeColumnLabel|trans }}</th>
        </tr>
    </thead>
    <tbody>
        {% for entry in rows %}
            <tr>
                <td class="is-nowrap">{{ entry.createdAt|date('Y-m-d H:i:s') }}</td>
                <td class="is-nowrap">{{ entry.ip }}</td>
                <td>{{ entry.url|length > 60 ? entry.url|slice(0, 57) ~ '...' : entry.url }}</td>
                <td>
                    {% if typeKey == 'reason' %}
                        <span class="tag is-light">{{ entry.reason }}</span>
                        {% if entry.user %}
                            <span class="has-text-grey">{{ entry.user.name }}</span>
                        {% endif %}
                    {% else %}
                        <span class="tag is-light">{{ entry.limiter }}</span>
                        {% if entry.userIdentifier %}
                            <span class="has-text-grey">{{ entry.userIdentifier }}</span>
                        {% endif %}
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4" class="has-text-centered has-text-grey">
                    {{ emptyLabel|trans }}
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
