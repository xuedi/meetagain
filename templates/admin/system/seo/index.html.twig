{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/_components/admin_tabs.html.twig' with {'adminTabs': adminTabs} only %}
        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

        <div class="columns">
            <div class="column is-6">

                <h1 class="title is-5">{{ 'admin_system_seo.heading_meta'|trans }}</h1>
                <p class="content">{{ 'admin_system_seo.help_meta'|trans }}</p>

                {{ form_start(form) }}
                {{ form_row(form.seoDescriptionDefault) }}
                {{ form_row(form.seoDescriptionEvents) }}
                {{ form_row(form.seoDescriptionMembers) }}
                <button class="button is-primary">{{ 'global.button_save'|trans }}</button>
                {{ form_end(form) }}

            </div>
            <div class="column is-6">

                <h2 class="title is-5">{{ 'admin_system_seo.heading_indexnow'|trans }}</h2>
                <p class="content">{{ 'admin_system_seo.help_indexnow'|trans }}</p>
                {% if indexNowKey %}
                    <p class="is-size-7 has-text-grey">{{ 'admin_system_seo.indexnow_key'|trans }} <code>{{ indexNowKey }}</code></p>
                {% endif %}
                {% if lastSubmittedAt %}
                    <p class="is-size-7 has-text-grey">{{ 'admin_system_seo.indexnow_last_submitted'|trans({'%time%': lastSubmittedAt|ago}) }}</p>
                {% else %}
                    <p class="is-size-7 has-text-grey">{{ 'admin_system_seo.indexnow_never_submitted'|trans }}</p>
                {% endif %}

            </div>
        </div>

    </div>

{% endblock %}
