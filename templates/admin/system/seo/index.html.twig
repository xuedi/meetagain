{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/system/_tabs_navigation.html.twig' with {'activeSection': 'seo'} %}

        <div class="columns">
            <div class="column is-6">

                <h1 class="title is-5">SEO Meta Descriptions</h1>
                <p class="content">
                    These descriptions appear in search engine results. Leave a field empty to use the built-in fallback text.
                    Maximum 160 characters each.
                </p>

                {{ form_start(form) }}
                {{ form_row(form.seoDescriptionDefault) }}
                {{ form_row(form.seoDescriptionEvents) }}
                {{ form_row(form.seoDescriptionMembers) }}
                <button class="button is-link">{{ "button_save" | trans }}</button>
                {{ form_end(form) }}

            </div>
            <div class="column is-6">

                <div class="box">
                    <h2 class="title is-5">IndexNow</h2>
                    <p class="content">
                        Submit all public URLs of this site to search engines via the IndexNow protocol.
                        The key is generated automatically and verified on first submission.
                    </p>
                    {% if indexNowKey %}
                        <p class="is-size-7 has-text-grey">Key: <code>{{ indexNowKey }}</code></p>
                    {% endif %}
                    {% if lastSubmittedAt %}
                        <p class="is-size-7 has-text-grey">Last submitted {{ lastSubmittedAt | ago }}</p>
                    {% else %}
                        <p class="is-size-7 has-text-grey">Never submitted</p>
                    {% endif %}
                    <form method="post" action="{{ path('app_admin_system_seo_indexnow_submit') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('indexnow_submit') }}">
                        <button class="button is-info mt-2">Submit to IndexNow</button>
                    </form>
                </div>

            </div>
        </div>

    </div>

{% endblock %}
