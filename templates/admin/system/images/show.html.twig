{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/system/_tabs_navigation.html.twig' with {'activeSection': 'images'} %}

        <div class="box">
            <div class="level">
                <div class="level-left">
                    <div class="level-item">
                        <span class="tag is-light">{{ image.type.name }}</span>
                    </div>
                    <div class="level-item has-text-grey">
                        {{ image.size | format_bytes }}
                    </div>
                    <div class="level-item has-text-grey">
                        <a href="{{ path('app_admin_member_edit', {'id': image.uploader.id}) }}">
                            {{ image.uploader.email }}
                        </a>
                    </div>
                </div>
                <div class="level-right">
                    <div class="level-item">
                        <a href="{{ path('app_admin_system_images') }}" class="button is-small">
                            <span class="icon is-small"><i class="fa fa-arrow-left"></i></span>
                            <span>{{ 'admin_system.button_back'|trans }}</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <table class="table is-fullwidth">
            <tbody>
                <tr>
                    <th>{{ 'admin_system.label_id'|trans }}</th>
                    <td><code>{{ image.id }}</code></td>
                </tr>
                <tr>
                    <th>{{ 'admin_system.label_hash'|trans }}</th>
                    <td><code>{{ image.hash }}</code></td>
                </tr>
                <tr>
                    <th>{{ 'admin_system.col_type'|trans }}</th>
                    <td><span class="tag is-light">{{ image.type.name }}</span></td>
                </tr>
                <tr>
                    <th>{{ 'admin_system.col_mime_type'|trans }}</th>
                    <td>{{ image.mimeType }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin_system.label_extension'|trans }}</th>
                    <td>{{ image.extension }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin_system.label_file_size'|trans }}</th>
                    <td>{{ image.size | format_bytes }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin_system.col_uploader'|trans }}</th>
                    <td>
                        <a href="{{ path('app_admin_member_edit', {'id': image.uploader.id}) }}">
                            {{ image.uploader.email }}
                        </a>
                    </td>
                </tr>
                <tr>
                    <th>{{ 'admin_system.col_created_at'|trans }}</th>
                    <td>{{ image.createdAt | date('Y-m-d H:i:s') }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin_system.label_updated_at'|trans }}</th>
                    <td>
                        {% if image.updatedAt %}
                            {{ image.updatedAt | date('Y-m-d H:i:s') }}
                        {% else %}
                            <span class="has-text-grey">&mdash;</span>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>{{ 'admin_system.label_reported'|trans }}</th>
                    <td>
                        {% if image.reported %}
                            <span class="tag is-danger is-light">{{ image.reported.name }}</span>
                        {% else %}
                            <span class="has-text-grey">&mdash;</span>
                        {% endif %}
                    </td>
                </tr>
            </tbody>
        </table>

        <h2 class="subtitle mt-5">{{ 'admin_system.heading_preview'|trans }}</h2>
        {% include '_components/image.html.twig' with {'image': image} %}

        <h2 class="subtitle mt-5">{{ 'admin_system.heading_locations'|trans }}</h2>
        {% if locations is empty %}
            <div class="notification is-info is-light">
                {{ 'admin_system.empty_locations'|trans }}
            </div>
        {% else %}
            <table class="table is-fullwidth is-narrow">
                <thead>
                    <tr>
                        <th>{{ 'admin_system.col_type'|trans }}</th>
                        <th>{{ 'admin_system.col_location_id'|trans }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for location in locations %}
                        <tr>
                            <td><span class="tag is-light">{{ location.locationType.name }}</span></td>
                            <td><code>{{ location.locationId }}</code></td>
                            <td>
                                {% set link = editLinks[location.id] ?? null %}
                                {% if link %}
                                    <a href="{{ path(link.route, link.params) }}">
                                        <span class="icon"><i class="fa fa-eye"></i></span>
                                    </a>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}

    </div>

{% endblock %}
