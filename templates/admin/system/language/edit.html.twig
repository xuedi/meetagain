{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/_components/admin_tabs.html.twig' with {'adminTabs': adminTabs} only %}
        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

        {{ form_start(form) }}

        <div class="columns">
            <div class="column is-8">
                {{ form_row(form.code) }}
                {{ form_row(form.name) }}
                {{ form_row(form.enabled) }}
                {{ form_row(form.sortOrder) }}
            </div>
            <div class="column is-4">
                <div class="box">
                    <h4 class="subtitle is-5">{{ 'admin_system_language.heading_tile_image'|trans }}</h4>
                    {% if language.tileImage %}
                        <div class="mb-3">
                            {% include '_components/image.html.twig' with {'image': language.tileImage, 'size': '300x200'} %}
                        </div>
                    {% else %}
                        <div class="mb-3 has-text-grey">
                            <em>{{ 'admin_system_images.no_image_uploaded'|trans }}</em>
                        </div>
                    {% endif %}
                    {{ form_row(form.tileImage) }}
                </div>
            </div>
        </div>

        <button class="button is-primary">{{ 'global.button_save'|trans }}</button>
        {{ form_end(form) }}

    </div>

{% endblock %}
