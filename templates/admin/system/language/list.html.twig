{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/_components/admin_tabs.html.twig' with {'adminTabs': adminTabs} only %}
        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

        <table id="filteredTable" class="table is-fullwidth">
            <thead>
            <tr>
                <th>{{ 'admin_system_language.col_flag'|trans }}</th>
                <th>{{ 'admin_system_language.col_code'|trans }}</th>
                <th>{{ 'admin_system_language.col_name'|trans }}</th>
                <th>{{ 'admin_system_language.col_has_tile'|trans }}</th>
                <th>{{ 'admin_system_language.col_status'|trans }}</th>
                <th>{{ 'admin_system_language.col_sort_order'|trans }}</th>
                <th>
                    <a href="{{ path('app_admin_language_add') }}">
                        <span class="icon"><i class="fa fa-plus"></i></span>
                    </a>
                </th>
            </tr>
            </thead>
            <tbody>
            {% for language in languages %}
                <tr>
                    <td>
                        <img src="{{ asset('images/flags/' ~ language.code ~ '.svg') }}" width="32" height="24" alt="{{ language.code }}"/>
                    </td>
                    <td>{{ language.code }}</td>
                    <td>{{ language.name }}</td>
                    <td>
                        {% if language.tileImage %}
                            <span class="has-text-success">{{ 'global.button_yes'|trans }}</span>
                        {% else %}
                            <span class="has-text-grey">{{ 'global.button_no'|trans }}</span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ path('app_admin_language_toggle', {'id': language.id}) }}"
                           title="{{ language.enabled ? 'admin_system_language.button_disable'|trans : 'admin_system_language.button_enable'|trans }}">
                            {% if language.enabled %}
                                <span class="tag is-success">{{ 'admin_system_language.status_enabled'|trans }}</span>
                            {% else %}
                                <span class="tag">{{ 'admin_system_language.status_disabled'|trans }}</span>
                            {% endif %}
                        </a>
                    </td>
                    <td>{{ language.sortOrder }}</td>
                    <td>
                        <a href="{{ path('app_admin_language_edit', {'id': language.id}) }}">
                            <span class="icon"><i class="fa fa-edit"></i></span>
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </div>

{% endblock %}
