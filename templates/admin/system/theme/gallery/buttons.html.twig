{#
    Gallery: Buttons -- Bulma button colour, size, and icon variants

    The Bulma allowlist for admin keeps `is-primary` for form submit only. Topbar action
    buttons handle their own variants via `AdminTopActionButton` (`is-warning`,
    `is-danger`, no variant); see the AdminTop infobar gallery entry. Row actions inside
    list tables are icon-only `<a>` and never carry the `.button` class.

    Used in:    admin/system/theme/gallery/index.html.twig
    Parameters: none
#}
<p class="is-size-7 has-text-grey">
    {{ 'admin_system_gallery.source_of_truth'|trans }}
    <code>templates/admin/host/edit.html.twig</code>,
    architecture/ux-admin.md ("Bulma allowlist", "Form pages")
</p>

<p class="mt-3 has-text-grey is-size-7">
    {{ 'admin_system_gallery.buttons_topbar_note'|trans }}
</p>

<h3 class="title is-6 mt-5">form submit</h3>
<div class="buttons">
    <button class="button is-primary">{{ 'admin_system_gallery.button_demo_save'|trans }}</button>
    <button class="button is-primary" disabled>{{ 'admin_system_gallery.button_demo_save'|trans }}</button>
    <button class="button is-primary is-loading">{{ 'admin_system_gallery.button_demo_save'|trans }}</button>
</div>

<h3 class="title is-6 mt-5">sizes (default button)</h3>
<div class="buttons">
    <button class="button is-small">small</button>
    <button class="button">normal</button>
    <button class="button is-large">large</button>
</div>

<h3 class="title is-6 mt-5">submit with icon</h3>
<div class="buttons">
    <button class="button is-primary">
        <span class="icon"><i class="fa fa-save"></i></span>
        <span>{{ 'admin_system_gallery.button_demo_save'|trans }}</span>
    </button>
</div>
