{#
    Gallery: Status display -- Topbar tag vs in-cell text/`tag is-light`

    `architecture/ux-admin.md` Design Rules and Bulma allowlist:
      - status as a tag belongs in the topbar (`tag is-warning/is-danger/is-success/is-light`,
        sized `is-medium`)
      - in-cell status uses plain coloured text; for type-like categorical labels a small
        `tag is-light` is acceptable.

    Used in:    admin/system/theme/gallery/index.html.twig
    Parameters: none
#}
<p class="is-size-7 has-text-grey">
    {{ 'admin_system_gallery.source_of_truth'|trans }}
    architecture/ux-admin.md ("Bulma allowlist", "Section header info conventions")
</p>

<h3 class="title is-6 mt-4">{{ 'admin_system_gallery.tags_topbar_title'|trans }}</h3>
<p class="has-text-grey is-size-7">{{ 'admin_system_gallery.tags_topbar_caption'|trans }}</p>
<p class="mt-2">
    <span class="tag is-success is-medium">{{ 'admin_system_gallery.tags_topbar_clean'|trans }}</span>
    <span class="tag is-warning is-medium ml-2"><strong>3</strong>&nbsp;{{ 'admin_system_gallery.tags_topbar_open'|trans }}</span>
    <span class="tag is-danger is-medium ml-2"><strong>1</strong>&nbsp;{{ 'admin_system_gallery.tags_topbar_failed'|trans }}</span>
    <span class="tag is-light is-medium ml-2">{{ 'admin_system_gallery.tags_topbar_neutral'|trans }}</span>
</p>

<h3 class="title is-6 mt-5">{{ 'admin_system_gallery.tags_cell_status_title'|trans }}</h3>
<p class="has-text-grey is-size-7">{{ 'admin_system_gallery.tags_cell_status_caption'|trans }}</p>
<table class="table is-fullwidth mt-2">
    <thead>
        <tr>
            <th>{{ 'admin_system_gallery.col_name'|trans }}</th>
            <th>{{ 'admin_system_gallery.col_status'|trans }}</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>about</td>
            <td><span class="has-text-success">{{ 'admin_system_gallery.plain_status_published'|trans }}</span></td>
        </tr>
        <tr>
            <td>contact</td>
            <td><span class="has-text-grey-light">{{ 'admin_system_gallery.plain_status_draft'|trans }}</span></td>
        </tr>
        <tr>
            <td>imprint</td>
            <td><span class="has-text-danger">{{ 'admin_system_gallery.plain_status_locked'|trans }}</span></td>
        </tr>
    </tbody>
</table>

<h3 class="title is-6 mt-5">{{ 'admin_system_gallery.tags_cell_type_title'|trans }}</h3>
<p class="has-text-grey is-size-7">{{ 'admin_system_gallery.tags_cell_type_caption'|trans }}</p>
<table class="table is-fullwidth mt-2">
    <thead>
        <tr>
            <th>{{ 'admin_system_gallery.col_name'|trans }}</th>
            <th>{{ 'admin_system_gallery.tags_cell_type_col'|trans }}</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>welcome.email.twig</td>
            <td><span class="tag is-light">{{ 'admin_system_gallery.tags_cell_type_transactional'|trans }}</span></td>
        </tr>
        <tr>
            <td>digest.email.twig</td>
            <td><span class="tag is-light">{{ 'admin_system_gallery.tags_cell_type_recurring'|trans }}</span></td>
        </tr>
    </tbody>
</table>
