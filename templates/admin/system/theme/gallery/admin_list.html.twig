            <td><span class="tag is-light">{{ 'admin_system_gallery.tags_cell_type_recurring'|trans }}</span></td>
            <td>
                <a href="#" title="View"><span class="icon"><i class="fa fa-eye"></i></span></a>
                <a href="#" title="Edit"><span class="icon"><i class="fa fa-edit"></i></span></a>
                <a href="#" title="Delete"><span class="icon"><i class="fa fa-trash"></i></span></a>
