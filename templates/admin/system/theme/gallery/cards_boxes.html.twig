{#
    Gallery: Boxes & columns -- `.box` and `.columns` layout primitives

    Bulma `card` is on the avoid list for admin (see `architecture/ux-admin.md` Bulma
    allowlist). The `.box` wrapper is only valid inside section bodies; the columns
    primitive is the preferred way to lay out side-by-side blocks.

    Used in:    admin/system/theme/gallery/index.html.twig
    Parameters: none
#}
<p class="is-size-7 has-text-grey">
    {{ 'admin_system_gallery.source_of_truth'|trans }}
    architecture/ux-admin.md ("Bulma allowlist")
</p>

<h3 class="title is-6 mt-4">plain box</h3>
<div class="box">
    {{ 'admin_system_gallery.boxes_plain_body'|trans }}
</div>

<h3 class="title is-6 mt-5">box with title</h3>
<div class="box">
    <p class="title is-6 mb-2">{{ 'admin_system_gallery.sample_info_title'|trans }}</p>
    <p>{{ 'admin_system_gallery.sample_info_intro'|trans }}</p>
</div>

<h3 class="title is-6 mt-5">columns layout</h3>
<div class="columns">
    <div class="column">
        <div class="box has-text-centered">left</div>
    </div>
    <div class="column">
        <div class="box has-text-centered">middle</div>
    </div>
    <div class="column">
        <div class="box has-text-centered">right</div>
    </div>
</div>
