{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/_components/admin_tabs.html.twig' with {'adminTabs': adminTabs} only %}
        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

        <h1 class="title is-5">{{ 'admin_system_theme.heading_logo'|trans }}</h1>
        <p class="subtitle is-6 has-text-grey">{{ 'admin_system_theme.help_logo'|trans }}</p>

        <div class="columns mb-4">
            <div class="column is-one-third">
                {% if currentLogo %}
                    <p class="has-text-grey-light is-size-7 mb-2">{{ 'admin_system_theme.current_logo_label'|trans }}</p>
                    {% include '_components/image.html.twig' with {image: currentLogo, size: '400x400'} %}
                {% else %}
                    <p class="has-text-grey-light is-size-7 mb-2">{{ 'admin_system_theme.default_logo_label'|trans }}</p>
                    <img src="{{ asset('images/logo.webp') }}" alt="Default logo" width="100" height="100">
                {% endif %}
            </div>
            <div class="column">
                {{ form_start(logoForm, {'attr': {'enctype': 'multipart/form-data'}}) }}
                {{ form_row(logoForm.file) }}
                <button class="button is-primary">{{ 'global.button_save'|trans }}</button>
                {{ form_end(logoForm) }}
            </div>
        </div>

        <h1 class="title is-5">{{ 'admin_system_theme.heading_colors'|trans }}</h1>
        <p class="subtitle is-6 has-text-grey">{{ 'admin_system_theme.help_colors'|trans }}</p>

        {{ form_start(colorsForm) }}
        <div class="columns is-multiline">
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_primary, help_key: 'admin_system_theme.color_primary'} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_link, help_key: 'admin_system_theme.color_link'} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_info, help_key: 'admin_system_theme.color_info'} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_success, help_key: 'admin_system_theme.color_success'} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_warning, help_key: 'admin_system_theme.color_warning', light_text: false} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_danger, help_key: 'admin_system_theme.color_danger'} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_text_grey, help_key: 'admin_system_theme.color_text_grey', text_preview: true} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_text_grey_light, help_key: 'admin_system_theme.color_text_grey_light', text_preview: true} %}
        </div>
        <button class="button is-primary">{{ 'global.button_save'|trans }}</button>
        {{ form_end(colorsForm) }}

    </div>

{% endblock %}
