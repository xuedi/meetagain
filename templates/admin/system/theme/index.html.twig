{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/system/_tabs_navigation.html.twig' with {'activeSection': 'theme'} %}

        <h1 class="title is-5">Theme Colors</h1>
        <p class="subtitle is-6 has-text-grey">Customize the site's color scheme to match your brand. The text grey colors are optimized for WCAG AA accessibility compliance.</p>

        {{ form_start(colorsForm) }}
        <div class="columns is-multiline">
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_primary, help: 'Main buttons and highlights'} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_link, help: 'Links and clickable elements'} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_info, help: 'Information messages'} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_success, help: 'Success notifications'} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_warning, help: 'Warning alerts', light_text: false} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_danger, help: 'Errors and delete actions'} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_text_grey, help: 'Secondary text content', text_preview: true} %}
            {% include 'admin/system/theme/_color_picker.html.twig' with {field: colorsForm.color_text_grey_light, help: 'Subtle hints and metadata', text_preview: true} %}
        </div>
        <button class="button is-link">{{ "button_save" | trans }}</button>
        {{ form_end(colorsForm) }}

    </div>

{% endblock %}
