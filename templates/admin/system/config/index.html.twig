{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/_components/admin_tabs.html.twig' with {'adminTabs': adminTabs} only %}
        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

        <div class="columns">
            <div class="column is-6">

                <h1 class="title is-5">{{ 'admin_system_config.heading_website_settings'|trans }}</h1>
                {{ form_start(form) }}
                {{ form_row(form.url) }}
                {{ form_row(form.host) }}
                <div class="columns mb-0">
                    <div class="column">
                        {{ form_row(form.senderName) }}
                    </div>
                    <div class="column">
                        {{ form_row(form.senderEmail) }}
                    </div>
                </div>
                {{ form_row(form.systemUser) }}
                {{ form_row(form.dateFormat) }}

                <fieldset class="p-4 mb-4 mt-4 fieldset-default">
                    <legend class="px-2 has-text-weight-semibold is-size-7">{{ 'admin_system_config.heading_footer_columns'|trans }}</legend>
                    <div class="columns mb-0">
                        <div class="column">
                            {{ form_row(form.footerCol1Title) }}
                        </div>
                        <div class="column">
                            {{ form_row(form.footerCol2Title) }}
                        </div>
                    </div>
                    <div class="columns mb-0">
                        <div class="column">
                            {{ form_row(form.footerCol3Title) }}
                        </div>
                        <div class="column">
                            {{ form_row(form.footerCol4Title) }}
                        </div>
                    </div>
                </fieldset>

                <button class="button is-primary">{{ 'global.button_save'|trans }}</button>
                {{ form_end(form) }}

            </div>
            <div class="column is-1"></div>
            <div class="column is-5 content">

                <h1 class="title is-5">{{ 'admin_system_config.heading_on_off_settings'|trans }}</h1>
                <table class="table is-fullwidth">
                    <tbody>
                    {% for item in config %}
                        <tr>
                            <td>{{ ("admin_system_config.option_" ~ item.name)|trans }}</td>
                            <td>
                                {% if item.isBoolean %}

                                    {% include '_components/toggle.html.twig' with {
                                        'link': path('app_admin_system_boolean', {'name': item.name}),
                                        'status': item.getBoolean,
                                        'csrfTokenId': 'app_admin_system_boolean' ~ item.name,
                                    } %}

                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>

                <fieldset class="p-4 mb-4 mt-6 fieldset-default">
                    <legend class="px-2 has-text-weight-semibold is-size-7">{{ 'admin_system_config.heading_website_image'|trans }}</legend>
                    <p class="subtitle is-6 has-text-grey">{{ 'admin_system_config.help_website_image'|trans }}</p>

                    {% if currentWebsiteImage %}
                        <p class="has-text-grey-light is-size-7 mb-2">{{ 'admin_system_config.current_website_image_label'|trans }}</p>
                        {% include '_components/image.html.twig' with {image: currentWebsiteImage, size: '350x184'} %}
                    {% else %}
                        <p class="has-text-grey-light is-size-7 mb-2">{{ 'admin_system_config.no_website_image_label'|trans }}</p>
                    {% endif %}

                    {{ form_start(websiteImageForm, {'attr': {'enctype': 'multipart/form-data'}}) }}
                    {{ form_row(websiteImageForm.file) }}
                    <p class="has-text-grey is-size-7 mb-3">{{ 'admin_system_config.usage_website_image'|trans }}</p>
                    <button class="button is-primary">{{ 'global.button_save'|trans }}</button>
                    {{ form_end(websiteImageForm) }}
                </fieldset>

            </div>
        </div>

    </div>

{% endblock %}
