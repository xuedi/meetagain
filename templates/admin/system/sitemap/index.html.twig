{% extends 'admin/base.html.twig' %}

{% block content %}
<div class="container">

    {% include 'admin/system/_tabs_navigation.html.twig' with {'activeSection': 'sitemap'} %}

    <div class="level mb-4">
        <div class="level-left">
            <div class="notification is-info is-light mb-0">
                {{ 'admin_system.sitemap_info'|trans({'%total%': total}) }}
            </div>
        </div>
        <div class="level-right">
            <a class="button is-info is-light" href="https://search.google.com/search-console/sitemaps" target="_blank" rel="noopener">
                Google Search Console ↗
            </a>
        </div>
    </div>

    {% set warnings_total = urls|filter(u => u.warnings|length > 0)|length %}
    {% if warnings_total > 0 %}
    <div class="notification is-warning is-light mb-4">
        {{ 'admin_system.sitemap_warnings'|trans({'%count%': warnings_total}) }}
    </div>
    {% endif %}

    <table class="table is-fullwidth is-striped is-hoverable">
        <thead>
            <tr>
                <th>{{ 'admin_system.col_section'|trans }}</th>
                <th>{{ 'admin_system.col_label'|trans }}</th>
                <th>{{ 'admin_system.col_url'|trans }}</th>
                <th>{{ 'admin_system.col_locales'|trans }}</th>
                <th>{{ 'admin_system.col_last_mod'|trans }}</th>
                <th>{{ 'admin_system.col_warnings'|trans }}</th>
            </tr>
        </thead>
        <tbody>
        {% for entry in urls %}
            <tr{% if entry.warnings|length > 0 %} class="has-background-warning-light"{% endif %}>
                <td><span class="tag is-light">{{ entry.section }}</span></td>
                <td>{{ entry.label }}</td>
                <td>
                    <a href="{{ entry.url }}" target="_blank" rel="noopener" class="is-size-7 has-text-grey">
                        {{ entry.url }}
                    </a>
                </td>
                <td>{{ entry.locales }}</td>
                <td>{{ entry.lastmod }}</td>
                <td>
                    {% for warning in entry.warnings %}
                        <span class="tag is-warning is-light">{{ warning }}</span>
                    {% endfor %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
