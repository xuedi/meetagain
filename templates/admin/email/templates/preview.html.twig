{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/email/_tabs_navigation.html.twig' with {'activeSection': 'templates'} %}

        <div class="content">
            <h1 class="title">{{ 'admin_email_templates.button_preview'|trans }}: {{ template.identifier }}</h1>
            <p>{{ 'admin_email_templates.preview_mock_notice'|trans }}</p>
        </div>

        <div class="mb-4">
            <div class="buttons has-addons">
                {% for locale in languages %}
                    <a href="{{ path('app_admin_email_templates_preview', {id: template.id, lang: locale}) }}"
                       class="button {% if locale == currentLanguage %}is-info is-selected{% endif %}">
                        {{ locale }}
                    </a>
                {% endfor %}
            </div>
        </div>

        <div class="columns">
            <div class="column is-8">
                <div class="box">
                    <p class="mb-4"><strong>{{ 'admin_email_templates.col_subject'|trans }}:</strong> {{ renderedSubject }}</p>
                    <hr>
                    <div class="content">
                        {{ renderedBody|raw }}
                    </div>
                </div>
            </div>
            <div class="column">
                <div class="box">
                    <h3 class="subtitle">{{ 'admin_email_templates.context_variables'|trans }}</h3>
                    <table class="table is-narrow is-fullwidth">
                        {% for key, value in context %}
                            <tr>
                                <th>{{ key }}</th>
                                <td>{% if value is iterable %}{{ value|json_encode }}{% else %}{{ value }}{% endif %}</td>
                            </tr>
                        {% endfor %}
                    </table>
                </div>
            </div>
        </div>

        <div class="buttons">
            <a href="{{ path('app_admin_email_templates_edit', {id: template.id}) }}" class="button is-info">
                <span class="icon"><i class="fa fa-edit"></i></span>
            </a>
            <a href="{{ path('app_admin_email_templates') }}" class="button">{{ 'global.button_back'|trans }}</a>
        </div>

    </div>

{% endblock %}
