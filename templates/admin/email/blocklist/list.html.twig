{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/email/_tabs_navigation.html.twig' with {'activeSection': 'blocklist'} %}

        <table id="filteredTable" class="table is-fullwidth">
            <thead>
            <tr>
                <th>Email</th>
                <th>Reason</th>
                <th>Added by</th>
                <th>Added at</th>
                <th>
                    <a href="{{ path('app_admin_email_blocklist_add') }}" title="Add">
                        <span class="icon"><i class="fa fa-plus"></i></span>
                    </a>
                </th>
            </tr>
            </thead>
            <tbody>
            {% for entry in entries %}
                <tr>
                    <td>{{ entry.email }}</td>
                    <td>{{ entry.reason }}</td>
                    <td>
                        {% if entry.addedBy %}
                            {{ entry.addedBy.name }}
                        {% else %}
                            <span class="has-text-grey">-</span>
                        {% endif %}
                    </td>
                    <td>{{ entry.addedAt|date('Y-m-d H:i:s') }}</td>
                    <td>
                        <a href="{{ path('app_admin_email_blocklist_delete', {'id': entry.id}) }}" title="Delete">
                            <span class="icon"><i class="fa fa-trash"></i></span>
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="has-text-centered has-text-grey">
                        No blocklist entries.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </div>

{% endblock %}
