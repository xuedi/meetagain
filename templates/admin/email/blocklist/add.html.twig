{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/email/_tabs_navigation.html.twig' with {'activeSection': 'blocklist'} %}

        <h1 class="title">{{ 'admin_email.blocklist_add_title'|trans }}</h1>

        <div class="columns">
            <div class="column is-8">
                {{ form_start(form) }}
                {{ form_row(form.email) }}
                {{ form_row(form.reason) }}
                <div class="field mt-5">
                    {{ form_widget(form.submit) }}
                    <a href="{{ path('app_admin_email_blocklist') }}" class="button is-light">
                        <span>{{ 'global.cancel'|trans }}</span>
                    </a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>

    </div>

{% endblock %}
