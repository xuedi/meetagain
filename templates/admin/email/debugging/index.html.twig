{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/email/_tabs_navigation.html.twig' with {'activeSection': 'debugging'} %}

        <form method="post" action="{{ path('app_admin_email_debugging_send') }}">

            <div class="columns">
                <div class="column is-4">
                    <div class="field">
                        <label class="label">{{ 'admin_email_debugging.field_email_type'|trans }}</label>
                        <div class="control">
                            <div class="select is-fullwidth">
                                <select id="emailType" name="emailType">
                                    {% for emailType in emailTypes %}
                                        <option value="{{ emailType.value }}"
                                                data-context="{{ mockData[emailType.value].context|json_encode }}">
                                            {{ emailType.value }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="column is-2">
                    <div class="field">
                        <label class="label">{{ 'admin_email_debugging.field_language'|trans }}</label>
                        <div class="control">
                            <div class="select is-fullwidth">
                                <select name="language">
                                    {% for lang in languages %}
                                        <option value="{{ lang }}">{{ lang }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="column">
                    <div class="field">
                        <label class="label">{{ 'admin_email_debugging.field_recipient'|trans }}</label>
                        <div class="control">
                            <input class="input" type="email" name="recipient" placeholder="test@example.com" required>
                        </div>
                    </div>
                </div>
            </div>

            <div class="box">
                <h3 class="subtitle">{{ 'admin_email_debugging.context_variables'|trans }}</h3>
                <div id="contextFields"></div>
            </div>

            <div class="field">
                <div class="control">
                    <button type="submit" class="button is-primary">
                        <span class="icon"><i class="fa fa-paper-plane"></i></span>
                        <span>{{ 'admin_email_debugging.button_send_test'|trans }}</span>
                    </button>
                </div>
            </div>

        </form>

    </div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/admin/email-debug.js') }}" defer></script>
{% endblock %}
