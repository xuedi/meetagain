{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/_components/admin_tabs.html.twig' with {'adminTabs': adminTabs} only %}
        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

        {{ form_start(form) }}

        <div class="columns">
            <div class="column is-8">

                <p class="mb-3">
                    {{ 'admin_cms.announcement_new_intro' | trans }}
                </p>
                <div class="is-flex is-align-items-center" style="gap: 0.5rem;">
                    {{ form_widget(form.cmsPage) }}
                    <button class="button is-primary">{{ 'admin_cms.button_link_cms_page'|trans }}</button>
                </div>
            </div>
        </div>

        {{ form_end(form) }}

    </div>

{% endblock %}
