{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/email/_tabs_navigation.html.twig' with {'activeSection': 'announcements'} %}

        <h1 class="title">{{ 'admin_cms.announcement_new' | trans }}</h1>

        {{ form_start(form) }}

        <div class="columns">
            <div class="column is-8">

                <p class="mb-3">
                    {{ 'admin_cms.announcement_new_intro' | trans }}
                </p>
                {{ form_widget(form.cmsPage) }}

                <div class="field mt-3">
                    <div class="control">
                        <button class="button is-primary">{{ 'global.button_create'|trans }}</button>
                        <a href="{{ path('app_admin_email_announcements') }}" class="button">{{ 'global.button_cancel'|trans }}</a>
                    </div>
                </div>
            </div>
        </div>

        {{ form_end(form) }}

    </div>

{% endblock %}
