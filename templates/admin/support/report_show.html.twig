{% extends 'admin/base.html.twig' %}

{% block content %}

    <div class="container">

        {% include 'admin/_components/admin_tabs.html.twig' with {'adminTabs': adminTabs} only %}
        {% include 'admin/_components/admin_top.html.twig' with {'adminTop': adminTop} only %}

        <div class="columns">
            <div class="column is-narrow">
                {% if report.image %}
                    {% include '_components/image.html.twig' with {'image': report.image, 'size': '100x100'} %}
                {% else %}
                    <span class="has-text-grey">{{ 'admin_support.image_deleted'|trans }}</span>
                {% endif %}
            </div>
            <div class="column">
                <table class="table is-fullwidth">
                    <tbody>
                        <tr>
                            <th>{{ 'admin_support.label_id'|trans }}</th>
                            <td><code>{{ report.id }}</code></td>
                        </tr>
                        <tr>
                            <th>{{ 'admin_support.col_date'|trans }}</th>
                            <td>{{ report.createdAt|date('Y-m-d H:i:s') }}</td>
                        </tr>
                        <tr>
                            <th>{{ 'admin_support.col_reporter'|trans }}</th>
                            <td>
                                {% if report.reporter %}
                                    <a href="{{ path('app_admin_member_edit', {'id': report.reporter.id}) }}">
                                        {{ report.reporter.name }} ({{ report.reporter.email }})
                                    </a>
                                {% else %}
                                    <span class="has-text-grey">{{ 'admin_support.label_deleted'|trans }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>{{ 'admin_support.col_reason'|trans }}</th>
                            <td><span class="tag is-warning">{{ report.reason.label()|trans }}</span></td>
                        </tr>
                        <tr>
                            <th>{{ 'admin_support.col_remarks'|trans }}</th>
                            <td>{{ report.remarks|default('-') }}</td>
                        </tr>
                        <tr>
                            <th>{{ 'admin_support.col_location'|trans }}</th>
                            <td>
                                {% if location %}
                                    {% if location.route %}
                                        <a href="{{ path(location.route, location.params) }}" class="button is-small">
                                            <span class="icon"><i class="fa fa-external-link"></i></span>
                                            <span>{{ location.label }}</span>
                                        </a>
                                    {% else %}
                                        {{ location.label }}
                                    {% endif %}
                                {% else %}
                                    <span class="has-text-grey">{{ 'admin_support.location_unknown'|trans }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>{{ 'admin_support.col_status'|trans }}</th>
                            <td>
                                {% if report.isOpen() %}
                                    <span class="tag is-warning">{{ 'admin_support.status_open'|trans }}</span>
                                {% else %}
                                    <span class="tag is-light">{{ 'admin_support.status_resolved'|trans }}</span>
                                {% endif %}
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

{% endblock %}
