<div class="box mb-4">
    <h2 class="title is-6">{{ tile.title|trans }}</h2>
    <div style="position: relative; height: 30vh; max-height: 14rem;">
        <canvas id="{{ tile.canvasId }}"
                class="chart-container"
                data-chart="{{ tile.dataset|json_encode }}"
                data-color="{{ tile.color }}"></canvas>
    </div>
</div>
