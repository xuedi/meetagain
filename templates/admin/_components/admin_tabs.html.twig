{#
 # AdminTabs component - canonical Bulma 'tabs is-boxed' strip for admin pages.
 #
 # Inputs:
 #   adminTabs - App\Admin\Tabs\AdminTabs
 #
 # Renders tabs in the order they were added; the first AdminTab with isActive=true wears
 # the 'is-active' class. Icons use Font Awesome classes without the 'fa-' prefix; the
 # partial prepends 'fa fa-' itself.
 #}
<div class="tabs is-boxed">
    <ul>
        {% for tab in adminTabs.tabs %}
            <li class="{% if tab.isActive %}is-active{% endif %}">
                <a href="{{ tab.target }}">
                    {% if tab.icon %}
                        <span class="icon is-small"><i class="fa fa-{{ tab.icon }}" aria-hidden="true"></i></span>
                    {% endif %}
                    <span>{{ tab.label }}</span>
                </a>
            </li>
        {% endfor %}
    </ul>
</div>
