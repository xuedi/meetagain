<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{% block meta_description %}{{ get_meta_description('default') }}{% endblock %}">

    <link rel="canonical" href="{{ get_canonical_url() }}" />
    {% block meta_robots %}{% endblock %}

    {% for altLangCode, altLangLink in get_hreflang_languages() %}
        <link rel="alternate" hreflang="{{ get_hreflang_code(altLangCode) }}" href="{{ altLangLink }}" />
    {% endfor %}

    <title>{% block title %}meetAgain{% endblock %}</title>
    <meta property="og:title" content="{% block og_title %}{{ block('title') }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
    <meta property="og:url" content="{{ get_canonical_url() }}">
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:site_name" content="meetAgain">
    {% block og_image %}{% endblock %}

    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="{{ block('og_title') }}"/>
    <meta name="twitter:description" content="{{ block('og_description') }}"/>
    {% block twitter_image %}{% endblock %}

    <script type="application/ld+json">{{ get_organization_schema()|raw }}</script>

    {% if breadcrumbs is defined and breadcrumbs|length > 1 %}
    <script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{% for crumb in breadcrumbs %}{"@type":"ListItem","position":{{ loop.index }},"name":{{ crumb.label|json_encode|raw }}{% if crumb.url is defined %},"item":{{ crumb.url|json_encode|raw }}{% endif %}}{% if not loop.last %},{% endif %}{% endfor %}]}</script>
    {% endif %}

    {% block json_ld %}{% endblock %}

    <link rel="stylesheet" href="{{ asset('styles/app.scss') }}"/>
    {% if app.request.locale starts with 'zh' %}
        <link rel="stylesheet" href="{{ asset('styles/lxgw-wenkai.scss') }}"/>
    {% endif %}
    {% for stylesheetPath in get_plugin_stylesheets() %}
        <link rel="stylesheet" href="{{ asset(stylesheetPath) }}"/>
    {% endfor %}
    {% if app.environment == 'prod' %}
        <script src="{{ get_app_bundle_url() }}" defer></script>
    {% else %}
        <script src="{{ asset('js/ma-fetch.js') }}" defer></script>
        <script src="{{ asset('js/notifications.js') }}" defer></script>
        <script src="{{ asset('js/navbar.js') }}" defer></script>
        <script src="{{ asset('js/toggles.js') }}" defer></script>
        <script src="{{ asset('js/cookie-consent.js') }}" defer></script>
        <script src="{{ asset('js/modal.js') }}" defer></script>
        <script src="{{ asset('js/block-user.js') }}" defer></script>
    {% endif %}
    {% for javascriptPath in get_plugin_javascripts() %}
        <script src="{{ asset(javascriptPath) }}" defer></script>
    {% endfor %}

    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{% endblock %}
</head>
<body id="body" class="has-navbar-fixed-top mt-5">
{% include 'base_navbar.html.twig' %}
{% block body %}{% endblock %}
{% for message in app.flashes('success') %}
    <div class="notification is-success flashNotification">
        <button class="delete"></button>
        {{ message|trans }}
    </div>
{% endfor %}
{% for message in app.flashes('warning') %}
    <div class="notification is-warning flashNotification">
        <button class="delete"></button>
        {{ message|trans }}
    </div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="notification is-danger flashNotification">
        <button class="delete"></button>
        {{ message|trans }}
    </div>
{% endfor %}
{% include 'base_footer.html.twig' %}
<div id="globalImageModal" class="modal">
    <div class="modal-background"></div>
    <div class="modal-content"><div class="box" id="globalImageModalContent"></div></div>
    <div class="modal-close is-large" aria-label="close"></div>
</div>
</body>
</html>
