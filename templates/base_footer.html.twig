<footer class="footer">
    <div class="container">
        <div class="columns is-mobile is-multiline">
            <div class="column is-two-fifths is-hidden-mobile">
                {% set pluginFooterAbout = get_plugin_footer_about() %}
                {% if pluginFooterAbout %}
                    {{ pluginFooterAbout | raw }}
                {% else %}
                    <span>powered by</span> <a target="_blank" href="https://github.com/xuedi/meetAgain">meetAgain</a>
                {% endif %}
            </div>
            <div class="column is-6-mobile">
                <p>{{ 'footer_col1' | trans }}</p>
                <ul>
                    {% for menu in get_menu('col1') %}
                        {% if menu.slug != 'index' %}
                            <li>
                                <a class="is-size-5-mobile" href="{{ menu.slug }}">{{ menu.name }}</a>
                            </li>
                        {% endif %}
                    {% endfor %}
                </ul>
            </div>
            <div class="column is-6-mobile">
                <p>{{ 'footer_col2' | trans }}</p>
                <ul>
                    {% for menu in get_menu('col2') %}
                        {% if menu.slug != 'index' %}
                            <li>
                                <a class="is-size-5-mobile" href="{{ menu.slug }}">{{ menu.name }}</a>
                            </li>
                        {% endif %}
                    {% endfor %}
                </ul>
            </div>
            <div class="column is-6-mobile">
                <p>{{ 'footer_col3' | trans }}</p>
                <ul>
                    {% for menu in get_menu('col3') %}
                        {% if menu.slug != 'index' %}
                            <li>
                                <a class="is-size-5-mobile" href="{{ menu.slug }}">{{ menu.name }}</a>
                            </li>
                        {% endif %}
                    {% endfor %}
                </ul>
            </div>
            <div class="column is-6-mobile">
                <p>{{ 'footer_col4' | trans }}</p>
                <ul>
                    {% for menu in get_menu('col4') %}
                        {% if menu.slug != 'index' %}
                            <li>
                                <a class="is-size-5-mobile" href="{{ menu.slug }}">{{ menu.name }}</a>
                            </li>
                        {% endif %}
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>
</footer>
