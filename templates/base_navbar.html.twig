<nav class="navbar navbar-top is-fixed-top py-4" role="navigation" aria-label="main navigation">
    <div class="container">
        <div class="navbar-brand">
            <a class="navbar-item" href="{{ is_show_frontpage() ? path('app_frontpage') : path('app_default') }}">
                <img class="brand-logo" src="{{ site_logo_url() }}" height="40" alt="Website Logo">
            </a>
            {% include 'base_navbar_burger.html.twig' %}
        </div>
        <div id="navBarTop" class="navbar-menu">
            <div class="navbar-start">
                {% for menu in get_menu('top') %}
                    {% if menu.slug != 'index' %}
                        <a class="navbar-item" href="{{ menu.slug }}">{{ menu.name }}</a>
                    {% endif %}
                {% endfor %}
                {% for pluginLink in get_plugins_links() %}
                    <a class="navbar-item" href="{{ pluginLink.slug }}">{{ pluginLink.name | trans }}</a>
                {% endfor %}
            </div>
            <div class="navbar-end">
                {% if is_granted('ROLE_USER') %}
                    {% include 'base_navbar_menu.html.twig' %}
                {% else %}
                    <a class="navbar-item" href="{{ path('app_login') }}">{{ "chrome.menu_login" | trans }}</a>
                    {% include 'base_navbar_cookie.html.twig' %}
                {% endif %}
                {% include 'base_navbar_flags.html.twig' %}
            </div>
        </div>
    </div>
</nav>
