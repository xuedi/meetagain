{% extends 'base.html.twig' %}

{% block title %}Public Data API{% endblock %}
{% block meta_description %}REST API documentation for meetAgain. Access events, CMS pages, translations and more via authenticated endpoints.{% endblock %}

{% block body %}

    <section class="section">
        <div class="container">
            <h1 class="title is-3">API Documentation</h1>
            <p class="mb-5">
                All available endpoints. Some endpoints require a token obtained via the auth endpoint. If you can't automate
                some of your workflows via API, feel free to request more end points. They will be then implemented if they
                make sense for the greater good.
            </p>

            <div class="columns">
                <div class="column is-8">
                    {% for section in sections %}
                        <h2 class="title is-5 mt-5">
                            {{ section.title }}
                            {% if section.badge %}
                                <span class="tag is-warning is-light ml-2">{{ section.badge }}</span>
                            {% endif %}
                        </h2>
                        {% for endpoint in section.endpoints %}
                            {% include '_components/api_endpoint.html.twig' with endpoint %}
                        {% endfor %}
                    {% endfor %}
                </div>

                <div class="column is-4">
                    {% include '_components/api_toolbox_sidebar.html.twig' %}
                </div>
            </div>
        </div>
    </section>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/api-docs.js') }}" defer></script>
{% endblock %}
