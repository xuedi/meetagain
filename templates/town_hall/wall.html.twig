{% extends 'base.html.twig' %}

{% block title %}{{ 'town_hall.wall_page_title'|trans }}{% endblock %}

{% block body %}
<section class="section">
    <div class="container">
        <h1 class="title is-3">{{ 'town_hall.wall_page_title'|trans }}</h1>
        <p class="block">
            <a href="{{ path('app_townhall', { _locale: app.request.locale }) }}">
                &laquo; {{ 'town_hall.back_to_hub'|trans }}
            </a>
        </p>

        <div class="box">
            <form method="post" action="{{ path('app_townhall_wall_post', { _locale: app.request.locale }) }}" class="mb-5">
                <input type="hidden" name="_token" value="{{ csrf_token('town_hall_wall_post') }}">
                <div class="field">
                    <div class="control">
                        <textarea class="textarea" name="content" rows="3" maxlength="{{ maxContentLength }}"
                                  placeholder="{{ 'town_hall.wall_post_placeholder'|trans }}" required></textarea>
                    </div>
                </div>
                <div class="field">
                    <div class="control">
                        <button type="submit" class="button is-link">{{ 'town_hall.wall_post_submit'|trans }}</button>
                    </div>
                </div>
            </form>
        </div>

        {% if wallPosts is empty %}
            <p class="has-text-grey">{{ 'town_hall.wall_empty_state'|trans }}</p>
        {% else %}
            {% for post in wallPosts %}
                <article class="box">
                    <div class="content">
                        <p>
                            <strong>{{ post.author ? post.author.name : 'town_hall.deleted_user'|trans }}</strong>
                            <small class="has-text-grey">{{ post.createdAt|date(get_date_format()) }}</small>
                        </p>
                        <p>{{ post.content|nl2br }}</p>

                        {% if post.author and post.author.id == app.user.id %}
                            <form method="post" action="{{ path('app_townhall_wall_delete', { _locale: app.request.locale, postId: post.id }) }}" style="display:inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('town_hall_wall_delete_' ~ post.id) }}">
                                <button class="button is-small is-light is-danger" type="submit">{{ 'town_hall.wall_delete'|trans }}</button>
                            </form>
                        {% endif %}
                    </div>

                    {% if post.replies|length > 0 %}
                        <hr>
                        {% for reply in post.replies %}
                            <article class="media">
                                <div class="media-content">
                                    <div class="content">
                                        <p>
                                            <strong>{{ reply.author ? reply.author.name : 'town_hall.deleted_user'|trans }}</strong>
                                            <small class="has-text-grey">{{ reply.createdAt|date(get_date_format()) }}</small>
                                            <br>
                                            {{ reply.content|nl2br }}
                                        </p>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    {% endif %}

                    <form method="post" action="{{ path('app_townhall_wall_reply', { _locale: app.request.locale, postId: post.id }) }}" class="mt-3">
                        <input type="hidden" name="_token" value="{{ csrf_token('town_hall_wall_reply_' ~ post.id) }}">
                        <div class="field has-addons">
                            <div class="control is-expanded">
                                <input class="input is-small" type="text" name="content" maxlength="1000"
                                       placeholder="{{ 'town_hall.wall_reply_placeholder'|trans }}" required>
                            </div>
                            <div class="control">
                                <button class="button is-link is-small" type="submit">{{ 'town_hall.wall_reply_submit'|trans }}</button>
                            </div>
                        </div>
                    </form>
                </article>
            {% endfor %}

            {% set pageCount = (total / perPage)|round(0, 'ceil') %}
            {% if pageCount > 1 %}
                <nav class="pagination is-centered" aria-label="pagination">
                    {% if page > 1 %}
                        <a class="pagination-previous" href="?page={{ page - 1 }}">{{ 'town_hall.pagination_previous'|trans }}</a>
                    {% endif %}
                    {% if page < pageCount %}
                        <a class="pagination-next" href="?page={{ page + 1 }}">{{ 'town_hall.pagination_next'|trans }}</a>
                    {% endif %}
                </nav>
            {% endif %}
        {% endif %}
    </div>
</section>
{% endblock %}
