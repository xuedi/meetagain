<div class="box">
    <h2 class="title is-5">
        {{ 'town_hall.tile_images_heading'|trans }}
        <a class="is-pulled-right is-size-7" href="{{ path('app_townhall_gallery', { _locale: app.request.locale }) }}">
            {{ 'town_hall.tile_images_link_gallery'|trans }}
        </a>
    </h2>
    {% if images is empty %}
        <p class="has-text-grey">{{ 'town_hall.empty_state'|trans }}</p>
    {% else %}
        <div class="columns is-multiline is-mobile">
            {% for image in images %}
                <div class="column is-3">
                    <a href="{{ path('app_event_details', { _locale: app.request.locale, id: image.event.id }) }}">
                        <figure class="image is-square">
                            <img src="/images/thumbnails/{{ image.hash }}_100x100.webp" alt="{{ image.event.title(app.locale) }}">
                        </figure>
                    </a>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
