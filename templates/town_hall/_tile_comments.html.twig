<div class="box">
    <h2 class="title is-5">{{ 'town_hall.tile_comments_heading'|trans }}</h2>
    {% if comments is empty %}
        <p class="has-text-grey">{{ 'town_hall.empty_state'|trans }}</p>
    {% else %}
        {% for comment in comments %}
            <article class="media">
                <div class="media-content">
                    <div class="content">
                        <p>
                            <strong>{{ comment.user ? comment.user.name : 'town_hall.deleted_user'|trans }}</strong>
                            <small class="has-text-grey">{{ comment.createdAt|date(get_date_format()) }}</small>
                            <br>
                            {{ comment.content|striptags|u.truncate(180, '...') }}
                            <br>
                            <a class="is-size-7" href="{{ path('app_event_details', { _locale: app.request.locale, id: comment.event.id }) }}">
                                {{ comment.event.title(app.locale) }}
                            </a>
                        </p>
                    </div>
                </div>
            </article>
        {% endfor %}
    {% endif %}
</div>
