<div class="navbar-item dropdown is-hoverable" id="cookie-consent-dropdown" role="region" aria-label="{{ "cookie.consent_headline" | trans }}">
    <div class="dropdown-trigger">
        <button
            class="button cookie-button"
            aria-haspopup="dialog"
            aria-expanded="false"
        >
            <span class="cookie-consent-label is-hidden">{{ "cookie.consent_button" | trans }}</span>
            <span class="icon is-small">
                <i class="fas fa-angle-down" aria-hidden="true"></i>
            </span>
        </button>
    </div>
    <div class="dropdown-menu" id="dropdown-cookie">
        <div class="dropdown-content" role="dialog" aria-labelledby="cookie-form-title" aria-describedby="cookie-form-description">
            <form action="{{ path('app_cookie') }}" method="post" aria-labelledby="cookie-form-title">
                <h2 id="cookie-form-title" class="navbar-item title is-5 mb-0">{{ "cookie.consent_headline" | trans }}</h2>
                <p id="cookie-form-description" class="navbar-item is-6">
                    {{ "cookie.consent_text" | trans }}
                </p>
                <h3 id="cookie-options-title" class="navbar-item title mt-5 mb-0 is-size-6">{{ "cookie.options" | trans }}</h3>
                <div class="navbar-item">
                    <div class="list" role="group" aria-labelledby="cookie-options-title">
                        <div class="list-item mt-0">
                            <div class="list-item-content">
                                <div class="list-item-title">
                                    <label class="checkbox" for="osm_consent_checkbox">
                                        <input
                                            type="checkbox"
                                            name="osm_consent_checkbox"
                                            {% if show_osm() %}checked{% endif %}
                                            id="osm_consent_checkbox"
                                            aria-describedby="osm-description"
                                        />
                                        <strong>{{ "cookie.option_osm" | trans }}</strong>
                                    </label>
                                </div>
                                <div id="osm-description" class="list-item-description has-text-grey is-size-7">
                                    {{ "cookie.option_osm_text" | trans }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="navbar-item">
                    <button
                        type="button"
                        class="button mr-2 cookieTrigger"
                        data-url="{{ path('app_ajax_cookie_accept') }}"
                        aria-label="{{ "cookie.button_accept" | trans }}"
                    >{{ "cookie.button_accept" | trans }}</button>
                    <button
                        type="button"
                        class="button mr-2 cookieTrigger"
                        data-url="{{ path('app_ajax_cookie_deny') }}"
                        aria-label="{{ "cookie.button_deny" | trans }}"
                    >{{ "cookie.button_deny" | trans }}</button>
                    <a
                        href="{{ path('app_cookie') }}"
                        class="button"
                        aria-label="{{ "cookie.button_status" | trans }}"
                    >{{ "cookie.button_status" | trans }}</a>
                </div>
            </form>
        </div>
    </div>
</div>