{
	admin off
	log default {
		output stdout
		format console
		level WARN
	}

	frankenphp {
		php_ini {
			memory_limit 1G
			max_execution_time 300
			upload_max_filesize 256M
			post_max_size 512M
		}
	}
}

# HTTPS with custom certificate for *.meetagain.local
*.meetagain.local, meetagain.local {
	tls /certs/meetagain.local.crt /certs/meetagain.local.key

	root * /var/www/html/public
	encode zstd br gzip

	@phpRoute {
		not file {path}
	}
	rewrite @phpRoute index.php

	@frontController path index.php
	php @frontController

	file_server {
		hide *.php
	}
}

# Localhost (HTTP only, no certificate needed)
http://localhost {
	root * /var/www/html/public
	encode zstd br gzip

	@phpRoute {
		not file {path}
	}
	rewrite @phpRoute index.php

	@frontController path index.php
	php @frontController

	file_server {
		hide *.php
	}
}
